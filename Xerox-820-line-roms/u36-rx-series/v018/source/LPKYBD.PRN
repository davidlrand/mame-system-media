Internal Equates

                                
                                
                                
                                ;	Internal equates
                                
  001D                          rtab1	equ	29		;rigid disk tables sector 1
  001E                          rtab2	equ	30		;  "    "      "     "    2
  0004                          ftab1	equ	04		;floppy	"      "     "    1
  0005                          ftab2	equ	05		;  "    "      "     "    2
  0006                          ftab3	equ	06		;  "    "      "     "    3
                                
