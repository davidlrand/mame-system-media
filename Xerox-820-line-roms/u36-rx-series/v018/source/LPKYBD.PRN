  0533'                         rxsign:				;source address in rom
                                	.phase	tca		;execution in transient command area
                                
  FC52    21 F091               signon:	ld	hl,confg	;point to configuration byte
  FC55    7E                    	ld	a,(hl)		;get configuration byte
