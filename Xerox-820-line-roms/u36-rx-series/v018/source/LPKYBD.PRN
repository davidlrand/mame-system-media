RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-9
RX1984 Restart

                                
                                
  0000'                         start:
                                
                                
                                	.phase	rx1984
                                
                                ;;	RX1984
                                ;		Entry here from Xerox monitor bfore entering SIGNON.
                                ;
                                ;
  1800    21 0000               	ld	hl,0		
  1803    CD F08B               	call	config		;get monitor configuration
  1806    7C                    	ld	a,h
  1807    FE 00                 	cp	rev0
  1809    CA 1877               	jp	z,noload	;skip if below 4.0
                                
  180C    DD E1                 	pop	ix		;throw away return address
  180E    C1                    	pop	bc		;BC <- table size 
  180F    D1                    	pop	de		;DE <- destination of monitor ext
  1810    E1                    	pop	hl		;HL <- extended jump table address
  1811    D5                    	push	de		;save destination address
  1812    ED B0                 	ldir			;append monitor table with lpkybd jmp vectors
  1814    E1                    	pop	hl		;HL <- monitor extension address
  1815    E5                    	push	hl		;save monitor extension address
  1816    23                    	inc	hl		
  1817    36 AF                 	ld	(hl),low lpkybd	;store address of low profile kbd in
  1819    23                    	inc	hl		; jump table
  181A    36 F9                 	ld	(hl),high lpkybd
  181C    D1                    	pop	de
  181D    C1                    	pop	bc		;BC <- table size
  181E    DD E1                 	pop 	ix		;IX <- address of low profile interface
  1820    D5                    	push	de		;monitor extension address
  1821    F5                    	push	af		;save monitor level
  1822    DD 22 FA08            	ld	(lpiadr),ix	;store address
  1826    DD 6E 00              	ld	l,(ix)		;HL - address of config byte
  1829    DD 23                 	inc	ix		;update address pointer	
  182B    DD 66 00              	ld	h,(ix)
  182E    DD 23                 	inc	ix		;update address pointer
  1830    7E                    	ld	a,(hl)		;A - configuration byte
  1831    F6 08                 	or	kblp			;set low profile bit flag
  1833    77                    	ld	(hl),a		;store configuration byte
                                
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-10
RX1984 Restart

                                
                                ;	alter BOOT commnd vectors
                                
                                
  1834    F1                    	pop	af
  1835    DD 6E 00              	ld	l,(ix)		;HL <- address in cmdtab to change
  1838    DD 23                 	inc	ix
  183A    DD 66 00              	ld	h,(ix)
  183D    DD 23                 	inc	ix
  183F    36 32'                	ld	(hl),low rxboot
  1841    23                    	inc	hl
  1842    36 06'                	ld	(hl),high rxboot
  1844    DD 6E 00                	ld	l,(ix)
  1847    DD 23                 	inc	ix
  1849    DD 66 00              	ld	h,(ix)
  184C    DD 23                 	inc	ix
  184E    36 32'                	ld	(hl),low rxboot
  1850    23                    	inc	hl
  1851    36 06'                	ld	(hl),high rxboot
                                	
                                ;	cp	rev1				;monitor check
                                ;	jr	z,soout				;skip if 4.01 monitor
                                
                                ;	ld	(ix+boff1),low (rxboot+romofs)	;4.02+ monitor boot over addr
                                ;	ld	(ix+boff1+1),high (rxboot+romofs)
                                
                                ;	ld	(ix+boff2),low (rxboot+romofs)
                                ;	ld	(ix+boff2+1),high (rxboot+romofs)
                                
  1853                          soout:
                                
                                ;	alter keyboard interrupt service
                                
  1853    DD 6E 00              	ld	l,(ix)
  1856    DD 23                 	inc	ix			;update address pointer
  1858    DD 66 00              	ld	h,(ix)			;hl - address of ext jump table
  185B    DD 23                 	inc	ix			;update interface address pointer
  185D    36 CD                 	ld	(hl),0cdh			;
  185F    23                    	inc	hl
  1860    D1                    	pop	de
  1861    73                    	ld	(hl),e
  1862    23                    	inc	hl
  1863    72                    	ld	(hl),d
  1864    23                    	inc	hl
  1865    DD 22 FA08            	ld	(lpiadr),ix		;save interface address pointer
                                
                                ;	Move in RX SIGNON to o/l area and execute it
                                
                                
  1869    21 0533'              	ld	hl,rxsign		;rom address
  186C    11 FC52               	ld	de,tca			;o/l area
  186F    01 00FF               	ld	bc,rxsigl		;length
  1872    ED B0                 	ldir
                                
  1874    C3 FC52               	jp	tca			;GO SIGN ON
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-11
RX1984 Restart

                                
  1877    E1                    noload:	pop	hl			;return address
  1878    C1                    	pop	bc			;throw away low profile keyboard
  1879    C1                    	pop	bc			;  interface addresses
  187A    C1                    	pop	bc
  187B    C1                    	pop	bc
  187C    C1                    	pop	bc
  187D    E5                    	push	hl			;save return address
  187E    3E FF                 	ld	a,x'ff'			;wrong monitor
  1880    A7                    	and	a			;load signon from monitor
  1881    C9                    	ret
                                
                                
                                
                                
                                	subttl	ROM resident (crt driver)
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-12
ROM resident (crt driver)

                                
                                
                                ;;	crtdvr - Crt Driver RX Addition.
                                ;
  1882                          rxcrt:
  1882    2A FFAC               	ld	hl,(cursor)	;set cursor address
  1885    3A FFB4               	ld	a,(chrsav)	;retrieve character under cursor
  1888    77                    	ld	(hl),a		;replace character under cursor
  1889    32 F319               	ld	(gold),a	;bury balcones gold
  188C    3A FFB2               	ld	a,(leadin)	;set leadin state
  188F    B7                    	or	a
  1890    C2 0196               	jp	nz,crtd2	;if processing escape sequence
  1893    3A F0E3               	ld	a,(mask)	;get keyboard mask
  1896    A1                    	and	c
  1897    4F                    	ld	c,a
  1898    FE 20                 	cp	' '
  189A    DA 0196               	jp	c,crtd2		;if control code
  189D    CD 18A3               	call	fonchk		;do font translation
  18A0    C3 0182               	jp	crtd1		;go to XR code
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-13
ROM resident (crt driver)

                                
                                	;;subroutine fonchk does the font translation for national
                                	;character sets
                                
                                	; entry:  C contains the character
                                	; exit:   C contains the translation
                                
                                
  18A3                          fonchk:
  18A3    E5                    	push	hl		;save cursor posn.
                                
  18A4    79                    	ld	a,c		;get char in a
  18A5    E6 80                 	and	10000000b	;preserve attribute bit
  18A7    F5                    	push	af
  18A8    21 FFB3               	ld	hl,attrib	;point to attribute enabled flag
  18AB    B6                    	or	(hl)		;test if set
  18AC    28 0A                 	jr	z,fon1		;no attribute bit - go do translation
  18AE    11 01DD               	ld	de,grpad	;check if graphics mode
  18B1    2A F339               	ld	hl,(prvatt)	;current attribute mode
  18B4    ED 52                 	sbc	hl,de
  18B6    28 0F                 	jr	z,fon2		;grahics mode - no translate
  18B8                          fon1:				;here to do translate
  18B8    79                    	ld	a,c
  18B9    CB BF                 	res	7,a		;clear attribute bit
                                
  18BB    21 F960               	ld	hl,fontbl	;address of exceptions table
  18BE    01 000D               	ld	bc,fontsz	;size of exceptions table
  18C1    ED B1                 	cpir			;search for char. in exceptions
  18C3    4F                    	ld	c,a		;restore char to c
  18C4    CC 18CC               	call	z,fntran	;if found do translation
  18C7    F1                    fon2:	pop	af		;retrieve attribute bit
  18C8    B1                    	or	c		;or it in
  18C9    4F                    	ld	c,a
                                
  18CA    E1                    	pop	hl		;retrieve cursor
  18CB    C9                    	ret
                                
                                	;;	s/r fntran translates font characters
                                	;	entry: (HL) - address+1 of char to be translated in fontbl
                                	;	exit:  (c)  - translated character
                                
  18CC                          fntran:
  18CC    2B                    	dec	hl		;back to byte to be translated
  18CD    01 000D               	ld	bc,fontsz	;size of table
  18D0    09                    	add	hl,bc		;add to address of char. to be translated
  18D1    4E                    	ld	c,(hl)		;get translated value
  18D2    C9                    	ret
                                
                                	subttl	ROM resident (screenprint routine)
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-14
ROM resident (screenprint routine)

                                
                                
                                ;;	This routine is called from the Xerox screenprint handler. It
                                ;	picks up the character to be printed from the crt ram, does a
                                ;	reverse font translate,replaces any control codes with a space,
                                ;	does a printer translate and outputs the character to the printer.
                                
                                ;	entry:- HL - address of byte to be printed
  18D3                          scrprt:				;entry point
                                	if	skip
                                	ld	(hlsav),hl	;save registers
                                	ld	(bcsav),bc
                                	endif
  18D3    E5                    	push	hl
  18D4    C5                    	push	bc
                                
  18D5    7E                    	ld	a,(hl)		;byte for printing
  18D6    CB BF                 	res	7,a		;ignore attribute bit
                                				;do reverse font translate
  18D8    21 F96D               	ld	hl,fontbl+fontsz	;point to translates
  18DB    01 000D               	ld	bc,fontsz
  18DE    ED B1                 	cpir			;search for char.
  18E0    20 07                 	jr	nz,scr01	;not in table
                                				;in table convert to media code
  18E2    01 000D               	ld	bc,fontsz	;offset back to media code
  18E5    37                    	scf
  18E6    ED 42                 	sbc	hl,bc		;points to media code
  18E8    7E                    	ld	a,(hl)
  18E9                          scr01:				;here with media code
  18E9    FE 20                 	cp	20h		;is it a control code
  18EB    30 02                 	jr	nc,scr02	;no
  18ED    3E 20                 	ld	a,20h		;yes. substitute a space
  18EF                          scr02:
  18EF    CD 1963               	call	potran		;do printer translation
  18F2    20 0D                 	jr	nz,scr03	;no translation done. go output char.
                                				;translation done.check escape bit
  18F4    CB 7F                 	bit	7,a		;escape bit
  18F6    28 09                 	jr	z,scr03		;not set go output char
  18F8    4F                    	ld	c,a		;set. save char.
  18F9    3E 1B                 	ld	a,esc		;output an escape
  18FB    CD 1956               	call	posout		;output routine
  18FE    79                    	ld	a,c		;restore char.
  18FF    CB BF                 	res	7,a		;clear escape bit
  1901                          scr03:
  1901    CD 1956               	call	posout		;print char
                                
                                	if 	skip
                                	ld	hl,(hlsav)	;restore registers
                                	ld	bc,(bcsav)
                                	endif
  1904    C1                    	pop	bc
  1905    E1                    	pop	hl
  1906    C3 F232               	jp	sprnt2		;return to Xerox code
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-15
ROM resident (screenprint routine)

                                
                                ;	Exception print driver - ROM entry point
                                ;
  1909    C5                    rmposend: push	bc
  190A    E5                    	push	hl
  190B    CD 1911               	call	posend
  190E    E1                    	pop	hl
  190F    C1                    	pop	bc
  1910    C9                    	ret
                                
                                ;;	posend - deals with character translation and escape
                                ;		 sequences for the diablo 630
                                ;		 input--- a contains char for output to channel b
  1911                          posend:
  1911    4F                    	ld	c,a
                                
  1912    3A F9A6               	ld	a,(escsq)	;in an escape sequence?
  1915    B7                    	or	a
  1916    20 22                 	jr	nz,pos04	;yes
                                
  1918    79                    	ld	a,c
  1919    FE 1B                 	cp	esc		;escape char?
  191B    20 07                 	jr	nz,pos01	;no
                                
  191D    CD 1956               	call	posout		;output char
  1920    32 F9A6               	ld	(escsq),a	;set escape sequence flag
  1923    C9                    	ret
                                
  1924                          pos01:				;not escape char
  1924    CD 1963               	call	potran		;do translation if neccessary
  1927    20 0D                 	jr	nz,pos03	;wasn't neccessary
                                
  1929    CB 7F                 	bit	7,a		;escape marker set?
  192B    28 09                 	jr	z,pos02		;no
                                
  192D    4F                    	ld	c,a
  192E    3E 1B                 	ld	a,esc
  1930    CD 1956               	call	posout		;output escape char
                                
  1933    79                    	ld	a,c
  1934    CB BF                 	res	7,a		;clear escape marker
                                
  1936                          pos02:				;escape marker not set
  1936                          pos03:				;no translation
  1936    CD 1956               	call posout		;output char
  1939    C9                    	ret
                                
  193A                          pos04:				;escape sequence
  193A    FE FF                 	cp	0ffh		;3rd byte?
  193C    20 06                 	jr	nz,pos05	;no 2nd
                                
  193E    79                    	ld	a,c
  193F    CD 1956               	call	posout		;output char
  1942    18 0D                 	jr	pos06
                                
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-16
ROM resident (screenprint routine)

                                
  1944                          pos05:				;2nd byte of escape sequence
  1944    79                    	ld	a,c
  1945    CD 1956               	call	posout		;output byte
                                
  1948    CD 1983               	call	poesc		;search escape table for char
  194B    20 04                 	jr	nz,pos06	;not present---2 byte sequence
                                
  194D    3E FF                 	ld	a,0ffh		;set sequence for 3rd byte
  194F    18 01                 	jr	pos07
                                
  1951                          pos06:				;end of 2 byte sequence
  1951    AF                    	xor	a
  1952    32 F9A6               pos07:	ld	(escsq),a	;toggle escape sequence flag
  1955    C9                    	ret
                                
                                ;escsq:	defb	0		;escape sequence flag
                                				;0=> no sequence in progress
                                				;1b=> expecting 2nd byte
                                				;ff=> expecting 3rd byte
                                
                                
  1956                          posout:
                                	if	skip
                                	push	af
                                	endif
  1956    47                    	ld	b,a
  1957    CD F03F               siox1:	call	siordy
  195A    CC F066               	call	z,idle
  195D    28 F8                 	jr	z,siox1
                                	if	skip
                                	pop	af
                                	endif
  195F    78                    	ld	a,b
  1960    D3 05                 	out	(siodpb),a
  1962    C9                    	ret
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-17
ROM resident (screenprint routine)

                                
                                
                                ;;	potran - does printer translation if neccessary and returns
                                ;		 a flag to indicate if translation has been done.
                                
                                ;		input- a  char for translaation
                                
                                ;		output- a  (translated) char
                                ;			z  set if char is translated (otherwise reset)
                                
  1963                          potran:
  1963    21 F97A               	ld	hl,prntbl	;print exceptions table
  1966    01 0016               	ld	bc,prntsz	;size of table
  1969    ED B1                 	cpir
  196B    C0                    	ret	nz		;no match - don't translate
                                
  196C    2B                    	dec	hl		;translate
  196D    01 0016               	ld	bc,prntsz
  1970    09                    	add	hl,bc		;offset to translation
  1971    7E                    	ld	a,(hl)		;translation byte
  1972    B7                    	or	a		;if zero, requires overstriking sequence
  1973    20 0B                 	jr	nz,ptr01	;non-zero - go output char
                                				;zero - use next 2 bytes in table as sequence
  1975    23                    	inc	hl
  1976    7E                    	ld	a,(hl)		;first byte
  1977    CD 1956               	call	posout
  197A    3E 08                 	ld	a,08h		;backspace
  197C    CD 1956               	call	posout
  197F    23                    	inc	hl		;second byte
                                
  1980    AF                    ptr01:	xor	a		;set z for return flag
  1981    7E                    	ld	a,(hl)		;get translation
  1982    C9                    	ret
                                
                                
                                ;;	poesc - searches the escape table for a match with the char
                                ;		passed in a. if found returns with z set otherwise
                                ;		z is clear
                                
  1983                          poesc:
  1983    21 198C               	ld	hl,pesctb	;table of escape sequences
  1986    01 0007               	ld	bc,esctsz	;size of table
  1989    ED B1                 	cpir
  198B    C9                    	ret
                                
  198C    09 0B 0C 1E           pesctb:	defb	09h,0bh,0ch,1eh,1fh,16h,11h	;630 daisy printer
  1990    1F 16 11              
  0007                          esctsz	equ	$-pesctb
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-18
ROM resident (screenprint routine)

                                
  1993                          pekhdl:	;function:- to deal with characters form a position
                                	;	    encoded keyboard.
                                	;input:-    A  character read from PIO
                                	;		CMD/STATUS byte
                                	;	bit 7 -CMD/STATUS byte if set
                                	;	bit 6 -upstroke flag
                                	;	bit 5 -y axis negative (mouse)
                                	;	bit 4 -x axis negative (mouse)
                                	;	bit 3 -mouse active
                                	;	bit 2 -ctrl key station active
                                	;	bit 1 -shift key station active
                                	;	bit 0 -lock key station active
                                	;		First data byte
                                	;	bit 7 -Always reset
                                	;	bits(6-0) -key station or x mouse displacement
                                	;		Second mouse data byte
                                	;	bit 7 -Always reset
                                	;	bits(6-0) -y mouse displacement
                                	;
                                	;output:-   1) Carry set -- command byte or sequence error
                                	;	    2) Carry clear -- translated character returned in A
                                
  1993    2F                    	cpl			;complement keyboard byte
  1994    D5                    	push	de		;save registers
  1995    16 00                 	ld	d,zero		;get flags
  1997    CB 7F                 	bit	cmd,a		;command byte?
  1999    28 17                 	jr	z,kypos		;skip to position byte handler
  199B    18 01                 	jr	cmdb		;skip to command byte handler
  199D                          nochar	equ	$
  199D    7A                    peknoc2: ld	a,d		;clear command byte (non-valid position byte)
                                
  199E    32 F9A7               cmdb:	ld	(cmdstat),a	;save command-status byte
  19A1    CB 5F                 	bit	mouse,a		;mouse cmd?
  19A3    28 05                 	jr	z,peknoc	;skip if not mouse
  19A5    21 F95D               	ld	hl,mstbl
  19A8    CB 8E                 	res	xy,(hl)
  19AA    CD 1A63               peknoc:	call	stpctc1		;reset repeat flag
  19AD    37                    peknoc1: scf			;this no the position byte
  19AE    D1                    pekex:	pop	de		;recover registers
  19AF    C3 F9B7               	jp	lpkext		;jmp instead of ret - small interrupt stack
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-19
ROM resident (screenprint routine)

                                
  19B2    5F                    kypos:	ld	e,a		;save position code
  19B3    21 F9A7               	ld	hl,cmdstat	;fetch command byte
  19B6    CB 7E                 	bit	cmd,(hl)	;out of sync check
  19B8    28 F0                 	jr	z,peknoc	;quit if no command byte
  19BA    CB 5E                 	bit	mouse,(hl)	;test for mickey mouse movement
  19BC    C2 1A7A               	jp	nz,mice		;skip if mickey mouse moved
  19BF    CB 76                 	bit	ustrk,(hl)	;test key posistion
  19C1    20 20                 	jr	nz,upstrk	;jump if special upstroke
  19C3    CD 19D8               	call	ctrtst		;test for control codes
  19C6    28 D5                 	jr	z,peknoc2	;quit if non printable control character
  19C8    CD 19FC               	call	tblsel		;select translation table
  19CB    CD 1A20               	call	alphtst		;test for alpha lock char
  19CE    CD 1A3A               	call	rptst		;test for repeat keys
  19D1    21 F9A7               charout: ld	hl,cmdstat	;fetch command byte
  19D4    72                    	ld	(hl),d		;clear command byte (valid position byte)
  19D5    A7                    	and	a		;clear carry
  19D6    18 D6                 	jr	pekex
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-20
ROM resident (screenprint routine)

                                
  19D8                          ctrtst:
                                	;Character is tested for the lock, shift, and ctrl key station.
                                	;
                                	;input	a - key station code
                                	;
                                	;output z - set if lock,shift, or ctrl key station
                                	;
  19D8    E5                    	push	hl		;save registers
  19D9    21 F953               	ld	hl,ctrltb	;non printable char table
  19DC    01 0006               	ld	bc,cntctr	;byte count of table
  19DF    ED B1                 	cpir			;search table
  19E1    E1                    	pop	hl
  19E2    C9                    	ret
                                
  19E3                          upstrk:
                                	;The up-stroke is tested for special up-stroke key-stations.
                                	;
                                	;input	a - key station code
                                	;	strkup - user enable flag
                                	;
                                	;output	a - translated up-stroke key-station code
                                	;
  19E3    21 F95D               	ld	hl,mstbl	;user enable up-stroke flag
  19E6    CB 5E                 	bit	strkup,(hl)
  19E8    28 B3                 	jr	z,nochar	;quit if user inhibited
                                	
  19EA    21 F959               	ld	hl,ups		;exception key-station table
  19ED    01 0002               	ld	bc,upssz	;byte count of table
  19F0    ED B1                 	cpir			;search table
  19F2    20 A9                 	jr	nz,nochar	;quit if no match
                                
  19F4    2B                    	dec	hl		;get exception
  19F5    01 0002               	ld	bc,upssz
  19F8    09                    	add	hl,bc
  19F9    7E                    	ld	a,(hl)
                                
  19FA    18 D5                 	jr	charout		;return translated character
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-21
ROM resident (screenprint routine)

                                
  19FC                          tblsel:
                                	;The appropriate keyboard translation table is selected
                                	;
                                	;input	hl - command-status address
                                	;	de - key station code
                                	;
                                	;output	a  - translated key station code
                                	;
  19FC    7E                    	ld	a,(hl)		;move cmd-status byte
  19FD    E5                    	push	hl		;save command-status ptr
  19FE    21 F867               	ld	hl,shtab	;preset to shift table
  1A01    CB 4F                 	bit	shift,a		;shift bit set?
  1A03    20 17                 	jr	nz,cmdb1	;skip if set
                                
  1A05    21 F8CE               	ld	hl,cdtab	;preset to control table
  1A08    CB 57                 	bit	ctrl,a		;control bit set?
  1A0A    20 10                 	jr	nz,cmdb1	;skip if set
                                
  1A0C    21 F800               	ld	hl,tabl		;preset to un shifted table
  1A0F    CB 47                 	bit	lock,a		;lock key set
  1A11    28 09                 	jr	z,cmdb1		;skip if reset
                                
  1A13    3A F93B               	ld	a,(shftlck)	;lock key set
  1A16    A7                    	and	a		;test for shift lock (not alpha lock)
  1A17    28 03                 	jr	z,cmdb1		;skip if reset
                                
  1A19    21 F867               	ld	hl,shtab	;preset to shift table
                                
  1A1C                          cmdb1:				;here with translation table address in hl
  1A1C    19                    	add	hl,de		;index into table
  1A1D    7E                    	ld	a,(hl)		;get translated char
  1A1E    E1                    	pop	hl		;recover command-status ptr
  1A1F    C9                    	ret
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-22
ROM resident (screenprint routine)

                                
  1A20                          alphtst:
                                	;If the lock key is depressed, the translated character is
                                	;tested to see if it is an alphabet.  If it is lower case,
                                	;then it is forced upper case.
                                	;
                                	;input	hl - command-status address
                                	;	a  - translated character
                                	;
                                	;output a  - translated character(upper chase if alpha+lock)
                                	;
  1A20    CB 46                 	bit	lock,(hl)	;test alpha lock flag
  1A22    C8                    	ret	z		;quit if not alpha lock
                                
  1A23    FE 7B                 	cp	upper		;test for upper alpha range
  1A25    30 06                 	jr	nc,alphexc	;skip if non alpha range
  1A27    FE 61                 	cp	lower		;test for lower case alpha range
  1A29    38 02                 	jr	c,alphexc	;skip if not lower alpha case
  1A2B    D6 20                 	sub	upascii		;set upper case ASCII alpha character
                                
                                
  1A2D                          alphexc:
                                	;Three additional caracters are allowed for the alpha lock key
                                	;
                                	;input	hl - command-status address
                                	;	a  - translated character
                                	;
                                	;output	a  - upper case exception
                                	;
  1A2D    21 F935               	ld	hl,captab		;lock exception table
  1A30    01 0003               	ld	bc,cptbsz		;table size
  1A33    ED B1                 	cpir				;search
  1A35    C0                    	ret	nz			;quit if not found
                                
  1A36    23                    	inc	hl			;get exception
  1A37    23                    	inc	hl
  1A38    7E                    	ld	a,(hl)
  1A39    C9                    	ret
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-23
ROM resident (screenprint routine)

                                
  1A3A                          rptst:
                                	;Checks for repeat character.  If repeat character, the millisec
                                	;timer is vector address is modified and the timer is set up
                                	;for 0.5 second.  The timer is kicked off.
                                	;
                                	;input	a - translated character
                                	;
  1A3A    21 F940               	ld	hl,rptbl	;repeat char table
  1A3D    01 0013               	ld	bc,cntrp	;number of repeat chars
  1A40    ED B1                 	cpir			;test for repeat chars
  1A42    C0                    	ret	nz		;quit if not repeat char
                                
  1A43    2A F93C               	ld	hl,(tick)	;millisec count
  1A46    22 F9A8               	ld	(millcnt),hl	;save it in table
  1A49    21 F9AA               	ld	hl,rptchar	;repeat char save address
  1A4C    77                    	ld	(hl),a		;save repeat char
  1A4D    F5                    	push	af
  1A4E    23                    	inc	hl		;repeat flag address
  1A4F    36 FF                 	ld	(hl),setflg	;set repeat flag
                                
  1A51    2A FF12               	ld	hl,(ctcvec+2)	;get 1 millisec interrupt vector
  1A54    22 F9AC               	ld	(save),hl	;save it
  1A57    21 F9D0               	ld	hl,rptclk	;kybd repeat key timer
  1A5A    22 FF12               	ld	(ctcvec+2),hl	;substitute it
                                
  1A5D    3E 81                 strctc1: ld	a,encntr	;enable millisec timmer
  1A5F    D3 19                 	out	(ctc1),a	;do it
  1A61    F1                    	pop	af		;recover character
  1A62    C9                    	ret
                                
                                
  1A63                          stpctc1:
                                	;This routine stops the millisecond timer and restores the
                                	;original timer vector
                                
  1A63    21 F9AB               	ld	hl,rptflg	;fetch repeat char flag
  1A66    7E                    	ld	a,(hl)
  1A67    A7                    	and	a		;set flags
  1A68    C8                    	ret	z		;quit if no repeat keys
                                
  1A69    72                    	ld	(hl),d		;clear repeat char flag
  1A6A    2A F9AC                	ld	hl,(save)	;original 1 millisec interrupt address
  1A6D    22 FF12               	ld	(ctcvec+2),hl	;restore it
                                
  1A70    3A F20E               	ld	a,(spact)	;fetch screen print flag
  1A73    A7                    	and	a
  1A74    C0                    	ret	nz		;don't kill timer, if screen printing
                                
  1A75    3E 01                 	ld	a,stcntr	;stop timer 
  1A77    D3 19                 	out	(ctc1),a
  1A79    C9                    	ret
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-24
ROM resident (screenprint routine)

                                
  1A7A                          mice:	;This is the optical mouse handler.  The delta x and y mouse
                                	;movement is accumulate and stored in memory locations.
                                	;
                                	;input	a=	mouse delta either x or y
                                	;	xy=	zero for x mouse delta
                                	;		x'ff' for y mouse delta
                                	;	hl=	cmdstat address
                                	;	cmdstat=bit 3	mouse moved
                                	;		bit 4	x delta negative
                                	;		bit 5	y delta negative
                                	;	mstbl  =bit 7	mouse enabled user flag
                                	;		bit 6	intrp/npol
                                	;		bit 1	y/nx byte
                                	;		bit 0	mouse table is updated
                                	;	mbyte  =interrupt return byte
                                	;	xmax   =maximum horizontal display units
                                	;	ymax   =maximum vertical display units
                                	;
                                	;output mstbl=	bit 0, mouse table updated
                                	;	xloc=	x position of mouse
                                	;	yloc=	y position of mouse
                                	;	dxmv=	prior x signed displacement
                                	;	dymv=	prior y signed displacement
                                	;
                                	;special requirements
                                	;	The majority of the mouse-pointer table is require memory
                                	;	resident in the in the user address space above X'BFFF'
                                	;	since this handle is ROM resident.  Variables MSTBL AND MSPTR
                                	;	reside in keyboard RAM space.  Variable MSPTR pointers to
                                	;	where the user mouse table resides.  These variable are
                                	;	update by both the handler and the user.  The following
                                	;	data structure resides in the user's RAM space only if
                                	;	the two-button mouse pointer is required for the applicaton:
                                	;	(MSPTR+0)	=MBYTE
                                	;	(MSPTR+1)	=XMAX-LSB
                                	;	(MSPTR+2)	=    -MSB
                                	;	(MSPTR+3)	=YMAX-LSB
                                	;	(MSPTR+4)	=    -MSB
                                	;	(MSPTR+5)	=XLOC-LSB
