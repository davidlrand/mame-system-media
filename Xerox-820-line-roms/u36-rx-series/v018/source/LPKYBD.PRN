  1A7A    5F                    	ld	e,a		;save mouse delta
  1A7B    7E                    	ld	a,(hl)
  1A7C    47                    	ld	b,a		;save cmd/status byte
  1A7D    21 F95D               	ld	hl,mstbl	;mouse table
  1A80    CB 7E                 	bit	msflg,(hl)	;test for user enabled
  1A82    CA 199D               	jp	z,nochar	;quit if mouse handler is not enabled
  1A85    DD E5                 	push	ix		;save register
  1A87    DD 2A F95E            	ld	ix,(msptr)	;fetch user's table
  1A8B    CB 4E                 	bit	xy,(hl)		;test y/nx mouse byte flag
  1A8D    20 26                 	jr	nz,micey	;skip if y axis delta
                                
  1A8F                          micex:
  1A8F    DD 6E 05              	ld	l,(ix+5)	;fetch current x position
  1A92    DD 66 06              	ld	h,(ix+6)
  1A95    7B                    	ld	a,e		;save unsigned mouse delta byte
  1A96    CB 60                 	bit	xneg,b		;test polarity of x delta
  1A98    CD 1AE8               	call	mice1		;add delta & do min value check
  1A9B    DD 73 09              	ld	(ix+x'9'),e	;save signed mouse delta word
  1A9E    DD 72 0A              	ld	(ix+x'a'),d
  1AA1    DD 5E 01              	ld	e,(ix+1)	;fetch max position value
  1AA4    DD 56 02              	ld	d,(ix+2)
  1AA7    CD 1AFD               	call	mice2		;do max value check
  1AAA    DD 75 05              	ld	(ix+5),l	;save position
  1AAD    DD 74 06              	ld	(ix+6),h
  1AB0    DD E1                 micex1:	pop	ix		;restore regiser
  1AB2    C3 19AD               	jp	peknoc1		;return to wait for y mouse byte
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-26
ROM resident (screenprint routine)

                                
  1AB5                          micey:
  1AB5    DD 6E 07              	ld	l,(ix+7)	;fetch current y position
  1AB8    DD 66 08              	ld	h,(ix+8)
  1ABB    7B                    	ld	a,e		;save unsigned mouse delta byte
  1ABC    CB 68                 	bit	yneg,b		;test polarity of y delta
  1ABE    CD 1AE8               	call	mice1		;add delta & do min value check
  1AC1    DD 73 0B              	ld	(ix+x'b'),e	;save signed mouse delta word
  1AC4    DD 72 0C              	ld	(ix+x'c'),d
  1AC7    DD 5E 03              	ld	e,(ix+3)	;fetch max position value
  1ACA    DD 56 04              	ld	d,(ix+4)
  1ACD    CD 1AFD               	call	mice2		;do max value check
  1AD0    DD 75 07              	ld	(ix+7),l	;save position
  1AD3    DD 74 08              	ld	(ix+8),h
                                
  1AD6    21 F95D               	ld	hl,mstbl	;update mouse status
  1AD9    CB C6                 	set	msmov,(hl)	;set the mouse update flag
  1ADB    CB 76                 	bit	mintrp,(hl)	;test for interrupt mode
  1ADD    CA 1AB0               	jp	z,micex1	;bye bye if polling mode
  1AE0    DD 7E 00              	ld	a,(ix)		;user interrupt byte
  1AE3    DD E1                 	pop	ix		;restore regiser
  1AE5    C3 19D1               	jp	charout		;bye bye
                                	page	
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-27
ROM resident (screenprint routine)

                                
                                	;This routine adds the delta to either the x or y position and
                                	;does minimum position check
                                	;input hl=	x or y position
                                	;	e=	mouse delta (absolute)
                                	;	zero	set if positive mouse delta
                                	;		reset if negative mouse delta
                                	;
                                	;output	hl=	update position
                                	;
  1AE8                          mice1:
  1AE8    20 04                 	jr	nz,mice11	;skip if delta negative
  1AEA    16 00                 	ld	d,zero		;set msb positive
  1AEC    18 07                 	jr	mice12
  1AEE    16 FF                 mice11: ld	d,-1		;set msb negative
  1AF0    7B                    	ld	a,e		;recover delta
  1AF1    2F                    	cpl			;2's complement
  1AF2    C6 01                 	add	a,1
  1AF4    5F                    	ld	e,a		;put negative value back
  1AF5    19                    mice12:	add	hl,de		;add delta to mouse position
  1AF6    7C                    	ld	a,h		;get msb
  1AF7    A7                    	and	a
  1AF8    F0                    	ret	p		;skip if msb is positive
  1AF9    21 0000               	ld	hl,zero		;set to minimum boundary
  1AFC    C9                    	ret
                                
                                	;This routine does a maximum x or y position check
                                	;input	hl=	x or y position
                                	;	de=	x or y max value
                                	;
                                	;output	a =	mstbl
                                	;
  1AFD                          mice2:
                                ;	ld	a,d		;msb position test
                                ;	cp	h
                                ;	jr	c,mice21	;skip if msb too big
                                ;	ld	a,e		;lsb position test
                                ;	cp	l
  1AFD    7B                    	ld	a,e		;lsb max byte
  1AFE    95                    	sub	l		;sub lsb position byte
  1AFF    00                    	nop			;avoid changing following addresses
  1B00    00                    	nop
  1B01    7A                    	ld	a,d		;msb max byte
  1B02    9C                    	sbc	a,h		;sub msb position byte
  1B03    30 01                 	jr	nc,mice22	;skip if lsb is not too big
  1B05    EB                    mice21:	ex	de,hl		;force maximum limit
                                
  1B06    3A F95D               mice22:	ld	a,(mstbl)	;mouse table
  1B09    CB 4F                 	bit	xy,a		;complement xy flag
  1B0B    28 04                 	jr	z,mice23
  1B0D    CB 8F                 	res	xy,a
  1B0F    18 02                 	jr	mice24
                                
  1B11    CB CF                 mice23:	set	xy,a
  1B13    32 F95D               mice24:	ld	(mstbl),a	;update table
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-28
ROM resident (screenprint routine)

  1B16    C9                    	ret
                                
                                
                                	page
