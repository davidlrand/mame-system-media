  FC61    F3                    	di
  FC62    3E CF                 	ld	a,11001111b	;set Pio B in Bit Mode
  FC64    D3 1D                 	out	(sysctl),a
  FC66    3E 38                 	ld	a,00111000b	;turn around d0,1,2
  FC68    D3 1D                 	out	(sysctl),a
  FC6A    3E 80                 	ld	a,10000000b	;ensure rom switched on but . . .
  FC6C    D3 1C                 	out	(syspio),a	;drop all drive selects
  FC6E    3E D0                 	ld	a,0d0h		;reset wd-1797-02
  FC70    D3 10                 	out	(wd1797),a
  FC72    10 FE                 sign1:	djnz	sign1		;wait 1797 not busy
  FC74    DB 1C                 	in	a,(syspio)
  FC76    CB 67                 	bit	c.five,a
  FC78    3E 02                 	ld	a,2		;preset 10 msec step rate
  FC7A    20 04                 	jr	nz,sign2	;if not 5"
  FC7C    CB E6                 	set	c.five,(hl)
  FC7E    3E 03                 	ld	a,3		;set long step
  FC80    D3 10                 sign2:	out	(wd1797),a	;restore / unload heads
  FC82    32 FF54               	ld	(steprt),a
  FC85    18 22                 	jr	sign4
  FC87    08                    sign3:	ex	af,af'		;save status
  FC88    7E                    	ld	a,(hl)
  FC89    F6 40                 	or	c.sasi
  FC8B    77                    	ld	(hl),a		;set Sasi card installed
  FC8C    08                    	ex	af,af'		;restore status
  FC8D    21 F708               	ld	hl,Rigdpb	;set address of rigid dpb
  FC90    11 F470               	ld	de,Fivdpb	;set address of 5.25" floppy dpb
  FC93    01 0300               	ld	bc,Sasidl	;set sasi driver length
  FC96    ED B0                 	ldir			;Move driver dow
  FC98    E6 02                 	and	2
  FC9A    20 0D                 	jr	nz,sign4	;if not A/E swap
  FC9C    21 F361               	ld	hl,Seltab+1
  FC9F    06 08                 	ld	b,8
  FCA1    7E                    sign3a:	ld	a,(hl)
  FCA2    EE 04                 	xor	4
  FCA4    77                    	ld	(hl),a
  FCA5    23                    	inc	hl
  FCA6    23                    	inc	hl
  FCA7    10 F8                 	djnz	sign3a
                                
