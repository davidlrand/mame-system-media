  F1EC                          savstk	equ	x'f1ec'		;stack save address
  FF10                          ctcvec	equ	x'ff10'		;counter timer interrupt vector
  FF18                          sysvec	equ	0ff18h		;vector page
  FF1A                          kbvec	equ	sysvec+2	;keyboard vector
  FC52                          tca	equ	0fc52h		;start of 4.02 transient command area
                                
                                
                                ;	Routines referenced by rx1984
                                
  F006                          const	equ	monitr+6
  F009                          conin	equ	monitr+9
  F003                          warm	equ	monitr+3
  F01B                          select	equ	monitr+1bh
  F01E                          home	equ	monitr+1eh
  F024                          read	equ	monitr+24h
  F08B                          config	equ	monitr+x'8b'	;monitor configure routine
  F03F                          siordy	equ	monitr+x'3f'	;sio channel b output ready status
  F066                          idle	equ	monitr+x'66'	;idle while i/o pending
  F06F                          key2	equ	monitr+x'6f'	;keyboard xlat char entry address
  F072                          key5	equ	monitr+x'72'	;keyboard without xlat char entry address
  F075                          pnext	equ	monitr+x'75'	;print message after call
  F078                          prboff	equ	monitr+x'78'	;promt boot entry
  FA80                          autobt	equ	prompt+1eh
