  FD54    C1                    	pop	bc		;throw away booter return
  FD55    C1                    	pop	bc		;get disk swap parameters
  FD56    E1                    	pop	hl
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-46
Overlay (boot)

  FD57    CD FD82               	call	swap		;swap them back for xerox boot
                                
  FD5A    C1                    	pop	bc		;throw away return address
  FD5B    CD F29C               	call	crton		;disable ram
  FD5E    DD 2A FA08            	ld	ix,(lpiadr)	;load 4.02+ monitor boot overlay
  FD62    DD 6E 00              	ld	l,(ix)
  FD65    DD 66 01              	ld	h,(ix+1)
  FD68    CD F293               	call	crtoff		;disable rom
                                
  FD6B                          boot6:
                                
  FD6B    C3 F078               	jp	prboff		;enter xerox code to execute boot
                                
  FD6E    00                    boots:	defb	0		;workbyte to save disk type
                                
                                
                                ;;	Booter - Boot Error Processor.
                                ;
  FD6F    CD F075               booter:	call	pnext
  FD72    07                    	defb	7
  FD73    64 3A 4C 6F           bootd:	defm	'd:Load error'
  FD77    61 64 20 65           
  FD7B    72 72 6F 72           
  FD7F    04                    	defb	eot
  FD80    C1                    	pop	bc		;switch drives back
  FD81    E1                    	pop	hl
                                
                                ;;	swap - swap logical drives.
                                ;
                                ;	Entry:	C = first  drive index, 0-15
                                ;		L = second drive index, 0-15
                                ;
  FD82    06 00                 swap:	ld	b,0		;clear upper indices
  FD84    60                    	ld	h,b
  FD85    11 F360               	ld	de,seltab	;set select table address
  FD88    29                    	add	hl,hl
  FD89    19                    	add	hl,de
  FD8A    EB                    	ex	de,hl		;set second address to DE, get seltab to HL
  FD8B    09                    	add	hl,bc
  FD8C    09                    	add	hl,bc		;set first address to HL
  FD8D    06 02                 	ld	b,2
  FD8F    4E                    swap1:	ld	c,(hl)		;swap two bytes
  FD90    1A                    	ld	a,(de)
  FD91    77                    	ld	(hl),a
  FD92    79                    	ld	a,c
  FD93    12                    	ld	(de),a
  FD94    23                    	inc	hl
  FD95    13                    	inc	de
  FD96    10 F7                 	djnz	swap1		;if swap not complete
  FD98    C9                    	ret
                                
                                	.dephase
                                	subttl	end
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-47
end

                                
                                
  0779'                         romtop:
  0779'                         	defs	(romsiz-x'24')-(romtop-start),-1
                                
  07DC'                         drctry:
                                	;Drctry is a table containing the RAM addresses of the keyboard
                                	;tables.  This table is located on ROM side of memory.  The
                                	;ROM address must be offset by x'1800' since resides in
                                	;the fourth 2kx8 ROM slot.  This directory is helpful if future
                                	;release require the RAM tables to reside in a different RAM
                                	;location
                                	;
  07DC'   F97A                  	defw	prntbl		;print exception table
  07DE'   F960                  	defw	fontbl		;font exception table
  07E0'   F95D                  	defw	mstbl		;mouse table
  07E2'   F959                  	defw	ups		;upstroke table
  07E4'   F958                  	defw	ctrlex		;function key inhibit expansion table
  07E6'   F953                  	defw	ctrltb		;function key inhibit table
  07E8'   F94F                  	defw	rptex		;repeat key expansion table
  07EA'   F940                  	defw	rptbl		;repeat key table
  07EC'   F93C                  	defw	tick		;repeat speed table
  07EE'   F93B                  	defw	shftlck		;shift lock flag
  07F0'   F938                  	defw	cptex		;alpha lock expansion table
  07F2'   F935                  	defw	captab		;alpha lock table
  07F4'   F8CE                  	defw	cdtab		;code + table
  07F6'   F867                  	defw	shtab		;shift table
  07F8'   F800                  	defw	tabl		;unshifted table
                                
                                				;define checkword to let xerox know
                                				;that we are present
  07FA'   12                    revs:	defb	ver		;revision level
  07FB'   00 FF                 lpid:	defb	x'00',x'ff'	;low profile kybd with Galaxy id
  07FD'   AA 55                 peid:	defb	0aah,55h	;position encoded kybd id
  07FF'   00                    cksum:	defb	0		;space for checksum
                                
  0024                          sz	equ	$-drctry	;end of ROM space occupied
                                
                                
                                	end
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	S
end

