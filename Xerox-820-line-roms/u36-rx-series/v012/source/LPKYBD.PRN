ROM resident (screenprint routine)

                                
  1A20                          alphtst:
                                	;If the lock key is depressed, the translated character is
                                	;tested to see if it is an alphabet.  If it is lower case,
                                	;then it is forced upper case.
                                	;
                                	;input	hl - command-status address
                                	;	a  - translated character
                                	;
                                	;output a  - translated character(upper chase if alpha+lock)
                                	;
  1A20    CB 46                 	bit	lock,(hl)	;test alpha lock flag
  1A22    C8                    	ret	z		;quit if not alpha lock
                                
  1A23    FE 7B                 	cp	upper		;test for upper alpha range
  1A25    30 06                 	jr	nc,alphexc	;skip if non alpha range
  1A27    FE 61                 	cp	lower		;test for lower case alpha range
  1A29    38 02                 	jr	c,alphexc	;skip if not lower alpha case
  1A2B    D6 20                 	sub	upascii		;set upper case ASCII alpha character
                                ;	ret
                                
                                
                                
  1A2D                          alphexc:
                                	;Three additional caracters are allowed for the alpha lock key
                                	;
                                	;input	hl - command-status address
                                	;	a  - translated character
                                	;
                                	;output	a  - upper case exception
                                	;
  1A2D    21 F935               	ld	hl,captab		;lock exception table
  1A30    01 0003               	ld	bc,cptbsz		;table size
  1A33    ED B1                 	cpir				;search
  1A35    C0                    	ret	nz			;quit if not found
                                
  1A36    23                    	inc	hl			;get exception
  1A37    23                    	inc	hl
  1A38    7E                    	ld	a,(hl)
  1A39    C9                    	ret
                                
                                	page
RX1984	MACRO-80 3.44	09-Dec-81	PAGE	1-21
ROM resident (screenprint routine)

                                
  1A3A                          rptst:
                                	;Checks for repeat character.  If repeat character, the millisec
                                	;timer is vector address is modified and the timer is set up
                                	;for 0.5 second.  The timer is kicked off.
                                	;
                                	;input	a - translated character
                                	;
  1A3A    21 F940               	ld	hl,rptbl	;repeat char table
  1A3D    01 0013               	ld	bc,cntrp	;number of repeat chars
  1A40    ED B1                 	cpir			;test for repeat chars
  1A42    C0                    	ret	nz		;quit if not repeat char
                                
  1A43    2A F93C               	ld	hl,(tick)	;millisec count
  1A46    22 F9A8               	ld	(millcnt),hl	;save it in table
  1A49    21 F9AA               	ld	hl,rptchar	;repeat char save address
  1A4C    77                    	ld	(hl),a		;save repeat char
  1A4D    F5                    	push	af
  1A4E    23                    	inc	hl		;repeat flag address
  1A4F    36 FF                 	ld	(hl),setflg	;set repeat flag
                                
  1A51    2A FF12               	ld	hl,(ctcvec+2)	;get 1 millisec interrupt vector
  1A54    22 F9AC               	ld	(save),hl	;save it
  1A57    21 F9D0               	ld	hl,rptclk	;kybd repeat key timer
  1A5A    22 FF12               	ld	(ctcvec+2),hl	;substitute it
                                
  1A5D    3E 81                 strctc1: ld	a,encntr	;enable millisec timmer
  1A5F    D3 19                 	out	(ctc1),a	;do it
  1A61    F1                    	pop	af		;recover character
  1A62    C9                    	ret
                                
                                
  1A63                          stpctc1:
                                	;This routine stops the millisecond timer and restores the
                                	;original timer vector
                                
  1A63    21 F9AB               	ld	hl,rptflg	;fetch repeat char flag
  1A66    7E                    	ld	a,(hl)
  1A67    A7                    	and	a		;set flags
  1A68    C8                    	ret	z		;quit if no repeat keys
                                
  1A69    72                    	ld	(hl),d		;clear repeat char flag
  1A6A    2A F9AC                	ld	hl,(save)	;original 1 millisec interrupt address
  1A6D    22 FF12               	ld	(ctcvec+2),hl	;restore it
                                
  1A70    3A F20E               	ld	a,(spact)	;fetch screen print flag
  1A73    A7                    	and	a
  1A74    C0                    	ret	nz		;don't kill timer, if screen printing
                                
  1A75    3E 01                 	ld	a,stcntr	;stop timer 
  1A77    D3 19                 	out	(ctc1),a
  1A79    C9                    	ret
                                	page
