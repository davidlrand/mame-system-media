  063A'                         rxboot:				;rom source address
                                	.phase	tca-romofs	;execution address o/l area
                                
  FC55                          	ds	romofs,0	;4.01 overlay start address
  FC5D    21 FF5D               	ld	hl,linbuf+1	;4.02 overlay start address
  FC60    7E                    boot1:	ld	a,(hl)		;scan command line
  FC61    2C                    	inc	l
  FC62    D6 0D                 	sub	cr
  FC64    28 0B                 	jr	z,boot2		;if no parameter, boot from A:
  FC66    FE 13                 	cp	' '-cr
  FC68    28 F6                 	jr	z,boot1		;skip leading blanks
  FC6A    D6 34                 	sub	'A'-cr
  FC6C    D8                    	ret	c		;if invalid drive
  FC6D    FE 10                 	cp	16
  FC6F    3F                    	ccf
  FC70    D8                    	ret	c		;if bad drive
  FC71    4F                    boot2:	ld	c,a		;set boot drive selected
  FC72    C6 41                 	add	a,'A'
  FC74    32 FD72               	ld	(bootd),a	;set up error message
  FC77    2E 00                 	ld	l,0		;set A:
  FC79    C5                    	push	bc
  FC7A    E5                    	push	hl
  FC7B    CD FD89               	call	swap		;switch boot drive with A:
  FC7E    21 FD6E               	ld	hl,booter	;set boot error return
  FC81    E5                    	push	hl
  FC82    0E 00                 	ld	c,0		;then boot from A:
  FC84    CD F01B               	call	select
  FC87    C0                    	ret	nz		;if drive not configured or density error
  FC88    3E FF                 	ld	a,-1
  FC8A    12                    	ld	(de),a
  FC8B    11 000A               	ld	de,10		;set dpb address offset within dph
  FC8E    19                    	add	hl,de
  FC8F    5E                    	ld	e,(hl)		;set dpb address
  FC90    23                    	inc	hl
  FC91    56                    	ld	d,(hl)
  FC92    CD F01E               	call	home
  FC95    1A                    	ld	a,(de)		;get low sectors per track
  FC96    32 FD6D               	ld	(boots),a	;inform boot loader
  FC99    B7                    	or	a
  FC9A    20 20                 	jr	nz,boot3	;if not rigid
  FC9C    21 000D               	ld	hl,13		;set reserved track offset within dpb
  FC9F    19                    	add	hl,de
  FCA0    4E                    	ld	c,(hl)		;get reserved tracks
  FCA1    23                    	inc	hl
  FCA2    46                    	ld	b,(hl)
  FCA3    0B                    	dec	bc		;point behind directory
  FCA4    ED 43 FA11            	ld	(phytrk),bc	;do implied seek
                                
