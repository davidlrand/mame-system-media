Overlay (signon)

                                
                                
                                
                                	;;	signon - Announce System Ready.
  054F'                         rxsign:				;source address in rom
                                	.phase	tca		;execution in transient command area
                                
  FC5D    21 F091               signon:	ld	hl,confg	;point to configuration byte
  FC60    DB 1C                 	in	a,(syspio)	;check configuration
  FC62    CB 47                 	bit	0,a
  FC64    28 26                 	jr	z,sign3		;if SASI interface present
  FC66    F3                    	di
  FC67    3E CF                 	ld	a,11001111b	;set Pio B in Bit Mode
  FC69    D3 1D                 	out	(sysctl),a
  FC6B    3E 38                 	ld	a,00111000b	;turn around d0,1,2
  FC6D    D3 1D                 	out	(sysctl),a
  FC6F    3E 80                 	ld	a,10000000b	;ensure rom switched on but .....
  FC71    D3 1C                 	out	(syspio),a	;drop all drive selects
  FC73    3E D0                 	ld	a,0d0h		;reset wd-1797-02
  FC75    D3 10                 	out	(wd1797),a
  FC77    10 FE                 sign1:	djnz	sign1		;wait 1797 not busy
  FC79    DB 1C                 	in	a,(syspio)
  FC7B    CB 67                 	bit	c.five,a
  FC7D    3E 02                 	ld	a,2		;preset 10 msec step rate
  FC7F    20 04                 	jr	nz,sign2	;if not 5"
  FC81    CB E6                 	set	c.five,(hl)
  FC83    3E 03                 	ld	a,3		;set long step
  FC85    D3 10                 sign2:	out	(wd1797),a	;restore / unload heads
  FC87    32 FF54               	ld	(steprt),a
  FC8A    18 1E                 	jr	sign4
  FC8C    CB F6                 sign3:	set	c.sasi,(hl)	;set Sasi card installed
  FC8E    21 F708               	ld	hl,Rigdpb	;set address of rigid dpb
  FC91    11 F470               	ld	de,Fivdpb	;set address of 5.25" floppy dpb
  FC94    01 0300               	ld	bc,Sasidl	;set sasi driver length
  FC97    ED B0                 	ldir			;Move driver down
  FC99    E6 02                 	and	2
  FC9B    20 0D                 	jr	nz,sign4	;if not A/E swap
  FC9D    21 F361               	ld	hl,Seltab+1
  FCA0    06 08                 	ld	b,8
  FCA2    7E                    sign3a:	ld	a,(hl)
  FCA3    EE 04                 	xor	4
  FCA5    77                    	ld	(hl),a
  FCA6    23                    	inc	hl
  FCA7    23                    	inc	hl
  FCA8    10 F8                 	djnz	sign3a
                                
  FCAA                          sign4:
  FCAA    21 0347'              	ld	hl,tables	;move rx resident code to ram
  FCAD    11 F800               	ld	de,tabled
                                	if	skip
                                	ld	bc,olsiz
                                	ldir
                                
                                	ld	hl,here		;not enough room for ram code
                                	ld	de,lpkybd
