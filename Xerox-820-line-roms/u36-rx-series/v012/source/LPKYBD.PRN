  1AC4    DD 72 0C              	ld	(ix+x'c'),d
                                ;	ld	de,(ymax)	;fetch max position value
  1AC7    DD 5E 03              	ld	e,(ix+3)	;fetch max position value
  1ACA    DD 56 04              	ld	d,(ix+4)
  1ACD    CD 1AFD               	call	mice2		;do max value check
                                ;	ld	(yloc),hl	;save position
  1AD0    DD 75 07              	ld	(ix+7),l	;save position
  1AD3    DD 74 08              	ld	(ix+8),h
                                
  1AD6    21 F95D               	ld	hl,mstbl	;update mouse status
  1AD9    CB C6                 	set	msmov,(hl)	;set the mouse update flag
  1ADB    CB 76                 	bit	mintrp,(hl)	;test for interrupt mode
  1ADD    CA 1AB0               	jp	z,micex1	;bye bye if polling mode
                                ;	ld	a,(mbyte)	;user interrupt byte
  1AE0    DD 7E 00              	ld	a,(ix)		;user interrupt byte
  1AE3    DD E1                 	pop	ix		;restore regiser
  1AE5    C3 19D1               	jp	charout		;bye bye
