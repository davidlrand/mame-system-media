  F9FC    F3                    	di
  F9FD    CD F9BE               	call	romside		;switch to romside
  FA00    CD 1909               	call	rmposend	;does real work
  FA03    CD F9C8               	call	ramside		;restore original memory side
  FA06    FB                    	ei
  FA07    C9                    	ret
                                
