  1909    C5                    rmposend: push	bc
  190A    E5                    	push	hl
  190B    CD 1911               	call	posend
  190E    E1                    	pop	hl
  190F    C1                    	pop	bc
  1910    C9                    	ret
                                
                                ;;	posend - deals with character translation and escape
                                ;		 sequences for the diablo 630
                                ;		 input--- a contains char for output to channel b
  1911                          posend:
  1911    4F                    	ld	c,a
                                
  1912    3A F9A6               	ld	a,(escsq)	;in an escape sequence?
  1915    B7                    	or	a
  1916    20 22                 	jr	nz,pos04	;yes
                                
  1918    79                    	ld	a,c
  1919    FE 1B                 	cp	esc		;escape char?
  191B    20 07                 	jr	nz,pos01	;no
                                
  191D    CD 1956               	call	posout		;output char
  1920    32 F9A6               	ld	(escsq),a	;set escape sequence flag
  1923    C9                    	ret
                                
  1924                          pos01:				;not escape char
  1924    CD 1963               	call	potran		;do translation if neccessary
  1927    20 0D                 	jr	nz,pos03	;wasn't neccessary
                                
  1929    CB 7F                 	bit	7,a		;escape marker set?
  192B    28 09                 	jr	z,pos02		;no
                                
  192D    4F                    	ld	c,a
  192E    3E 1B                 	ld	a,esc
  1930    CD 1956               	call	posout		;output escape char
                                
  1933    79                    	ld	a,c
  1934    CB BF                 	res	7,a		;clear escape marker
                                
  1936                          pos02:				;escape marker not set
  1936                          pos03:				;no translation
  1936    CD 1956               	call posout		;output char
  1939    C9                    	ret
                                
  193A                          pos04:				;escape sequence
  193A    FE FF                 	cp	0ffh		;3rd byte?
  193C    20 06                 	jr	nz,pos05	;no 2nd
                                
  193E    79                    	ld	a,c
  193F    CD 1956               	call	posout		;output char
  1942    18 0D                 	jr	pos06
                                
