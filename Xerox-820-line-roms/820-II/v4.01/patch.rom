F4C9 	PATCH1          F4CD 	PATCH2          F651 	PATCH3          
F652 	PATCH4                                                                                                                                                            msg2:	db	'Floppy driver version 4.00 not present.$'
                                msg3:	db	'Floppy driveňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň                                                                                                                                de,100h
	ld	bc,800h
	jp	move

ccs:	ld	e,0		;preset ckecksum
ccs1:	ld	a,(hl)
	inc	hl
	add	a,e
	ld	e,a
	dec	bc
	ld	a,b
                                                                                                                             ¬U!ld	c,9
	call	5
	jp	0

msg1:	db	'Floppy driver patch installed.$'
msg2:	db	'Floppy driver version 4.00 not present.$'
msg3:                                                                                                                                ALL IDLE
;	ld	(patch4),a
;	ld	(patch5),a
	ld	a,(patch1-1)
	ld	(patch2),a	;restore track ld c,(hl)
	ld	hl,config
	inc	(hl)                                                                                                                                	or	c
	jr	nz,ccs1
	or	e
	ret

	ds	200h-$,0

code:
	.phase	1800h

;;	Put this antidote after any other prescriptions.
	title	PATCH for Xerox 820-II v 4.00 rom WD1797 Driver	

	.z80

