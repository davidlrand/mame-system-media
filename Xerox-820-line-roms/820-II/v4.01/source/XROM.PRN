                                ;
                                ;	* X <first addr> <last addr>
                                ;
                                	OVERLAY	TEST
  038B'                   +     	C&SEG
  FC55    FE 02                 	CP	2		;check parameter count
  FC57    37                    	SCF
  FC58    C0                    	RET	NZ
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-59
TRANSIENT COMMAND PROCESSORS

  FC59    13                    	INC	DE
  FC5A    5A                    	LD	E,D		;get ending page address into E
  FC5B    54                    	LD	D,H		;get starting page address into D
  FC5C    06 00                 	LD	B,0		;initialize pass counter
  FC5E    62                    TEST1:	LD	H,D		;point HL to start of block
  FC5F    2E 00                 	LD	L,0
  FC61    7D                    TEST2:	LD	A,L
  FC62    AC                    	XOR	H		;generate test byte
  FC63    A8                    	XOR	B
  FC64    77                    	LD	(HL),A		;store byte in RAM
  FC65    23                    	INC	HL
  FC66    7C                    	LD	A,H
  FC67    BB                    	CP	E		;check for end of test block
  FC68    20 F7                 	JR	NZ,TEST2
  FC6A    62                    	LD	H,D		;now read back each byte & compare
  FC6B    2E 00                 	LD	L,0		;point HL back to start
  FC6D    7D                    TEST3:	LD	A,L
  FC6E    AC                    	XOR	H		;re-generate test byte data
  FC6F    A8                    	XOR	B
  FC70    CD FB0E               	CALL	CHECK		;verify memory data still good
  FC73    C0                    	RET	NZ		;exit if escape request is indicated
  FC74    23                    	INC	HL		; else go on to next byte
  FC75    7C                    	LD	A,H
  FC76    BB                    	CP	E		;check for end of block
  FC77    20 F4                 	JR	NZ,TEST3
  FC79    04                    	INC	B		;bump pass count
  FC7A    3E 2B                 	LD	A,'+'
  FC7C    CD FC20               	CALL	OUTPUT
  FC7F    28 DD                 	JR	Z,TEST1		;do another pass if user not unhappy
  FC81    C9                    	RET
                                	ELSE
                                TEST	EQU	WHAT
                                	ENDIF
