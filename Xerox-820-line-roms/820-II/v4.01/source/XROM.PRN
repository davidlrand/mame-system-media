  FC5B    ED 59                 	OUT	(C),E		;output to d0-d7 and address to a0-a17
  FC5D    B7                    	OR	A
  FC5E    C9                    	RET
                                	ELSE
                                OUTCMD	EQU	WHAT
                                	ENDIF
