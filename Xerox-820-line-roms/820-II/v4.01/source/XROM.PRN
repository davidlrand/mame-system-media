BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-50
I/O BYTE DRIVERS

                                
                                	OVERLAY	IOBDVR
  00BB'                   +     	C&SEG
                                	.DEPHASE
                                	.PHASE	IOBLOC
                                ;
                                ;	COMINS - Communications input status.
                                ;
  F770    DB 06                 COMINS:	IN	A,(SIOCPA)
  F772    0F                    	RRCA
  F773    9F                    	SBC	A,A
  F774    C9                    	RET
                                ;
                                ;	COMINP - Communications input data.
                                ;
  F775    DB 06                 COMINP:	IN	A,(SIOCPA)
  F777    0F                    	RRCA
  F778    30 FB                 	JR	NC,COMINP
  F77A    DB 04                 	IN	A,(SIODPA)
  F77C    C3 F0E2               	JP	KBMASK
                                ;
                                ;	COMOUT - Communications output.
                                ;
  F77F    CD F788               COMOUT:	CALL	COMOTS
  F782    28 FB                 	JR	Z,COMOUT
  F784    79                    	LD	A,C
  F785    D3 04                 	OUT	(SIODPA),A
  F787    C9                    	RET
                                ;
                                ;	COMOTS - Communications output status.
                                ;
  F788    DB 06                 COMOTS:	IN	A,(SIOCPA)
  F78A    E6 04                 	AND	4
  F78C    C8                    	RET	Z
  F78D    F6 FF                 	OR	-1
  F78F    C9                    	RET
                                ;
                                ;	CONIOB - get console I/O byte.
                                ;
  F790    3A 0003               CONIOB:	LD	A,(IOBYTE)
  F793    E6 03                 	AND	00000011B
  F795    C9                    	RET
                                ;
                                ;	IOCONO - Console output through IOBYTE.
                                ;
  F796    CD F790               IOCONO:	CALL	CONIOB
  F799    28 E4                 	JR	Z,COMOUT
  F79B    3D                    	DEC	A
  F79C    CA F2FE               	JP	Z,FASTCRT
  F79F    79                    	LD	A,C
  F7A0    C3 F0F8               	JP	SIOOUT
                                ;
                                ;	IOCONS - Console status through IOBYTE.
                                ;
  F7A3    CD F790               IOCONS:	CALL	CONIOB
  F7A6    28 C8                 	JR	Z,COMINS
  F7A8    3D                    	DEC	A
  F7A9    CA F0CD               	JP	Z,KBDST
  F7AC    C3 F0E5               	JP	SIOST
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-51
I/O BYTE DRIVERS

                                ;
                                ;	IOCONI - Console input through IOBYTE.
                                ;
  F7AF    CD F790               IOCONI:	CALL	CONIOB
  F7B2    28 C1                 	JR	Z,COMINP
  F7B4    3D                    	DEC	A
  F7B5    CA F0D8               	JP	Z,KBDIN
  F7B8    C3 F0F0               	JP	SIOIN
                                ;
                                ;	LSTOUT - List output through IOBYTE.
                                ;
  F7BB    3A 0003               IOLIST:	LD	A,(IOBYTE)
  F7BE    E6 C0                 	AND	11000000B
  F7C0    28 BD                 	JR	Z,COMOUT
  F7C2    EA F7DC               	JP	PE,PIOOUT
  F7C5    79                    	LD	A,C
  F7C6    FA F0F8               	JP	M,SIOOUT
  F7C9    C3 F2FE               	JP	FASTCRT
                                ;
                                ;	List output through IOBYTE.
                                ;
  F7CC    3A 0003               IOLSTS:	LD	A,(IOBYTE)
  F7CF    E6 C0                 	AND	11000000B
  F7D1    28 B5                 	JR	Z,COMOTS
  F7D3    EA F7F4               	JP	PE,PIOSTO
  F7D6    FA F105               	JP	M,SIORDY
  F7D9    F6 FF                 	OR	-1
  F7DB    C9                    	RET
                                ;
                                ;	Parallel Output Driver.
                                ;
  F7DC    CD F7F4               PIOOUT:	CALL	PIOSTO
  F7DF    28 FB                 	JR	Z,PIOOUT	;if printer not ready
  F7E1    79                    	LD	A,C
  F7E2    D3 08                 	OUT	(GPIODA),A	;load character data
  F7E4    DB 0A                 	IN	A,(GPIODB)
  F7E6    CB 97                 	RES	P.STRB,A	;assert strobe
  F7E8    D3 0A                 	OUT	(GPIODB),A
  F7EA    CB D7                 	SET	P.STRB,A	;release stobe
  F7EC    D3 0A                 	OUT	(GPIODB),A
  F7EE    3E 0A                 	LD	A,10		;delay for ACK
  F7F0    3D                    PIO1:	DEC	A
  F7F1    20 FD                 	JR	NZ,PIO1
  F7F3    C9                    	RET	
                                ;
                                ;	Parallel Output Status.
                                ;
  F7F4    DB 0A                 PIOSTO:	IN	A,(GPIODB)	;read status
  F7F6    2F                    	CPL
  F7F7    E6 10                 	AND	1 SHL P.RDYO
  F7F9    C8                    	RET	Z		;if ready
  F7FA    F6 FF                 	OR	-1
  F7FC    C9                    	RET
  008D                          IOBDVS	EQU	$-IOBLOC
                                	.DEPHASE
                                	.PHASE	CLOC+IOBDVS
