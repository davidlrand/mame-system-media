  FC55                          CLOC	DEFL	$		;establish overlay execution address
                                	OVERLAY	START
  0C55"                   +     	C&SEG
                                ;
                                ;	SIGNON - Announce System Ready.
                                ;
  FC55    08                    SIGNON:	EX	AF,AF'
  FC56    CD F293               	CALL	CRTOFF		;disable ROM/RAM
  FC59    08                    	EX	AF,AF'
  FC5A    28 4A                 	JR	Z,SIGN4		;if Rx1984 loaded disk driver
  FC5C    08                    	EX	AF,AF'		;get system PIO data
  FC5D    21 F091               	LD	HL,CONFG	;point to configuration byte
  FC60    CB 47                 	BIT	0,A
  FC62    28 24                 	JR	Z,SIGN3		;if SASI interface present
  FC64    F3                    	DI
  FC65    3E CF                 	LD	A,11001111B	;set PIO B in Bit Mode
  FC67    D3 1D                 	OUT	(SYSCTL),A
  FC69    3E 38                 	LD	A,00111000B	;turn around d0,1,2
  FC6B    D3 1D                 	OUT	(SYSCTL),A
  FC6D    D3 1C                 	OUT	(SYSPIO),A	;drop all drive selects
  FC6F    3E D0                 	LD	A,0D0H		;reset WD-1797-02
  FC71    D3 10                 	OUT	(WD1797),A
  FC73    10 FE                 SIGN1:	DJNZ	SIGN1		;wait 1797 not busy
  FC75    DB 1C                 	IN	A,(SYSPIO)
  FC77    CB 67                 	BIT	C.FIVE,A
  FC79    3E 02                 	LD	A,2		;preset 10 msec step rate
  FC7B    20 04                 	JR	NZ,SIGN2	;if not 5"
  FC7D    CB E6                 	SET	C.FIVE,(HL)
  FC7F    3E 03                 	LD	A,3		;set long step
  FC81    D3 10                 SIGN2:	OUT	(WD1797),A	;restore / unload heads
  FC83    32 FF54               	LD	(STEPRT),A
  FC86    18 1E                 	JR	SIGN4
  FC88    CB F6                 SIGN3:	SET	C.SASI,(HL)	;set SASI card installed
  FC8A    21 F708               	LD	HL,RIGDPB	;set address of rigid DPB
  FC8D    11 F470               	LD	DE,FIVDPB	;set address of 5.25" floppy DPB
  FC90    01 0300               	LD	BC,SASIDL	;set SASI driver length
  FC93    ED B0                 	LDIR			;Move driver down
  FC95    E6 02                 	AND	2
  FC97    20 0D                 	JR	NZ,SIGN4	;if not A/E swap
  FC99    21 F361               	LD	HL,SELTAB+1
  FC9C    06 08                 	LD	B,8
  FC9E    7E                    SIGN3A:	LD	A,(HL)
  FC9F    EE 04                 	XOR	4
  FCA1    77                    	LD	(HL),A
  FCA2    23                    	INC	HL
  FCA3    23                    	INC	HL
  FCA4    10 F8                 	DJNZ	SIGN3A
  FCA6    CD FC3D               SIGN4:	CALL	PNEXT
  FCA9    1A                    	DEFB	CLRS		;clear screen
                                	IF	OPTIONS AND O.ESCT
  FCAA    1B 38                 	DEFB	ESC,'8'		;set low light as default mode
                                	ELSE
                                	DEFB	'R'-'@'
                                	ENDIF
  FCAC    38 32 30 2D           	DEFM	'820-II v '
  FCB0    49 49 20 76           
  FCB4    20                    
  FCB5    34 2E 30 31           	DEFB	REV/100+'0','.',(REV MOD 100)/10+'0',(REV MOD 10)+'0'
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-49
