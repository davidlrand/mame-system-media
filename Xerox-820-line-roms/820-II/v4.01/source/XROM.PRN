                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-52
TRANSIENT COMMAND PROCESSORS

                                
                                	IF	OPTIONS AND O.DDVR
                                ;	-- disk boot loader command --
                                ;
                                	OVERLAY	BOOT
  0148'                   +     	C&SEG
  FC55    21 FF5D               	LD	HL,LINBUF+1
  FC58    7E                    BOOT1:	LD	A,(HL)		;scan command line
  FC59    2C                    	INC	L
  FC5A    D6 0D                 	SUB	CR
  FC5C    28 0B                 	JR	Z,BOOT2		;if no parameter, boot from A:
  FC5E    FE 13                 	CP	' '-CR
  FC60    28 F6                 	JR	Z,BOOT1		;skip leading blanks
  FC62    D6 34                 	SUB	'A'-CR
  FC64    D8                    	RET	C		;if invalid drive
  FC65    FE 10                 	CP	16
  FC67    3F                    	CCF
  FC68    D8                    	RET	C		;if bad drive
  FC69    4F                    BOOT2:	LD	C,A		;set boot drive selected
  FC6A    C6 41                 	ADD	A,'A'
  FC6C    32 FCDD               	LD	(BOOTD),A	;set up error message
  FC6F    2E 00                 	LD	L,0		;set A:
  FC71    C5                    	PUSH	BC
  FC72    E5                    	PUSH	HL
  FC73    CD FCEE               	CALL	SWAP		;switch boot drive with A:
  FC76    21 FCD9               	LD	HL,BOOTER	;set boot error return
  FC79    E5                    	PUSH	HL
  FC7A    0E 00                 	LD	C,0		;then boot from A:
  FC7C    CD FA17               	CALL	SELECT
  FC7F    C0                    	RET	NZ		;if drive not configured or density error
  FC80    3E FF                 	LD	A,-1
  FC82    12                    	LD	(DE),A
