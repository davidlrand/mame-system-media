  FD32    F3                    	DI
  FD33    ED 79                 	OUT	(C),A
  FD35    3E AA                 	LD	A,10101010B	;assert DTR, 7 bpc, RTS, Tx Enb
  FD37    B2                    	OR	D
  FD38    ED 79                 	OUT	(C),A
  FD3A    FB                    	EI
  FD3B    3E FF                 	LD	A,0FFH
  FD3D    C3 FE90               	JP	SIOOT		;send RUBOUT to allow MARKING
                                ;
                                ;	PRC - Process Remote Character.
                                ;
  FD40    CD FED6               PRC:	CALL	SIOINC		;read remote character
  FD43    FD CB 00 76           	BIT	S.RECHO,(IY)
  FD47    C4 FD5F               	CALL	NZ,SNDRMT	;echo it back
  FD4A    18 26                 	JR	DOC		;display it locally
                                ;
                                ;	SNDLOC - Send character to screen.
                                ;
  FD4C    CD FD72               SNDLOC:	CALL	DOC
  FD4F    FE 0D                 	CP	CR
  FD51    C0                    	RET	NZ
  FD52    FD CB 00 6E           	BIT	S.AUTOL,(IY)
  FD56    C8                    	RET	Z
  FD57    3E 0A                 	LD	A,LF
  FD59    CD FD72               	CALL	DOC
  FD5C    3E 0D                 	LD	A,CR
  FD5E    C9                    	RET
                                ;
                                ;	SNDRMT - Send character to remote.
                                ;
  FD5F    CD FE90               SNDRMT:	CALL	SIOOT
  FD62    FE 0D                 	CP	CR
  FD64    C0                    	RET	NZ
  FD65    FD CB 00 66           	BIT	S.AUTOR,(IY)
  FD69    C8                    	RET	Z
  FD6A    3E 0A                 	LD	A,LF
  FD6C    CD FE90               	CALL	SIOOT
  FD6F    3E 0D                 	LD	A,CR
  FD71    C9                    	RET
                                ;
                                ;	DOC - Display One Character.
                                ;
  FD72    FE 7F                 DOC:	CP	7FH
  FD74    C8                    	RET	Z		;don't display RUBOUT
  FD75    4F                    	LD	C,A		;send it to screen
  FD76    C5                    	PUSH	BC
  FD77    CD FE9B               	CALL	OUTCRT		;display character
  FD7A    C1                    	POP	BC
  FD7B    47                    	LD	B,A
  FD7C    79                    	LD	A,C
  FD7D    FE 0A                 	CP	LF
  FD7F    C0                    	RET	NZ
