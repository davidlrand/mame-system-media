                                ;	LBL - link bottom line.
                                ;
  FE0B    01 0050               LBL:	LD	BC,80
  FE0E    2A FEE6               	LD	HL,(BOTPTR)
  FE11    B7                    	OR	A
  FE12    ED 42                 	SBC	HL,BC
  FE14    CD FE41               	CALL	WLP
  FE17    22 FEE6               	LD	(BOTPTR),HL
  FE1A    EB                    	EX	DE,HL
  FE1B    2A FEE8               	LD	HL,(TOPPTR)
  FE1E    B7                    	OR	A
  FE1F    ED 52                 	SBC	HL,DE
  FE21    20 0B                 	JR	NZ,LBL1
