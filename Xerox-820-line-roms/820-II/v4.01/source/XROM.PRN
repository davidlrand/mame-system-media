  FFFF                          TRUE	EQU	-1
  0000                          FALSE	EQU	NOT TRUE
  0000                          DEBUG	EQU	FALSE		;assemble RAM loader
  0000                          LDIRSM	EQU	FALSE		;simulate LDIR on screen accesses
                                ;
                                ;	Absolute Memory Addresses.
                                ;
  0000                          ROM	EQU	01000H AND DEBUG;non resident code base
  1800                          ROMSIZ	EQU	01000H+((NOT DEBUG) AND 0800H)
  1800                          RX1984	EQU	01800H		;prescription for the future
  0800                          LX1984	EQU	00800H		;length of future
  0003                          IOBYTE	EQU	00003H		;I/O byte
  0080                          BOOTLD	EQU	00080H		;boot loader address
  ED80                          BOOTBF	EQU	0ED80H		;boot loader buffer
  FF00                          RAM	EQU	0FF00H		;system RAM page address
  F000                          MONITR	EQU	0F000H		;resident monitor address
  3000                          CRTMEM	EQU	03000H		;CRT memory address
  3C00                          CRTMAX	EQU	CRTMEM+24*128	;CRT maximum address
  0030                          CRTBAS	EQU	HIGH CRTMEM	;starting page of display RAM
  003C                          CRTTOP	EQU	HIGH CRTMAX	;ending page of display RAM
                                ;
                                ;	I/O Port Addresses.
                                ;
  0000                          BAUDA	EQU	00H		;channel A baud rate generator
  0004                          SIODPA	EQU	04H		;SIO data port A (communications)
  0005                          SIODPB	EQU	05H		;SIO data port B (printer)
  0006                          SIOCPA	EQU	06H		;SIO control/status port A
  0007                          SIOCPB	EQU	07H		;SIO control/status port B
  0008                          GPIODA	EQU	08H		;general purpose parallel I/O A data
  0009                          GPIOCA	EQU	09H		;general purpose parallel I/O A control
  000A                          GPIODB	EQU	0AH		;general purpose parallel I/O B data
  000B                          GPIOCB	EQU	0BH		;general purpose parallel I/O B control
  000C                          BAUDB	EQU	0CH		;channel B baud rate generator
  0010                          WD1797	EQU	10H		;Western Digital disk controller base
  0014                          SCROLL	EQU	14H		;CRT bottom line scroll register
  0018                          CTC	EQU	18H		;quad counter/timer circuit
  0018                          CTC0	EQU	18H		;CTC channel 0 (user)
  0019                          CTC1	EQU	19H		;CTC channel 1 (msec, screen print)
  001A                          CTC2	EQU	1AH		;CTC channel 2 (one second prescaler)
  001B                          CTC3	EQU	1BH		;CTC channel 3 (one second)
  001C                          SYSPIO	EQU	1CH		;system PIO data
  001D                          SYSCTL	EQU	1DH		;system PIO control
  001E                          KBDDAT	EQU	1EH		;keyboard data
  001F                          KBDCTL	EQU	1FH		;keyboard control
  0028                          BELLOF	EQU	28H		;turn bell off
  0029                          BELLON	EQU	29H		;turn bell on
  0030                          SLSDEN	EQU	30H		;select single density
  0031                          SLDDEN	EQU	31H		;select double density
  0034                          CHROM1	EQU	34H		;select ROM 1 character generator
  0035                          CHROM2	EQU	35H		;select ROM 2 character generator
  0036                          LOWLITE	EQU	36H		;select low intensity attribute
  0068                          ASYNC	EQU	68H		;set internal clocks for asynchronous SIO A
  0069                          SYNC	EQU	69H		;set external clocks for  synchronous SIO A
