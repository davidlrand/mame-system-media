  0288    02C1                  	DEFW	STUFF		;Ctrl-_ is display control chars
  0036                          CTLSIZ	EQU	$-CTLTAB
                                ;
                                ;	Escape sequence table.
                                ;
                                ;	Maintains functional compatibility with terminals supporting
                                ;	ADM-3a style supersets.
                                ;
  028A    28                    ESCTAB:	DB	'('		;disable attribute (Soroc/Televideo, et.al)
  028B    29                    	DB	')'		;enable atribute (Soroc/Televideo, et.al)
  028C    2A                    	DB	'*'		;clear screen (Soroc/Televideo, et.al)
  028D    30                    	DB	'0'		;strip keyboard upper bit
  028E    31                    	DB	'1'		;pass keyboard upper bit
  028F    34                    	DB	'4'		;char font and blinking
  0290    35                    	DB	'5'		;char font and graphics
  0291    36                    	DB	'6'		;char font and blinking
  0292    37                    	DB	'7'		;char font and inverse video
  0293    38                    	DB	'8'		;char font and lo-light
  0294    3D                    	DB	'='		;position cursor
  0295    45                    	DB	'E'		;line insert (Televideo, et.al)
  0296    51                    	DB	'Q'		;character insert (Televideo, et. al)
  0297    52                    	DB	'R'		;line delete (Televideo, et. al)
  0298    57                    	DB	'W'		;character delete (Televideo, et. al)      
  0299    54                    	DB	'T'		;clear to end of line (Televideo, et. al)
  029A    59                    	DB	'Y'		;clear to end of screen (Televideo, et. al)
  0011                          ESCTBL	EQU	$-ESCTAB
  029B    0361                  ESCADR:	DEFW	CLREOS
  029D    0344                  	DEFW	CLREOL
  029F    03F5                  	DEFW	CHRDEL
  02A1    037C                  	DEFW	LINDEL
  02A3    03DC                  	DEFW	CHRINS
  02A5    03A4                  	DEFW	LININS
  02A7    0205                  	DEFW	SETXY
  02A9    01CF                  	DEFW	SETLOW
  02AB    01D9                  	DEFW	SETINV
  02AD    01D4                  	DEFW	SETBLI
  02AF    01DD                  	DEFW	SETGRA
  02B1    01D4                  	DEFW	SETBLI
  02B3    01F7                  	DEFW	SETMSK
  02B5    01F7                  	DEFW	SETMSK
  02B7    0357                  	DEFW	CLRSCN
  02B9    01EF                  	DEFW	ENATR
  02BB    01F2                  	DEFW	DISATR
                                	IF1
                                	IF	($-ESCADR)/2 NE ESCTBL
                                	.PRINTX	ESCAPE TABLE MISMATCH
                                	ENDIF
                                	ENDIF
                                	ENDIF			;o.esct and options
                                ;
                                ;	ESCAPE - Initialize escape sequence.
                                ;
  02BD    3E 01                 ESCAPE:	LD	A,1
  02BF    12                    	LD	(DE),A		;set sequence state
  02C0    C9                    NONO:	RET			;for escape processing
                                ;
                                ;	STUFF - Enable next char to be stored directly.
                                ;
  02C1    3E 04                 STUFF:	LD	A,4
  02C3    12                    	LD	(DE),A		;set sequence state
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-33
ROM-RESIDENT CRT DRIVER

  02C4    C9                    	RET			;for control character output mode
                                ;
                                ;	DEFCUR - Enable next chara to be new cursor.
                                ;
  02C5    3E 05                 DEFCUR:	LD	A,5
  02C7    12                    	LD	(DE),A
  02C8    C9                    	RET
                                ;
                                ;	HOMEUP - Move cursor to upper left.
                                ;
  02C9    0E 20                 HOMEUP:	LD	C,' '		;use cursor addressing routine
  02CB    C3 0210               	JP	SETROW		;to do homeup almost for free
                                ;
                                ;	BAKSPC - Move cursor left.
                                ;
  02CE    7D                    BAKSPC:	LD	A,L		;check for left margin
  02CF    E6 7F                 	AND	01111111B
  02D1    C8                    	RET	Z		;abort if in leftmost column
  02D2    2D                    	DEC	L		;back up cursor pointer
  02D3    C9                    	RET
                                ;
                                ;	FORSPC - Move cursor right.
                                ;
  02D4    7D                    FORSPC:	LD	A,L		;check for rightmost colunm
  02D5    E6 7F                 	AND	01111111B
  02D7    FE 4F                 	CP	79
  02D9    D0                    	RET	NC		;do nothing if already there
  02DA    2C                    	INC	L
  02DB    C9                    	RET			;else advance the cursor pointer
                                ;
                                ;	UPSCR - Move cursor up.
                                ;
  02DC    11 FF80               UPCSR:	LD	DE,-128		;subtract 1 from row# component
  02DF    19                    	ADD	HL,DE		; of cursor pointer in HL
  02E0    7C                    	LD	A,H
  02E1    FE 30                 	CP	CRTBAS		;check for underflow of pointer
  02E3    D0                    	RET	NC
  02E4    26 3B                 	LD	H,CRTTOP-1	;wrap cursor around modulo 3k
  02E6    C9                    	RET
                                ;
                                ;	DNCSR - Move cursor down.
                                ;
  02E7    11 0080               DNCSR:	LD	DE,128		;add 1 to row# component
  02EA    19                    	ADD	HL,DE		; of cursor pointer in HL
  02EB    7C                    	LD	A,H
  02EC    FE 3C                 	CP	CRTTOP		;check for overflow of pointer
  02EE    D8                    	RET	C
  02EF    26 30                 	LD	H,CRTBAS	;reset pointer modulo 128*24
  02F1    C9                    	RET
                                ;
                                ;	RETURN - Move cursor to left side.
                                ;
  02F2    7D                    RETURN:	LD	A,L		;clear column
  02F3    E6 80                 	AND	10000000B
  02F5    6F                    	LD	L,A		;move cursor pointer back
  02F6    C9                    	RET			; to start of line
                                ;
                                ;	LFEED - Move cursor down with scroll.
                                ;
  02F7    7D                    LFEED:	LD	A,L
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-34
ROM-RESIDENT CRT DRIVER

  02F8    17                    	RLA
  02F9    7C                    	LD	A,H
  02FA    17                    	RLA			;extract row# component of HL
  02FB    E6 1F                 	AND	00011111B
  02FD    4F                    	LD	C,A		;copy row# into C for scroll test
  02FE    CD 02E7               	CALL	DNCSR		;move cursor to next row down
  0301    3A FFB1               	LD	A,(BASE)	;test if cursor was on bottom row
  0304    91                    	SUB	C		;of screen before moving down
  0305    32 F319               	LD	(GOLD),A	;send scroll flag back to fast users
  0308    C0                    	RET	NZ		;exit if not at bottom
  0309    E5                    	PUSH	HL		;prepare scroll screen up
  030A    3A F31C               	LD	A,(USRSTK+1)
  030D    3C                    	INC	A
  030E    C4 040F               	CALL	NZ,BBG		;bury balcones gold, unless monitor running
  0311    CD 0341               	CALL	CLRLIN		;fill top line with spaces
  0314    29                    	ADD	HL,HL
  0315    7C                    	LD	A,H		;get row# component of HL into A
  0316    E6 1F                 	AND	00011111B
  0318    32 FFB1               	LD	(BASE),A	;store new base line#
  031B    D3 14                 	OUT	(SCROLL),A	;scroll top line to bottom
  031D    E1                    	POP	HL		;restore cursor
  031E    C9                    	RET
                                ;
                                ;	TAB - Move cursor to next tab stop.
                                ;
  031F    11 0008               TAB:	LD	DE,8		;tabs are every 8 columns
  0322    7D                    	LD	A,L		;get column component of
  0323    E6 78                 	AND	01111000B	;previous tab position
  0325    83                    	ADD	A,E
  0326    FE 50                 	CP	80
  0328    D0                    	RET	NC		;if next tab column past end of line
  0329    7D                    	LD	A,L
  032A    E6 F8                 	AND	11111000B	;advance cursor to next tab stop
  032C    6F                    	LD	L,A
  032D    19                    	ADD	HL,DE
  032E    C9                    	RET
                                ;
                                ;	BELL - Move speaker back and forth.
                                ;
  032F    3E 35                 BELL:	LD	A,BLTIM		;Bell time constant
  0331    D3 29                 BELL1:	OUT	(BELLON),A	;push speaker out
  0333    06 61                 	LD	B,BLONC		;set Bell on time constant
  0335    10 FE                 	DJNZ	$		;pause B*2 micro seconds
  0337    D3 28                 	OUT	(BELLOF),A	;yank speaker in
  0339    06 61                 	LD	B,BLOFC		;set Bell off time constant
  033B    10 FE                 	DJNZ	$
  033D    3D                    	DEC	A
  033E    20 F1                 	JR	NZ,BELL1	;if more noise to make
  0340    C9                    	RET
                                ;
                                ;	CLRLIN - Clear line.
                                ;
  0341    CD 02F2               CLRLIN:	CALL	RETURN		;return cursor and fall through clreol
                                ;
                                ;	CLREOL - Clear to end of line.
                                ;
  0344    7D                    CLREOL:	LD	A,L
  0345    E6 7F                 	AND	01111111B	;get column component of cursor posistion
  0347    FE 50                 	CP	80
  0349    D0                    	RET	NC		;if someone busted curpos
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-35
ROM-RESIDENT CRT DRIVER

  034A    ED 44                 	NEG
  034C    C6 50                 	ADD	A,80		;calculate number of characters to clear
  034E    47                    	LD	B,A
  034F    7D                    	LD	A,L		;save cursor column
  0350    36 20                 CLR1:	LD	(HL),' '	;clear next location
  0352    2C                    	INC	L
  0353    10 FB                 	DJNZ	CLR1		;if end of line not clear
  0355    6F                    	LD	L,A		;restore cursor column
  0356    C9                    	RET
                                ;
                                ;	CLRSCN - Clear visible screen memory.
                                ;
  0357    21 3000               CLRSCN:	LD	HL,CRTMEM	;home cursor
  035A    3E 17                 	LD	A,23
  035C    32 FFB1               	LD	(BASE),A	;put line 23 at bottom of screen
  035F    D3 14                 	OUT	(SCROLL),A	;note scroll register gets A8-A12, not d0-d7
                                ;
                                ;	CLREOS - Clear to end of screen.
                                ;
  0361    CD 0344               CLREOS:	CALL	CLREOL		;clear remainder of current row
  0364    E5                    	PUSH	HL		;save cursor location
  0365    ED 4B FFB1            CLRS1:	LD	BC,(BASE)	;set bottom screen row to C
  0369    7D                    	LD	A,L
  036A    17                    	RLA
  036B    7C                    	LD	A,H
  036C    17                    	RLA			;get row# component of HL into A
  036D    E6 1F                 	AND	00011111B
  036F    B9                    	CP	C
  0370    28 08                 	JR	Z,CLRS2		;if HL is on bottom row of screen
  0372    CD 02E7               	CALL	DNCSR		;point HL to next row
  0375    CD 0341               	CALL	CLRLIN		;and fill that line with spaces
  0378    18 EB                 	JR	CLRS1
  037A    E1                    CLRS2:	POP	HL		;restore original cursor pointer
  037B    C9                    	RET
                                ;
                                ;	LINDEL - Line delete.
                                ;
  037C    E5                    LINDEL:	PUSH	HL		;save cursor address
  037D    CD 040F               	CALL	BBG		;bury balcones gold
  0380    29                    	ADD	HL,HL
  0381    7C                    	LD	A,H
  0382    E6 1F                 	AND	00011111B	;extract row
  0384    ED 4B FFB0            	LD	BC,(BASE-1)	;get base screen row in B
  0388    CD 03D1               LIND1:	CALL	SMP		;set move parameters
  038B    B8                    	CP	B
  038C    28 10                 	JR	Z,LIND2		;if last line
  038E    C5                    	PUSH	BC		;B=last line, C=row
  038F    01 0050               	LD	BC,80
                                	LDIRS
  0392    ED B0           +     	LDIR
  0394    C1                    	POP	BC
  0395    79                    	LD	A,C
  0396    3C                    	INC	A
  0397    FE 18                 	CP	24
  0399    38 ED                 	JR	C,LIND1
  039B    AF                    	XOR	A		;wrap
  039C    18 EA                 	JR	LIND1		;move next line
  039E    EB                    LIND2:	EX	DE,HL
  039F    CD 0341               LIND3:	CALL	CLRLIN
  03A2    E1                    	POP	HL		;restore original cursor
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-36
ROM-RESIDENT CRT DRIVER

  03A3    C9                    	RET
                                ;
                                ;	LININS - Line insert.
                                ;
  03A4    E5                    LININS:	PUSH	HL		;save cursor position
  03A5    3E 17                 	LD	A,23		;get bottom line
  03A7    CD F31E               	CALL	CCA		;compute cursor address
  03AA    CD 040F               	CALL	BBG		;bury balcones gold
  03AD    E1                    	POP	HL
  03AE    E5                    	PUSH	HL
  03AF    29                    	ADD	HL,HL
  03B0    7C                    	LD	A,H
  03B1    E6 1F                 	AND	00011111B	;extract cursor row
  03B3    47                    	LD	B,A
  03B4    3A FFB1               	LD	A,(BASE)	;set last line
  03B7    B8                    LINI1:	CP	B
  03B8    28 13                 	JR	Z,LINI3		;if move complete
  03BA    3D                    	DEC	A
  03BB    F2 03C0               	JP	P,LINI2
  03BE    3E 17                 	LD	A,23
  03C0    CD 03D1               LINI2:	CALL	SMP		;set move parameters
  03C3    EB                    	EX	DE,HL
  03C4    C5                    	PUSH	BC
  03C5    01 0050               	LD	BC,80
                                	LDIRS
  03C8    ED B0           +     	LDIR
  03CA    C1                    	POP	BC
                                	IF	LDIRSM
                                	LD	A,C
                                	ENDIF
  03CB    18 EA                 	JR	LINI1		;move next line
  03CD    E1                    LINI3:	POP	HL
  03CE    E5                    	PUSH	HL		;restore cursor
  03CF    18 CE                 	JR	LIND3		;clear cursor line
                                ;
                                ;	SMP - Set move parameters.
                                ;
  03D1    4F                    SMP:	LD	C,A		;save row
                                	IF	0
                                	LD	L,0
                                	LD	E,L
                                	ADD	A,CRTBAS SHL 1	;set screen address
                                	LD	D,A
                                	RR	D
                                	RR	E		;destination address
                                	INC	A		;advance row
                                	LD	H,A
                                	RR	H
                                	RR	L
                                	CP	CRTBAS*2+24
                                	JR	NZ,SMP2		;if not on last line
                                	LD	H,CRTBAS
                                SMP2:
                                	ELSE
  03D2    CD F324               	CALL	CCA2
  03D5    EB                    	EX	DE,HL
  03D6    79                    	LD	A,C
  03D7    CD F323               	CALL	CCA1
                                	ENDIF
  03DA    79                    	LD	A,C
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-37
ROM-RESIDENT CRT DRIVER

  03DB    C9                    	RET
                                ;
                                ;	CHRINS - Character insert.
                                ;
  03DC    E5                    CHRINS:	PUSH	HL
  03DD    7D                    	LD	A,L		;set cursor column
  03DE    E6 7F                 	AND	01111111B	;set move length = 79-column
  03E0    ED 44                 	NEG
  03E2    C6 4F                 	ADD	A,79
  03E4    47                    	LD	B,A		;number of characters to move
  03E5    7E                    	LD	A,(HL)		;get character under cursor
  03E6    36 20                 	LD	(HL),' '	;clear character under cursor
  03E8    28 06                 	JR	Z,CHRIN2	;if cursor in last column
  03EA    2C                    CHRIN1:	INC	L
  03EB    4E                    	LD	C,(HL)
  03EC    77                    	LD	(HL),A
  03ED    79                    	LD	A,C
  03EE    10 FA                 	DJNZ	CHRIN1
  03F0    32 F319               CHRIN2:	LD	(GOLD),A	;shift line into the gold mine
  03F3    E1                    	POP	HL
  03F4    C9                    	RET
                                ;
                                ;	CHRDEL - Character delete.
                                ;
  03F5    E5                    CHRDEL:	PUSH	HL
  03F6    7D                    	LD	A,L
  03F7    E6 7F                 	AND	01111111B	;isolate cursor column
  03F9    ED 44                 	NEG
  03FB    C6 4F                 	ADD	A,79
  03FD    4F                    	LD	C,A		;number of chars to move = 79-column
  03FE    06 00                 	LD	B,0
  0400    54                    	LD	D,H
  0401    5D                    	LD	E,L
  0402    1A                    	LD	A,(DE)
  0403    32 F319               	LD	(GOLD),A	;mine balcones gold
  0406    23                    	INC	HL
                                	IF	LDIRSM
                                	CALL	NZ,SIMLDIR	;if cursor not in last column
                                	ELSE
  0407    C4 0418               	CALL	NZ,LDIRX
                                	ENDIF
  040A    EB                    	EX	DE,HL
  040B    36 20                 	LD	(HL),' '	;blank last character on line
  040D    E1                    	POP	HL		;restore cursor
  040E    C9                    	RET
                                ;
                                ;	BBG - Bury balcones gold.
                                ;
  040F    CD 02F2               BBG:	CALL	RETURN
  0412    11 FF5C               	LD	DE,LINBUF	;balcones diamonds are forever
  0415    01 0050               	LD	BC,80
  0418    ED B0                 LDIRX:	LDIR
  041A    C9                    	RET
                                	SUBTTL	LOGICAL TO PHYSICAL DRIVER EXECUTIONER
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-38
LOGICAL TO PHYSICAL DRIVER EXECUTIONER

                                
                                	ABOVE			;code goes in RAM
  0518!                   +     	D&SEG
                                ;
                                ;	XQDVR - Execute Physical Driver.
                                ;
                                ;	Entry:	HL = Pointer to Physical Drive Request Block
                                ;
                                ;	Exit:	See Physical Driver
                                ;
  F344    23                    XQDVR:	INC	HL		;point at physical unit
  F345    E5                    	PUSH	HL
  F346    23                    	INC	HL
  F347    5E                    	LD	E,(HL)		;set logical drive
  F348    21 F360               	LD	HL,SELTAB	;Set driver mapping table address
  F34B    16 00                 	LD	D,0
  F34D    19                    	ADD	HL,DE		;index into driver select table
  F34E    19                    	ADD	HL,DE
  F34F    5E                    	LD	E,(HL)		;set physical driver index
  F350    23                    	INC	HL
  F351    7E                    	LD	A,(HL)		;set physical unit
  F352    21 F380               	LD	HL,DVRTAB	;set driver table address
  F355    19                    	ADD	HL,DE
  F356    19                    	ADD	HL,DE
  F357    5E                    	LD	E,(HL)		;set physical driver address
  F358    23                    	INC	HL
  F359    56                    	LD	D,(HL)
  F35A    E1                    	POP	HL		;recover request block address
  F35B    77                    	LD	(HL),A		;store physical unit
  F35C    2B                    	DEC	HL
  F35D    D5                    	PUSH	DE		;execute physical driver
  F35E    C9                    	RET
                                	SUBTTL	PHYSICAL DISK DRIVER AREA
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-39
PHYSICAL DISK DRIVER AREA

                                
                                ;
                                ;	Physical Disk Driver Area.
                                ;
                                ;	1.25k of space is reserved here for the Physical Disk Drivers.
                                ;	These drivers are assembled separately and included prior
                                ;	to ROM production.
                                ;
                                	ABOVE
  035F"                   +     	D&SEG
                                ;
                                ;	Waste space to get drivers on page boundry.
                                ;
  F35F                          WASTED:
  000F                          BNDRY	EQU	0FH
                                	IF	($ AND BNDRY) NE 0
  F35F                          	DEFS	BNDRY+1-($ AND BNDRY),-1
                                	ENDIF
  F360    53 45 4C 54           SELTAB:	DEFM	'SELTAB AND PHYSICAL DRIVERS HERE'
  F364    41 42 20 41           
  F368    4E 44 20 50           
  F36C    48 59 53 49           
  F370    43 41 4C 20           
  F374    44 52 49 56           
  F378    45 52 53 20           
  F37C    48 45 52 45           
  F380                          	DEFS	32-($-SELTAB),0	;Drive Select Mapping Table goes here
  F380                          DVRTAB:	REPT	8		;Physical Driver Address Table goes here
                                	DEFW	SELERR
                                	ENDM
  F380    FA08            +     	DEFW	SELERR
  F382    FA08            +     	DEFW	SELERR
  F384    FA08            +     	DEFW	SELERR
  F386    FA08            +     	DEFW	SELERR
  F388    FA08            +     	DEFW	SELERR
  F38A    FA08            +     	DEFW	SELERR
  F38C    FA08            +     	DEFW	SELERR
  F38E    FA08            +     	DEFW	SELERR
  F390                          DSKDVR:
  0298                          WD17DL	EQU	298H
  0300                          SASIDL	EQU	300H
  F470                          FIVDPB	EQU	$+8*16+26+6+4*16
  F708                          RIGDPB	EQU	FIVDPB+WD17DL
  F770                          IOBLOC	EQU	FIVDPB+SASIDL
                                	IF	OPTIONS AND O.DDVR
  F390                          	DEFS	FIVDPB-DSKDVR+WD17DL+SASIDL,-1	;Disk Drivers here
                                	ENDIF
  FA08                          DVRLMT:				;disk driver limit
  FA08                          RQTOP	EQU	$		;set required top of resident monitor
  FA08    21 0000               SELERR:	LD	HL,0
  FA0B    F6 FF                 	OR	-1
  FA0D    C9                    	RET
                                	SUBTTL	820 STYLE DISK DRIVER EMULATOR
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-40
820 STYLE DISK DRIVER EMULATOR

                                
                                ;
                                ;	820 Style Disk Driver Emulator.
                                ;
                                	ABOVE			;generate code in RAM
  0A0E"                   +     	D&SEG
  FA0E    FF                    PHYCMD:	DEFB	-1		;physical Driver Command
  FA0F    FF                    PHYUNT:	DEFB	-1		;physical unit
  FA10    00                    PHYDRV:	DEFB	00		;logical unit
  FA11    0000                  PHYTRK:	DEFW	00		;track
  FA13    0001                  PHYSEC:	DEFW	01		;sector
  FA15    ED80                  PHYDMA:	DEFW	BOOTBF		;dma address
                                ;
                                ;	SELECT - Select Unit for I/O.
                                ;
                                ;	Entry:	C  = Unit
                                ;	Exit:	A  = 0  if no errors
                                ;		A  = -1 if errors
                                ;
                                ;	Select is documented as not switching units if the new unit
                                ;	is not ready.  This is not a very good idea.  This driver
                                ;	does remember the new unit, so that a seek/read/write will fail.
                                ;
  FA17    79                    SELECT:	LD	A,C		;set drive selected
  FA18    FE 08                 	CP	8
  FA1A    30 1D                 	JR	NC,SEL1
  FA1C    32 FA10               	LD	(PHYDRV),A	;save logical CP/M drive
  FA1F    21 FA5A               	LD	HL,SELTBL	;set select table address
  FA22    06 00                 	LD	B,0
  FA24    09                    	ADD	HL,BC		;index into select table
  FA25    7E                    	LD	A,(HL)
  FA26    B7                    	OR	A
  FA27    EB                    	EX	DE,HL
  FA28    67                    	LD	H,A		;in case previous select worked, say no DPH
  FA29    6F                    	LD	L,A		;to internal routines
  FA2A    C8                    	RET	Z		;if drive has already been selected
  FA2B    D5                    	PUSH	DE		;save table address
  FA2C    06 FF                 	LD	B,-1		;set Select operation
  FA2E    CD FA51               	CALL	XQPHYS		;execute physical driver
  FA31    7D                    	LD	A,L		;get returned DPH address
  FA32    B4                    	OR	H
  FA33    D1                    	POP	DE		;retrieve select table address
  FA34    28 03                 	JR	Z,SEL1		;if select unsuccessful
  FA36    AF                    	XOR	A		;return no errors
  FA37    12                    	LD	(DE),A		;prevent more density re-selects
  FA38    C9                    	RET
  FA39    F6 FF                 SEL1:	OR	-1		;return error
  FA3B    C9                    	RET
                                ;
                                ;	HOME - Position to track zero.
                                ;
  FA3C    0E 00                 HOME:	LD	C,0		;force track zero
                                ;
                                ;	SEEK - Seek Track.
                                ;
                                ;	Entry:	C  = Track to read/write from next
                                ;
  FA3E    79                    SEEK:	LD	A,C
  FA3F    32 FA11               	LD	(PHYTRK),A
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-41
820 STYLE DISK DRIVER EMULATOR

  FA42    AF                    	XOR	A		;return no errors
  FA43    C9                    	RET
                                ;
                                ;	WRITE - Write Physical Sector.
                                ;
  FA44    06 00                 WRITE:	LD	B,0		;set write operation
  FA46    18 02                 	JR	RDWR
                                ;
                                ;	READ - Read Physical Sector.
                                ;
  FA48    06 01                 READ:	LD	B,1		;set read operation
                                ;
                                ;	RDWR - Read/Write Processor.
                                ;
                                ;	Entry:	C  = Sector
                                ;		HL = Transfer Address
                                ;	Exit:	A  = 0 if no errors
                                ;		A  = -1 if errors
                                ;
  FA4A    79                    RDWR:	LD	A,C
  FA4B    32 FA13               	LD	(PHYSEC),A	;set physical sector
  FA4E    22 FA15               	LD	(PHYDMA),HL	;set transfer address
                                ;
                                ;	XQPHYS - Internal Execute Physical Driver.
                                ;
                                ;	Entry:	B  = -1 for Select
                                ;		B  =  0 for Write
                                ;		B  =  1 for Read
                                ;
  FA51    21 FA0E               XQPHYS:	LD	HL,PHYCMD	;point to physical command block
  FA54    70                    	LD	(HL),B		;store operation
  FA55    CD F344               	CALL	XQDVR		;execute driver
  FA58    B7                    	OR	A		;set flags
  FA59    C9                    	RET
                                ;
                                ;	Emulator Disk I/O RAM.
                                ;
  FA5A    FF FF FF FF           SELTBL:	DEFB	-1,-1,-1,-1	;drive already selected table
  FA5E    FF FF FF FF           	DEFB	-1,-1,-1,-1
                                	SUBTTL	COMMAND PROCESSOR
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-42
COMMAND PROCESSOR

                                
                                	ABOVE			;put code upstairs
  0A62"                   +     	D&SEG
                                ;
                                ;	Prompt user for command.
                                ;
  FA62    FB                    PROMPT:	EI
  FA63    31 0000               	LD	SP,STACK	;reset system stack
  FA66    CD FC3D               	CALL	PNEXT
  FA69    0D 0A                 	DEFB	CR,LF
  FA6B    2A 20                 	DEFM	'* '
  FA6D    04                    	DEFB	EOT
  FA6E    21 FF5C               	LD	HL,LINBUF
  FA71    0E 50                 	LD	C,80		;buffer of 80 chars (ver. 2.0)
  FA73    CD FB37               	CALL	GETLIN		;input a bufered console line
  FA76    38 51                 	JR	C,WHAT		;print 'what ?' if input error
  FA78    3A FF5C               AUTOBT:	LD	A,(LINBUF)	;get first character in line
  FA7B    FE 0D                 	CP	CR
  FA7D    28 E3                 	JR	Z,PROMPT	;jump if a null line
  FA7F    D6 40                 	SUB	'@'
  FA81    FE 1B                 	CP	'Z'-'@'+1
  FA83    30 44                 	JR	NC,WHAT		;if not letter
  FA85    87                    	ADD	A,A
  FA86    4F                    	LD	C,A
  FA87    06 00                 	LD	B,0
  FA89    21 FAD9               	LD	HL,CMDTAB+1	;index command table with character
  FA8C    09                    	ADD	HL,BC
  FA8D    7E                    	LD	A,(HL)
  FA8E    2B                    	DEC	HL
  FA8F    6E                    	LD	L,(HL)		;get address of command processor
  FA90    67                    	LD	H,A
  FA91    E6 80                 	AND	80H
  FA93    20 17                 	JR	NZ,PRMT1	;if resident command
  FA95    11 FC55               	LD	DE,CLOC		;move transient command to RAM area
  FA98    D5                    	PUSH	DE
  FA99    01 0299               	LD	BC,TPAMAX	;set length of largest transient
  FA9C    F3                    	DI
  FA9D    DB 1C                 	IN	A,(SYSPIO)
  FA9F    B7                    	OR	A
  FAA0    F5                    	PUSH	AF
  FAA1    F4 F29C               	CALL	P,CRTON		;enable ROM if disabled
  FAA4    ED B0                 	LDIR
  FAA6    F1                    	POP	AF
  FAA7    F4 F293               	CALL	P,CRTOFF	;disable ROM if enabled
  FAAA    FB                    	EI
  FAAB    E1                    	POP	HL		;set execution address
  FAAC    E5                    PRMT1:	PUSH	HL
  FAAD    CD FC36               	CALL	CRLF
  FAB0    FD 21 FF5D            	LD	IY,LINBUF+1
  FAB4    CD FB5F               	CALL	PARAMS		;input numeric parameters from
  FAB7    DD E1                 	POP	IX		;line buffer and test if error
  FAB9    2A FFB5               	LD	HL,(PARAM1)
  FABC    ED 5B FFB7            	LD	DE,(PARAM2)
  FAC0    ED 4B FFB9            	LD	BC,(PARAM3)
  FAC4    CD FAD6               	CALL	JPIX		;call subroutine @ IX
  FAC7    30 99                 	JR	NC,PROMPT	;go back to prompt if no errors
  FAC9    CD FC3D               WHAT:	CALL	PNEXT
  FACC    20 57 68 61           	DEFM	' What?'
  FAD0    74 3F                 
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-43
COMMAND PROCESSOR

  FAD2    07                    	DEFB	'G'-64		;say 'what ?' and squeal
  FAD3    04                    	DEFB	EOT
  FAD4    18 8C                 	JR	PROMPT
  FAD6    DD E9                 JPIX:	JP	(IX)		;call subroutine @ ix
  FAD8    177B                  CMDTAB:	DEFW	HELP		;@ - Help user
  FADA    11B8                  	DEFW    BOOT            ;a - boot cp/m
  FADC    1353                  	DEFW	BAUD		;b - bit rate
  FADE    1436                  	DEFW	BLOCK		;c - memory block move
  FAE0    12F2                  	DEFW	MEMDMP		;d - dump memory in hex/ascii
  FAE2    1315                  	DEFW	VIEW		;e - enter memory
  FAE4    1428                  	DEFW	FILL		;f - fill memory
  FAE6    12DB                  	DEFW	GOTO		;g - goto program
  FAE8    14E2                  	DEFW	TERM		;h - host terminal
  FAEA    13CA                  	DEFW	INCMD		;i - read from input port
  FAEC    FAC9                  	DEFW	WHAT		;j - not used
  FAEE    FAC9                  	DEFW	WHAT		;k - not used
  FAF0    11B8                  	DEFW	BOOT		;l - load system
  FAF2    1315                  	DEFW	VIEW		;m - memory examine/change
  FAF4    FAC9                  	DEFW	WHAT		;n - not used
  FAF6    13F1                  	DEFW	OUTCMD		;o - write to output port
  FAF8    1459                  	DEFW	PROTO		;p - printer protocol
  FAFA    FAC9                  	DEFW	WHAT		;q - not used
  FAFC    1367                  	DEFW	DSKCMD		;r - display disk sector data
  FAFE    FAC9                  	DEFW	WHAT		;s - not used
  FB00    1477                  	DEFW	TYPE		;t - typewriter mode
  FB02    FAC9                  	DEFW	WHAT		;u - not used
  FB04    1443                  	DEFW	VERCMD		;v - memory block compare
  FB06    1367                  	DEFW	DSKCMD		;w - disc sector write command
  FB08    13FB                  	DEFW	TEST		;x - RAM diagnostic
  FB0A    FAC9                  	DEFW	WHAT		;y - not used
  FB0C    FAC9                  	DEFW	WHAT		;z - not used
  0036                          CMDSIZ	EQU	$-CMDTAB
  FB0E    BE                    CHECK:	CP	(HL)
  FB0F    C8                    	RET	Z		;return if (HL)=A
  FB10    F5                    	PUSH	AF
  FB11    CD FB22               	CALL	MDATA		;print what was actually read
  FB14    CD FC3D               	CALL	PNEXT
  FB17    53 68 6F 75           	DEFM	'Should='
  FB1B    6C 64 3D              
  FB1E    04                    	DEFB	EOT
  FB1F    F1                    	POP	AF
  FB20    18 07                 	JR	PUT2J
  FB22    CD FC36               MDATA:	CALL	CRLF
  FB25    CD FC16               	CALL	PUT4HS
  FB28    7E                    	LD	A,(HL)
  FB29    C3 FC1B               PUT2J:	JP	PUT2HS
                                	SUBTTL	CONSOLE SUPPORT ROUTINES
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-44
CONSOLE SUPPORT ROUTINES

                                
                                ;
                                ;	GETLIN - Read line into buffer.
                                ;
  FB2C    3E 40                 GETHLP:	LD	A,'@'
  FB2E    32 FF5C               	LD	(LINBUF),A
  FB31    3E 0D                 	LD	A,CR
  FB33    32 FF5D               	LD	(LINBUF+1),A
  FB36    C9                    	RET
  FB37    41                    GETLIN:	LD	B,C		;save max line length parameter in B
  FB38    CD FC27               GLIN1:	CALL	ECHO		;get a character from the console
  FB3B    FE 1E                 	CP	HELPKEY
  FB3D    28 ED                 	JR	Z,GETHLP	;if user needs help
  FB3F    77                    	LD	(HL),A
  FB40    FE 0D                 	CP	CR		;check for carriage return
  FB42    C8                    	RET	Z		;if end of line
  FB43    FE 08                 	CP	'H'-64		;check for ctl-H backspace
  FB45    28 09                 	JR	Z,GLIN4
  FB47    FE 20                 	CP	' '
  FB49    D8                    	RET	C		;other control characters are illegal
  FB4A    23                    	INC	HL		;store character in buffer
  FB4B    0D                    	DEC	C
  FB4C    20 EA                 	JR	NZ,GLIN1	;get another if there's more room
  FB4E    37                    	SCF
  FB4F    C9                    	RET			;return with carry=1 if too
                                				;many characters are entered
  FB50    2B                    GLIN4:	DEC	HL		;delete last character from buffer
  FB51    CD FC3D               	CALL	PNEXT
  FB54    20 08                 	DEFB	' ','H'-64	;delete character from screen
  FB56    04                    	DEFB	EOT
  FB57    0C                    	INC	C
  FB58    78                    	LD	A,B		;set max line length
  FB59    91                    	SUB	C
  FB5A    30 DC                 	JR	NC,GLIN1	;if backspace not past the start of the line
  FB5C    C9                    	RET
  FB5D    FD 23                 PARA0:	INC	IY		;advance character scan
  FB5F    01 00FF               PARAMS:	LD	BC,LOW -1	;set parameter index
  FB62    FD 7E 00              	LD	A,(IY+0)	;fetch character
  FB65    D6 0D                 	SUB	CR
  FB67    C8                    	RET	Z		;if no parameters
  FB68    D6 13                 	SUB	' '-CR
  FB6A    28 F1                 	JR	Z,PARA0		;if leading blanks
  FB6C    0C                    PARA1:	INC	C		;advance parameter index
  FB6D    CB 51                 	BIT	2,C
  FB6F    37                    	SCF
  FB70    C0                    	RET	NZ		;error if > 4 numbers entered
  FB71    C5                    PARA2:	PUSH	BC		;save parameter count
  FB72    CD FBDA               	CALL	GETHEX		;read a number from line buffer
  FB75    C1                    	POP	BC
  FB76    DD 21 FFB5            PARA4:	LD	IX,PARAM1	;point to parameter storage area
  FB7A    DD 09                 	ADD	IX,BC		;add parameter count in bc
  FB7C    DD 09                 	ADD	IX,BC
  FB7E    DD 75 00              	LD	(IX+0),L
  FB81    DD 74 01              	LD	(IX+1),H	;store data returned from 'GETHEX'
  FB84    FE 20                 	CP	' '
  FB86    28 E4                 	JR	Z,PARA1		;get another item if space
  FB88    FE 2C                 	CP	','
  FB8A    28 E0                 	JR	Z,PARA1		;get another item if comma
  FB8C    79                    	LD	A,C		;set parameter count
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-45
CONSOLE SUPPORT ROUTINES

  FB8D    3C                    	INC	A
  FB8E    C9                    	RET
                                ;
                                ;	DUMP - Dump memory.
                                ;
  FB8F    E5                    DUMP:	PUSH	HL		;save starting address
  FB90    CD FC16               	CALL	PUT4HS		;print starting address in hex
  FB93    CD FC1E               	CALL	SPACE
  FB96    06 10                 	LD	B,16
  FB98    3E 0F                 DUMP2:	LD	A,16-1		;skip 3 columns on 16 byte boundry
  FB9A    CD FC23               	CALL	DMPFMT
  FB9D    3E 07                 	LD	A,8-1		;skip 2 columns on 8 byte boundry
  FB9F    CD FC23               	CALL	DMPFMT
  FBA2    3E 03                 	LD	A,4-1		;skip 1 column  on 4 byte boundry
  FBA4    CD FC23               	CALL	DMPFMT
  FBA7    7E                    	LD	A,(HL)		;get a data byte @ HL
  FBA8    23                    	INC	HL
  FBA9    CD FC1B               	CALL	PUT2HS		;print the data in hex
  FBAC    10 EA                 	DJNZ	DUMP2		;repeat 16 times
  FBAE    CD FC1E               	CALL	SPACE
  FBB1    E1                    	POP	HL		;restore starting address
  FBB2    06 10                 	LD	B,16
  FBB4    3E 1F                 DUMP3:	LD	A,1FH		;force next character
  FBB6    CD F00C               	CALL	CONOUT
  FBB9    7E                    	LD	A,(HL)		;get back data byte @ HL
  FBBA    23                    	INC	HL
  FBBB    CD F00C               	CALL	CONOUT		;print ASCII character in A
  FBBE    10 F4                 	DJNZ	DUMP3
  FBC0    CD F006               	CALL	CONST		;check console status
  FBC3    28 0C                 	JR	Z,DUMP4		;if character not ready
  FBC5    CD F009               	CALL	CONIN		;read character
  FBC8    FE 0D                 	CP	CR
  FBCA    C8                    	RET	Z		;if user abort
  FBCB    CD F009               	CALL	CONIN		;pause while user examines display
  FBCE    FE 0D                 	CP	CR
  FBD0    C8                    	RET	Z		;if user found it
  FBD1    CD FC36               DUMP4:	CALL	CRLF		;send end of line
  FBD4    1B                    	DEC	DE
  FBD5    7A                    	LD	A,D
  FBD6    B3                    	OR	E
  FBD7    20 B6                 	JR	NZ,DUMP		;if dump not complete
  FBD9    C9                    	RET
                                ;
                                ;	GETHEX - Converts ASCII to binary.
                                ;
                                ;	Carry set on illegal conversion result
                                ;	Terminating character returns in A.
                                ;	HL returns with 16 bit binary integer
                                ;
  FBDA    21 0000               GETHEX:	LD	HL,0		;preset result
  FBDD    54                    	LD	D,H
  FBDE    5D                    	LD	E,L
  FBDF    29                    GNUM1:	ADD	HL,HL		;multiply result by 16
  FBE0    29                    	ADD	HL,HL
  FBE1    29                    	ADD	HL,HL
  FBE2    29                    	ADD	HL,HL
  FBE3    19                    	ADD	HL,DE		;append next digit
  FBE4    FD 7E 00              GNUM3:	LD	A,(IY+0)	;get next character from line buffer
  FBE7    4F                    	LD	C,A
  FBE8    FD 23                 	INC	IY		;advance buffer address
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-46
CONSOLE SUPPORT ROUTINES

  FBEA    CD FBF3               	CALL	HEXBIN		;convert one ASCII hex to binary
  FBED    5F                    	LD	E,A
  FBEE    30 EF                 	JR	NC,GNUM1
  FBF0    79                    	LD	A,C		;return first non hex digit
  FBF1    B7                    	OR	A
  FBF2    C9                    	RET
                                ;
                                ;	HEXBIN - Convert hex to binary.
                                ;
  FBF3    D6 30                 HEXBIN:	SUB	'0'
  FBF5    D8                    	RET	C
  FBF6    FE 0A                 	CP	10
  FBF8    3F                    	CCF
  FBF9    D0                    	RET	NC
  FBFA    D6 07                 	SUB	7
  FBFC    FE 0A                 	CP	10
  FBFE    D8                    	RET	C
  FBFF    FE 10                 	CP	16
  FC01    3F                    	CCF
  FC02    C9                    	RET
  FC03    F5                    PUT2HX:	PUSH	AF
  FC04    1F                    	RRA
  FC05    1F                    	RRA
  FC06    1F                    	RRA
  FC07    1F                    	RRA
  FC08    CD FC0C               	CALL	PUTNIB
  FC0B    F1                    	POP	AF
  FC0C    E6 0F                 PUTNIB:	AND	00001111B
  FC0E    C6 90                 	ADD	A,90H
  FC10    27                    	DAA
  FC11    CE 40                 	ADC	A,40H
  FC13    27                    	DAA
  FC14    18 0A                 	JR	OUTPUT
  FC16    7C                    PUT4HS:	LD	A,H
  FC17    CD FC03               	CALL	PUT2HX
  FC1A    7D                    	LD	A,L
  FC1B    CD FC03               PUT2HS:	CALL	PUT2HX
                                ;
                                ;	SPACE - Output space.
                                ;
  FC1E    3E 20                 SPACE:	LD	A,' '		;fall through to output space
  FC20    C3 F00C               OUTPUT:	JP	CONOUT		;display character
                                ;
                                ;	DMPFMT - Dump Command Output Formatter.
                                ;
  FC23    A5                    DMPFMT:	AND	L		;check address boundry
  FC24    C0                    	RET	NZ		;if not on boundry
  FC25    18 F7                 	JR	SPACE		;skip one column
                                ;
                                ;	ECHO - Read and echo console character.
                                ;
                                ;	Echo inputs one character from the console
                                ;	device, prints it on the console output and
                                ;	then returns it in the A register in upper case.
                                ;
  FC27    CD F009               ECHO:	CALL	CONIN		;input a character and echo it
  FC2A    FE 1E                 	CP	HELPKEY
  FC2C    C8                    	RET	Z		;do not echo help key
  FC2D    CD F00C               	CALL	CONOUT
  FC30    FE 41                 	CP	'A'
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-47
CONSOLE SUPPORT ROUTINES

  FC32    D8                    	RET	C		;if not lower case
  FC33    D6 00                 	SUB	'A'-'A'		;convert lower case to upper case
  FC35    C9                    	RET
                                ;
                                ;	CRLF - Carriage Return/Line Feed.
                                ;
  FC36    CD FC3D               CRLF:	CALL	PNEXT		;print next message
  FC39    0D 0A 04              	DEFB	CR,LF,EOT
  FC3C    C9                    	RET
                                ;
                                ;	PNEXT - Print message after call.
                                ;
  FC3D    E3                    PNEXT:	EX	(SP),HL		;set message address
  FC3E    7E                    	LD	A,(HL)
  FC3F    23                    	INC	HL
  FC40    E3                    	EX	(SP),HL		;set return address
  FC41    FE 04                 	CP	EOT
  FC43    C8                    	RET	Z
  FC44    CD F00C               	CALL	CONOUT
  FC47    18 F4                 	JR	PNEXT
                                	IF	OPTIONS AND (O.MOVE OR O.VERF)
                                ;
                                ;	Set block address for move and verify.
                                ;
  FC49    EB                    BLOCAD:	EX	DE,HL
  FC4A    B7                    	OR	A		;clear carry
  FC4B    ED 52                 	SBC	HL,DE		;get diffrence between
  FC4D    EB                    	EX	DE,HL		;HL & DE for bytecount
  FC4E    D5                    	PUSH	DE		;exchange DE, BC
  FC4F    50                    	LD	D,B
  FC50    59                    	LD	E,C
  FC51    C1                    	POP	BC
  FC52    03                    	INC	BC		;get count+1 into BC
  FC53    C9                    	RET
                                	ENDIF
  FC54    C9                    	RET
