  FDE2    E5                    	PUSH	HL
  FDE3    CD FE9B               	CALL	OUTCRT		;display character
  FDE6    E1                    	POP	HL
  FDE7    C1                    	POP	BC
  FDE8    10 E8                 	DJNZ	DLN3		;if not entire line
  FDEA    C9                    	RET
