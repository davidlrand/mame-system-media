BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-63
TERMINAL / SCREEN MANAGER		

                                
                                	OVERLAY	TERM
  0472'                   +     	C&SEG
  000F                          PASS8	EQU	15
  0016                          INSLIN	EQU	22
  0017                          DELLIN	EQU	23
  001A                          CLRCHR	EQU	26
  001E                          HOMSCR	EQU	30
  001F                          FORCE	EQU	31
  0081                          KUPLIN	EQU	81H		;Move top line off screen to buffer
  0082                          KDNLIN	EQU	82H		;Move bottom line off screen to buffer
  00B1                          RMTTOG	EQU	80H+'1'		;Toggle Remote Echo
  00B2                          RMTALF	EQU	80H+'2'		;Toggle Remote Auto LF after CR
  008A                          LOCALF	EQU	80H+LF		;Toggle Local Auto LF after CR
  00FF                          TYPTOG	EQU	80H+7FH		;Toggle Local Echo
  00AE                          BRKKEY	EQU	80H+'.'		;Hardware BREAK function
  0007                          S.LECHO	EQU	7		;local echo
  0006                          S.RECHO	EQU	6		;remote echo
  0005                          S.AUTOL	EQU	5		;local auto LF after CR
  0004                          S.AUTOR	EQU	4		;remote auto LF after CR
  0100                          TRMBUF	EQU	100H
  EE80                          BUFTOP	EQU	TRMBUF+760*80
  EF00                          SIOBUF	EQU	MONITR-100H
  EF00                          TRMSTK	EQU	SIOBUF
  FC55    FE 02                 	CP	2		;check number of arguments
  FC57    3F                    	CCF
  FC58    D8                    	RET	C		;if more than 1
  FC59    B7                    	OR	A
  FC5A    20 02                 	JR	NZ,TERM1	;if port specifed
  FC5C    2E 00                 	LD	L,0
  FC5E    01 0406               TERM1:	LD	BC,SIOCPA+SIODPA*256	;preset A channel ports
  FC61    CB 45                 	BIT	0,L
  FC63    28 03                 	JR	Z,TERM2		;if 0/1 or A/B
  FC65    01 0507               	LD	BC,SIOCPB+SIODPB*256	;set B channel ports
  FC68    ED 43 FE78            TERM2:	LD	(PORTS),BC
  FC6C    31 EF00               	LD	SP,TRMSTK
  FC6F    CD FC3D               	CALL	PNEXT
  FC72    1A                    	DB	CLRS
                                	IF	OPTIONS AND O.ESCT
  FC73    1B 31                 	DB	ESC,'1'
                                	ELSE
                                	DB	PASS8
                                	ENDIF
  FC75    54 65 72 6D           	DB	'Terminal mode.  Touch CTRL+ESC to exit.'
  FC79    69 6E 61 6C           
  FC7D    20 6D 6F 64           
  FC81    65 2E 20 20           
  FC85    54 6F 75 63           
  FC89    68 20 43 54           
  FC8D    52 4C 2B 45           
  FC91    53 43 20 74           
  FC95    6F 20 65 78           
  FC99    69 74 2E              
  FC9C    0D 0A                 	DB	CR,LF
  FC9E    04                    	DB	EOT
  FC9F    FD 21 FEE5            	LD	IY,STATUS	;set pointer to status byte
  FCA3    CD F006               TERM3:	CALL	CONST		;status keyboard
  FCA6    C4 FCB1               	CALL	NZ,PKI		;process keyboard input
  FCA9    CD FEC8               	CALL	SIOIST		;status SIO
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-64
TERMINAL / SCREEN MANAGER		

  FCAC    C4 FD40               	CALL	NZ,PRC		;process remote character
  FCAF    18 F2                 	JR	TERM3		;until user escapes
                                ;
                                ;	PKI - Process Keyboard Input.
                                ;
  FCB1    3E 00                 PKI:	LD	A,0
  FCB2                          BRKFLG	EQU	$-1
  FCB3    B7                    	OR	A
  FCB4    C4 FD21               	CALL	NZ,CLRBRK	;terminate pending break
  FCB7    CD F009               	CALL	CONIN		;read input
  FCBA    CB 7F                 	BIT	7,A
  FCBC    20 0B                 	JR	NZ,PKI1		;if function key
  FCBE    CD FD5F               	CALL	SNDRMT		;send it to remote
  FCC1    FD CB 00 7E           	BIT	S.LECHO,(IY)
  FCC5    C4 FD4C               	CALL	NZ,SNDLOC	;if local echo enabled, display console input
  FCC8    C9                    	RET
  FCC9    FE 81                 PKI1:	CP	KUPLIN
  FCCB    20 12                 	JR	NZ,PKI2		;if not scroll up
  FCCD    CD FE50               	CALL	GCP		;get cursor position
  FCD0    CD FC3D               	CALL	PNEXT		;home screen, then delete top line
                                	IF	OPTIONS AND O.ESCT
  FCD3    1E 1B 52 04           	DEFB	HOMSCR,ESC,'R',EOT
                                	ELSE
                                	DEFB	HOMSCR,DELLIN,EOT
                                	ENDIF
  FCD7    CD FD89               	CALL	LTL		;link top line
  FCDA    CD FDEB               	CALL	DBL		;display bottom line
  FCDD    18 14                 	JR	PKI3
  FCDF    FE 82                 PKI2:	CP	KDNLIN
  FCE1    20 13                 	JR	NZ,PKI4		;if not scroll down
  FCE3    CD FE50               	CALL	GCP		;get cursor position
  FCE6    CD FC3D               	CALL	PNEXT		;home screen, insert blank line
                                	IF	OPTIONS AND O.ESCT
  FCE9    1E 1B 45 04           	DEFB	HOMSCR,ESC,'E',EOT
                                	ELSE
                                	DEFB	HOMSCR,DELLIN,EOT
                                	ENDIF
  FCED    CD FE0B               	CALL	LBL		;link bottom line
  FCF0    CD FDB1               	CALL	DTL		;display top line
  FCF3    C3 FE6E               PKI3:	JP	RCP		;restore cursor position
  FCF6    FE FF                 PKI4:	CP	TYPTOG
  FCF8    20 04                 	JR	NZ,PKI5
  FCFA    3E 80                 	LD	A,1 SHL S.LECHO
  FCFC    18 16                 	JR	PKI8
  FCFE    FE B1                 PKI5:	CP	RMTTOG
  FD00    20 04                 	JR	NZ,PKI6
  FD02    3E 40                 	LD	A,1 SHL S.RECHO
  FD04    18 0E                 	JR	PKI8
  FD06    FE 8A                 PKI6:	CP	LOCALF
  FD08    20 04                 	JR	NZ,PKI7
  FD0A    3E 20                 	LD	A,1 SHL S.AUTOL
  FD0C    18 06                 	JR	PKI8
  FD0E    FE B2                 PKI7:	CP	RMTALF
  FD10    20 09                 	JR	NZ,PKI9
  FD12    3E 10                 	LD	A,1 SHL S.AUTOR
  FD14    FD AE 00              PKI8:	XOR	(IY)
  FD17    FD 77 00              	LD	(IY),A
  FD1A    C9                    	RET
  FD1B    FE AE                 PKI9:	CP	BRKKEY
  FD1D    C0                    	RET	NZ
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-65
TERMINAL / SCREEN MANAGER		

  FD1E    3A FCB2               	LD	A,(BRKFLG)
  FD21    EE FF                 CLRBRK:	XOR	-1
  FD23    32 FCB2               	LD	(BRKFLG),A
  FD26    16 10                 	LD	D,10H		;set line SPACING
  FD28    20 02                 	JR	NZ,SETBRK
  FD2A    16 00                 	LD	D,0		;set line MARKING
  FD2C    ED 4B FE78            SETBRK:	LD	BC,(PORTS)
