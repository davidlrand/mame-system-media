BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-7
CODE GENERATION CONTROL MACROS DEFINITIONS

                                
                                ;
                                ;	ROM Code Placement Macros.
                                ;
                                ;
                                ;	The Common Segment holds the non-resident (banked) portion
                                ;	of the monitor.  This segment is not copied to RAM.
                                ;
                                ;
                                ;	The Data Segment holds the resident portion of the monitor.
                                ;	It is moved to RAM, at location MONITR during initialization.
                                ;
                                ;
                                ;	The Code Segment holds the various Transient Commands.  Each
                                ;	command is loaded from the ROM to the TPA when it is executed.
                                ;
                                ;
                                ;	The following macros keep it all straight.
                                ;
                                ;
                                ;	BELOW - Generate code for ROM below.
                                ;
                                BELOW	MACRO
                                	SEGMENT	B		;;enable common segment
                                	ENDM
                                ;
                                ;	ABOVE - Generate code for RAM above.
                                ;
                                ABOVE	MACRO
                                	SEGMENT	D		;;enable data segment
                                	ENDM
                                ;
                                ;	OVERLAY - Generate code for transients.
                                ;
                                OVERLAY	MACRO	ADDR
                                TLOC	DEFL	TLOC+$-CLOC
                                ADDR	EQU	TLOC+BLOC+CLOC-MONITR
                                	SEGMENT	C		;;enable code segment
                                	ENDM
                                ;
                                ;	BSEG - activate common segment.
                                ;
                                BSEG	MACRO
                                	COMMON	/COMROM/
                                	DEFS	COMRES
                                SEGA	DEFL	$
                                	ENDM
                                ;
                                ;	SEGMENT - Activate Segment.
                                ;
                                SEGMENT	MACRO	S
                                	UPDATE			;;update active phase counter
                                S&SPACE	DEFL	-1		;;set enabled segment active        
                                	S&SEG			;;activate segment code placement
                                	.PHASE	S&LOC		;;set absolute segment location counter
                                	ENDM
                                ;
                                ;	UPDATE - Update Phase Counters.
                                ;
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-8
CODE GENERATION CONTROL MACROS DEFINITIONS

                                UPDATE	MACRO
                                	IF	BSPACE
                                COMRES	DEFL	$-ROM+100H-3
                                	ENDIF
                                	IRPC	X,<BCD>
                                	IF	X&SPACE		;;if segment active
                                	IF	CSPACE
                                	IF	TPAL LT ($-CLOC)
                                TPAL	DEFL	$-CLOC
                                	ENDIF
                                	ELSE
                                X&LOC	DEFL	$		;;save segment address
                                	ENDIF
                                X&SPACE	DEFL	0		;;clear segment active
                                	.DEPHASE		;;revert to relocatable
                                	ENDIF
                                	ENDM
                                	ENDM
  0000                          BLOC	DEFL	ROM		;establish non-resident code base
  F000                          DLOC	DEFL	MONITR		;establish resident code base
  0000                          TLOC	DEFL	0		;establise transient code base
  0000                          TPAL	DEFL	0		;establish maximum transient length
  0000                          BSPACE	DEFL	0		;preset common segment inactive
  0000                          CSPACE	DEFL	0		;preset code segment inactive
  0000                          DSPACE	DEFL	0		;preset data segment inactive
  0000                          COMRES	DEFL	0		;preset common base address
                                LDIRS	MACRO
                                	IF	LDIRSM
                                	CALL	SIMLDIR
                                	ELSE
                                	LDIR
                                	ENDIF
                                	ENDM
