  FC66    78                    VERF2:	LD	A,B
  FC67    B1                    	OR	C
  FC68    20 F4                 	JR	NZ,VERF1
  FC6A    C9                    	RET
                                	ELSE
                                VERCMD	EQU	WHAT
                                	ENDIF
                                	IF	OPTIONS AND O.PROT
                                ;
                                ;	Printer Protocol.
                                ;
                                	OVERLAY	PROTO
  03E9'                   +     	C&SEG
  FC55    3D                    	DEC	A
  FC56    28 10                 	JR	Z,PROT1		;if one parameter
  FC58    D6 02                 	SUB	2
  FC5A    37                    	SCF
  FC5B    C0                    	RET	NZ
  FC5C    7B                    	LD	A,E
  FC5D    F6 04                 	OR	4
  FC5F    32 F10C               	LD	(SIOMSK),A
  FC62    79                    	LD	A,C
  FC63    F6 04                 	OR	4
  FC65    32 F10E               	LD	(SIOVAL),A
  FC68    7D                    PROT1:	LD	A,L
  FC69    B7                    	OR	A
  FC6A    3E C9                 	LD	A,0C9H
  FC6C    28 01                 	JR	Z,PROT2
  FC6E    AF                    	XOR	A
  FC6F    32 F115               PROT2:	LD	(XONENB),A
  FC72    C9                    	RET
                                	ELSE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-61
TRANSIENT COMMAND PROCESSORS

                                PROTO	EQU	WHAT
                                	ENDIF
                                	IF	(OPTIONS AND O.TYPE) NE 0
                                ;
                                ;	TYPE - Simple Typewriter.
                                ;
                                	OVERLAY	TYPE
  0407'                   +     	C&SEG
  FC55    B7                    	OR	A
  FC56    28 06                 	JR	Z,TYP0		;if no baud rate
  FC58    3D                    	DEC	A
  FC59    37                    	SCF
  FC5A    C0                    	RET	NZ		;if more than one parameter
  FC5B    7D                    	LD	A,L
  FC5C    D3 0C                 	OUT	(BAUDB),A	;set printer baud rate
  FC5E    CD FC3D               TYP0:	CALL	PNEXT
  FC61    1A                    	DEFB	CLRS
                                	IF	(OPTIONS AND O.ESCT) NE 0
  FC62    1B 31                 	DEFB	ESC,'1'		;set 8 bit keyboard mode
                                	ELSE
                                	DEFB	'O'-'@'		;set 8 bit keyboard mode
                                	ENDIF
  FC64    54 79 70 65           	DEFM	'Typewriter mode.  Touch CTRL+ESC to exit.'
  FC68    77 72 69 74           
  FC6C    65 72 20 6D           
  FC70    6F 64 65 2E           
  FC74    20 20 54 6F           
  FC78    75 63 68 20           
  FC7C    43 54 52 4C           
  FC80    2B 45 53 43           
  FC84    20 74 6F 20           
  FC88    65 78 69 74           
  FC8C    2E                    
  FC8D    0D 0A 04              	DEFB	CR,LF,EOT
  FC90    CD F0E5               TYP1:	CALL	SIOST		;status printer
  FC93    28 0F                 	JR	Z,TYP2		;if char not ready
  FC95    CD F0F0               	CALL	SIOIN		;read character
  FC98    E6 7F                 	AND	7FH		;strip parity bit
  FC9A    CD F00C               	CALL	CONOUT
  FC9D    FE 0D                 	CP	CR
  FC9F    3E 0A                 	LD	A,LF
  FCA1    CC F00C               	CALL	Z,CONOUT
  FCA4    CD F006               TYP2:	CALL	CONST		;status console
  FCA7    28 E7                 	JR	Z,TYP1		;if user not active
  FCA9    CD F009               	CALL	CONIN		;read keyboard
  FCAC    CD F0F8               	CALL	SIOOUT		;send character to printer
  FCAF    CD F00C               	CALL	CONOUT		;and screen
  FCB2    FE 0D                 	CP	CR
  FCB4    20 DA                 	JR	NZ,TYP1		;if not CR
  FCB6    3E 0A                 	LD	A,LF		;send line feed to screen and printer
  FCB8    CD F0F8               	CALL	SIOOUT
  FCBB    CD F00C               	CALL	CONOUT
  FCBE    18 D0                 	JR	TYP1
                                	ELSE
                                TYPE	EQU	WHAT
                                	ENDIF
                                	IF	OPTIONS AND O.TERM
