  FEA1    F5                    	PUSH	AF		;save balcones gold
  FEA2    CD FEA7               	CALL	SIOPL
  FEA5    F1                    	POP	AF
  FEA6    C9                    	RET
                                ;
                                ;	SIOPL - SIO Poll Input Characters.
                                ;
  FEA7    C5                    SIOPL:	PUSH	BC
  FEA8    CD FE77               	CALL	SIOINS		;input SIO status
  FEAB    28 19                 	JR	Z,SIOPL3	;if input not ready
  FEAD    48                    	LD	C,B		;set data port address
  FEAE    ED 78                 	IN	A,(C)
  FEB0    CB BF                 	RES	7,A		;pitch parity bit
  FEB2    E5                    	PUSH	HL
  FEB3    2A FEEA               	LD	HL,(IPOINT)	;set in pointer
  FEB6    77                    	LD	(HL),A		;store character in FIFO
  FEB7    2C                    	INC	L
  FEB8    20 02                 	JR	NZ,SIOPL1
  FEBA    2E 00                 	LD	L,LOW SIOBUF
  FEBC    3A FEEC               SIOPL1:	LD	A,(OPOINT)
  FEBF    95                    	SUB	L
  FEC0    28 03                 	JR	Z,SIOPL2	;if buffer full
  FEC2    22 FEEA               	LD	(IPOINT),HL
  FEC5    E1                    SIOPL2:	POP	HL
  FEC6    C1                    SIOPL3:	POP	BC
  FEC7    C9                    	RET
                                ;
                                ;	SIOIST - SIO Input Status.
                                ;
  FEC8    CD FEA7               SIOIST:	CALL	SIOPL		;poll for input
  FECB    2A FEEC               	LD	HL,(OPOINT)	;set out pointer
  FECE    3A FEEA               	LD	A,(IPOINT)
  FED1    95                    	SUB	L
  FED2    C8                    	RET	Z		;if data not ready
  FED3    F6 FF                 	OR	-1
  FED5    C9                    	RET
                                ;
                                ;	SIOIN - SIO Input Character.
                                ;
  FED6    CD FEC8               SIOINC:	CALL	SIOIST		;set input ready status
  FED9    28 FB                 	JR	Z,SIOINC
  FEDB    7E                    	LD	A,(HL)
  FEDC    2C                    	INC	L		;advance out
  FEDD    20 02                 	JR	NZ,SIOI1
  FEDF    2E 00                 	LD	L,LOW SIOBUF
  FEE1    22 FEEC               SIOI1:	LD	(OPOINT),HL
  FEE4    C9                    	RET
  FEE5    00                    STATUS:	DB	0
  FEE6    0100                  BOTPTR:	DW	TRMBUF
  FEE8    0100                  TOPPTR:	DW	TRMBUF
  FEEA    EF00                  IPOINT:	DW	SIOBUF
  FEEC    EF00                  OPOINT:	DW	SIOBUF
                                	ELSE
                                TERM	EQU	WHAT
                                	ENDIF
                                	IF	OPTIONS AND O.HELP
                                ;
                                ;	Help Key Command.
                                ;
