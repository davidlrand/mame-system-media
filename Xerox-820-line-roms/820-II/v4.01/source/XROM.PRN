BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-71
SEGMENT SIZE INFORMATION

                                
                                ;
                                ;	Top of Overlay Area.
                                ;
                                	OVERLAY	STOP
  0771'                   +     	C&SEG
  0299                          TPAMAX	EQU	TPAL		;set length of transient move
                                ;
                                ;	Top of Resident Monitor.
                                ;
                                	BELOW
  0000!                   +     	DEFS	COMRES
  041B                          RBASE	EQU	$
                                ;
                                ;	Top of Non Resident Monitor.
                                ;
                                	ABOVE
  0518!                   +     	D&SEG
  FC55                          RESTOP	EQU	$		;resident top
  0C55                          RESLEN	EQU	$-MONITR	;length of resident monitor
                                	UPDATE			;clear active segment
                                ;
                                ;	Top of Burned Rom Set.
                                ;
  17E1                          ROMTOP	EQU	BLOC+DLOC+TLOC-MONITR
                                ;
                                ;	Fill Out Unused Rom Space.
                                ;
  0C55"                         	CSEG
                                	IF	(ROM+ROMSIZ-ROMTOP) GT 0
  0771'                         	DEFS	(ROM+ROMSIZ-ROMTOP),-1
                                	ENDIF
                                	SUBTTL	RESIDENT MONITOR SYSTEM RAM
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-72
RESIDENT MONITOR SYSTEM RAM

                                
                                	.PHASE	RAM
                                ;
                                ;	Start of Documented Storage Locations.
                                ;
  FF00                          VECTAB:				;interrupt vector table starts here
  FF00                          SIOVEC:	DEFS	16		;space for 8 vectors for SIO
  FF10                          CTCVEC:	DEFS	8		;space for 4 vectors for CTC
  FF18                          SYSVEC:	DEFS	4		;space for 2 vectors for system PIO
  FF1C                          GENVEC:	DEFS	4		;space for 2 vectors for general PIO
                                ;
                                ;	Keyboard data input FIFO variables
                                ;
  FF20                          FIFO:	DEFS	16		;console input fifo
  FF30                          FIFCNT:	DEFS	1		;fifo data counter
  FF31                          FIFIN:	DEFS	1		;fifi input pointer
  FF32                          FIFOUT:	DEFS	1		;fifo output pointer
  FF33                          	DEFS	1		;round address
                                ;
                                ;	More interrupt vectors
                                ;
  FF34                          EXPVEC:	DEFS	8		;space for 4 vectors for expansion slot
                                ;
                                ;	Available memory pointers.
                                ;
  FF3C                          AVAILB:	DEFS	2		;bottom of available memory
  FF3E                          AVAILT:	DEFS	2		;top of available memory
                                ;
                                ;
                                ;	End of documented storage locations.
  FF40                          	DEFS	16		;local stack for interrupts
  FF50                          INTSTK:
                                ;
                                ;	clock-timer interrupt variables
                                ;
  FF50                          MILSEC:	DEFS	2		;One Millisecond timer, Enable int on CTC1
  FF52                          TIKCNT:	DEFS	2		;16 bit seconds counter (18 hr, 12 min, 16 sec)
  FF54                          STEPRT:	DEFS	1		;WD 1797 step rate
  FF55                          TIMOUT:	DEFS	1		;time-out, decrements once per second
                                ;
                                ;	Getime entry returns the address of DAY
                                ;
  FF56                          DAY:	DEFS	1		;calendar day		(01-31)
  FF57                          MONTH:	DEFS	1		;	  month		(01-12)
  FF58                          YEAR:	DEFS	1		;	  year-1970	(1970-2225)
  FF59                          HRS:	DEFS	1		;clock hours		(00-23)
  FF5A                          MINS:	DEFS	1		;      minutes		(00-59)
  FF5B                          SECS:	DEFS	1		;      seconds		(00-59)
                                ;
                                ;	CRT output driver variables
                                ;
  FF5C                          LINBUF:	DEFS	80		;line buffer & Bcc gold mine
  FFAC                          CURSOR:	DEFS	2		;cursor pointer
  FFAE                          CSRCHR:	DEFS	1		;character used for a cursor
  FFAF                          DIRCUR:	DEFS	2		;cursor pointer for direct CRT display
  FFB1                          BASE:	DEFS	1		;current contents of scroll register
  FFB2                          LEADIN:	DEFS	1		;state of lead-in sequence handler
  FFB3                          ATTRIB:	DEFS	1		;attribute enable
  FFB4                          CHRSAV:	DEFS	1		;character under cusror
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-73
RESIDENT MONITOR SYSTEM RAM

                                ;
                                ;	Console monitor program variables
                                ;
  FFB5                          PARAM1:	DEFS	2		;storage for numbers read
  FFB7                          PARAM2:	DEFS	2		; from line input buffer
  FFB9                          PARAM3:	DEFS	2		; by 'PARAMS' subroutine
  FFBB                          PARAM4:	DEFS	2		; for command processors
  FFBD                          LAST:	DEFS	2		;last address used by 'MEMDMP'
                                ;
                                ;	Configurable parameter address table
                                ;
  FFBF                          CONTBL:	DEFS	2*NUMCON
  FFCB                          SPARE1:	DEFS	1		;spare configuration byte
  FFCC                          SPARE2:	DEFS	1		;another spare byte
  FFCD                          SPARE:	DEFS	(RAM+100H-48)-$	;spare RAM space
  FFD0                          SPARND:				;end of spare RAM
  FFD0                          	DEFS	16		;CRT stack
  FFE0                          CRTSTK:
  FFE0                          RSTSP:	DEFS	2		;SP register on reset
  FFE2                          RSTHL:	DEFS	2		;HL register on reset
  FFE4                          RSTPC:	DEFS	2		;possible PC from top of stack
  FFE6                          	DEFS	26		;monitor stack
  0000                          STACK:
                                	.DEPHASE
                                	SUBTTL	CONSOLE MESSAGES
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-74
CONSOLE MESSAGES

                                
                                ;
                                ;	Console Message Macros.
                                ;
                                MESSAGE	MACRO	TEXT,H1,H2
                                	IF1
                                	.RADIX	16
                                	PRINTX	<TEXT>,%(H1),%(H2-1),%((H2)-(H1))
                                	.RADIX	10
                                	ENDIF
                                	ENDM
                                PRINTX	MACRO	TEXT,H1,H2,H3
                                	.PRINTX + TEXT H1 - H2 = H3 +
                                	ENDM
                                	IF	ROMTOP GE (ROM+ROMSIZ)
                                	MESSAGE	<* THE ROM SET IS TFB *>,ROM+ROMSIZ,ROMTOP
                                	ENDIF
                                	IF	CLOC+TPAL GT RAM
                                	MESSAGE	<* THE TPA SET IS TFB *>,RAM,CLOC+TPAL
                                	ENDIF
                                	MESSAGE	<NON-RESIDENT EXECUTES >,ROM,BLOC
                                	MESSAGE	<ROM IS BURNED UP FROM >,ROM,ROMTOP
                                	MESSAGE	<UNUSED ROM SPACE FROM >,ROMTOP,ROM+ROMSIZ-1
                                	MESSAGE	<RESIDENT MONITOR NEEDS>,MONITR,RQTOP
                                	MESSAGE	<SPACE WASTED TO DRIVER>,WASTED,SELTAB
                                	MESSAGE <PHYSICAL DISK DRIVERS >,SELTAB,DVRLMT
                                	MESSAGE <DRIVER OFFSET FOR ZSID>,200H+BLOC+SELTAB-MONITR,0
                                	MESSAGE	<I/O BYTE DRIVERS FROM >,IOBLOC,IOBLOC+IOBDVS
                                	MESSAGE	<COMMAND PROCESSOR AREA>,RQTOP,RESTOP
                                	MESSAGE	<TRANSIENT OVERLAY ROM >,START,STOP
                                	MESSAGE	<TRANSIENT COMMAND AREA>,CLOC,CLOC+TPAL
                                	MESSAGE	<SPARE LOCATIONS IN RAM>,SPARE,SPARND
                                	SUBTTL	THE*END
                                	END	ENTRY
