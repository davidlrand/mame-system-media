BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-15
RESIDENT MONITOR ENTRY POINTS

                                
                                ;
                                ;	Resident monitor entry points.
                                ;
                                ;	This Entry Point Vector provides the only reliable access
                                ;	to services provided by the Resident Monitor.  Any access
                                ;	to code in the Monitor or its RAM page past the keyboard
                                ;	variables is not allowed.  Future releases of the Resident
                                ;	Monitor will always provide compatability with these entry
                                ;	vectors.
                                ;
                                ;	This restriction also applies to the Resident Monitor RAM
                                ;	Page at the top of memory.  Access to RAM Variables must
                                ;	be obtained through the appropriate entry vector.
                                ;
                                	ABOVE
  0266!                   +     	D&SEG
  F000    C3 F07C               COLD:	JP	RESTART		;monitor restart
  F003    C3 FA62               WARM:	JP	PROMPT		;monitor entry point
  F006    C3 F0CD               CONST:	JP	KBDST		;console status to A
  F009    C3 F0D8               CONIN:	JP	KBDIN		;console input to A
  F00C    C3 F2F1               CONOUT:	JP	CRTOUT		;console output from A
  F00F    C3 F2FE               	JP	FASTCRT		;fast CRT output from C
  F012    C3 F0E5               	JP	SIOST		;SIO channel B status to A
  F015    C3 F0F0               	JP	SIOIN		;SIO channel B input to A
  F018    C3 F0F8               	JP	SIOOUT		;SIO channel B output from A
  F01B    C3 FA17               	JP	SELECT		;select drive in C
  F01E    C3 FA3C               	JP	HOME		;home R/W head
  F021    C3 FA3E               	JP	SEEK		;seek to track in C
  F024    C3 FA48               	JP	READ		;read sector C -> buffer @ HL
  F027    C3 FA44               	JP	WRITE		;write sector C <- buffer @ HL
  F02A    C3 F344               	JP	XQDVR		;execute physical driver request @ HL 
  F02D    C3 F284               	JP	SETCUR		;set direct CRT cursor from HL
  F030    C3 F288               	JP	OUTCUR		;direct CRT display
  F033    C3 F2A3               	JP	CRTLDIR		;CRT memory block move ala` LDIR
  F036    C3 F097               	JP	GETSEL		;return address of disk mapping table to HL
  F039    C3 F086               	JP	DAYTIM		;return address of Time-of-Day
  F03C    C3 F08B               	JP	CONFIG		;return configuration status
  F03F    C3 F105               	JP	SIORDY		;SIO channel B output ready status
  F042    C3 F0A4               	JP	SETCON		;set configuration
  F045    C3 F0BF               	JP	SSP		;start screen print
  F048    C3 F13F               USRSEC:	JP	NULINT		;user accessible 1 second interrupt
  F04B    C3 F7A3               	JP	IOCONS		;console status through iobyte
  F04E    C3 F7AF               	JP	IOCONI		;console input through iobyte
  F051    C3 F796               	JP	IOCONO		;console output through iobyte
  F054    C3 F7BB               	JP	IOLIST		;printer output through iobyte
  F057    C3 F7CC               	JP	IOLSTS		;printer status through iobyte
  F05A    C3 F770               	JP	COMINS		;communications input ready status
  F05D    C3 F775               	JP	COMINP		;communications input data to A
  F060    C3 F77F               	JP	COMOUT		;communications output data from C
  F063    C3 F788               	JP	COMOTS		;communications output ready status
  F066    C3 F13F               IDLE:	JP	NULINT		;idle while I/O is pending
  F069    C3 F0D2               	JP	SOFT		;record soft error
  F06C                          	DEFS	16,-1		;space for option ROM linkage
                                	SUBTTL	MONITOR FUNCTION PROCESSORS
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-16
MONITOR FUNCTION PROCESSORS

                                
                                ;
                                ;	Monitor Restart.
                                ;
  F07C    F3                    RESTART:DI			;lock system
  F07D    DB 1C                 	IN	A,(SYSPIO)
  F07F    F6 80                 	OR	1 SHL 7		;enable banked ROM
  F081    D3 1C                 	OUT	(SYSPIO),A
  F083    C3 0000               	JP	PRS		;reload monitor from ROM or RAM
                                ;
                                ;	DAYTIM - Return Address of Time-of-Day.
                                ;
  F086    11 FF56               DAYTIM:	LD	DE,DAY		;point to day of month
  F089    18 0F                 	JR	RETVAL
                                ;
                                ;	CONFIG - Return Configuration Status Byte.
                                ;
  F08B    3A F0E3               CONFIG:	LD	A,(MASK)	;turn keyboard mask into C.KEYM
  F08E    E6 80                 	AND	080H
  F090    F6 00                 	OR	0
  F091                          CONFG	EQU	$-1	;*****=>;This word stored by Preset
  F092    5F                    	LD	E,A
  F093    16 01                 	LD	D,REV-400	;return revision level
  F095    18 03                 	JR	RETVAL
                                ;
                                ;	GETSEL - Get address of Select table.
                                ;
  F097    11 F360               GETSEL:	LD	DE,SELTAB	;set select table address
                                ;
                                ;	RETVAL - Return Value to Caller.
                                ;
  F09A    24                    RETVAL:	INC	H		;see if high level language call
  F09B    25                    	DEC	H
  F09C    28 03                 	JR	Z,RETV1		;if assembly level call
  F09E    73                    	LD	(HL),E		;store answer in variable
  F09F    23                    	INC	HL
  F0A0    72                    	LD	(HL),D
  F0A1    EB                    RETV1:	EX	DE,HL		;leave result in HL as well
  F0A2    FB                    EIRET:	EI
  F0A3    C9                    	RET
                                ;
                                ;	SETCON - Set Configuration.
                                ;
  F0A4    7E                    SETCON:	LD	A,(HL)		;get configuration table index
  F0A5    CB BF                 	RES	7,A
  F0A7    FE 06                 	CP	NUMCON
  F0A9    D0                    	RET	NC		;if index out of range
  F0AA    5F                    	LD	E,A
  F0AB    7E                    	LD	A,(HL)		;get read/write flag
  F0AC    23                    	INC	HL
  F0AD    46                    	LD	B,(HL)		;get configuration data
  F0AE    16 00                 	LD	D,0
  F0B0    21 FFBF               	LD	HL,CONTBL	;set address of configuration table addresses
  F0B3    19                    	ADD	HL,DE
  F0B4    19                    	ADD	HL,DE
  F0B5    5E                    	LD	E,(HL)		;get configurable byte address
  F0B6    23                    	INC	HL
  F0B7    56                    	LD	D,(HL)
  F0B8    EB                    	EX	DE,HL
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-17
MONITOR FUNCTION PROCESSORS

  F0B9    CB 7F                 	BIT	7,A		;set direction
  F0BB    7E                    	LD	A,(HL)		;get previous value
  F0BC    C8                    	RET	Z		;if asking current configuration
  F0BD    70                    	LD	(HL),B		;store new configuration
  F0BE    C9                    	RET
                                ;
                                ;	SSP - Start Screen Print.
                                ;
  F0BF    3E 67                 SSP:	LD	A,3+((24+1) SHL 2)	;start with CR/LF
  F0C1    32 F20E               	LD	(SPACT),A
  F0C4    AF                    	XOR	A
  F0C5    32 F224               	LD	(SPCNT),A
  F0C8    3E 81                 	LD	A,81H		;start millisecond timer
  F0CA    D3 19                 	OUT	(CTC1),A
  F0CC    C9                    	RET
                                	SUBTTL	CONSOLE / PRINTER DRIVERS
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-18
CONSOLE / PRINTER DRIVERS

                                
                                	ABOVE			;run this code upstairs
  00CD"                   +     	D&SEG
                                ;
                                ;	KBDST - Keyboard Status.
                                ;
                                ;	Returns A =  0 if no character
                                ;		A = -1 if character available
                                ;
  F0CD    3A FF30               KBDST:	LD	A,(FIFCNT)	;get input FIFO bytecount
  F0D0    B7                    	OR	A
  F0D1    C8                    	RET	Z		;if keyboard queue is empty
                                ;
                                ;	SOFT - Record soft error.
                                ;
  F0D2    F6 FF                 SOFT:	OR	-1		;set ready / error status
  F0D4    C9                    	RET
                                ;
                                ;	KBDIN - Keyboard Input.
                                ;
                                ;	Returns A = character
                                ;
  F0D5    CD F066               KBDIN1:	CALL	IDLE		;idle CPU
  F0D8    CD F0CD               KBDIN:	CALL	KBDST
  F0DB    28 F8                 	JR	Z,KBDIN1	;loop until keyboard input ready
  F0DD    E5                    	PUSH	HL
  F0DE    CD F130               	CALL	REMOVE		;get keyboard entry
  F0E1    E1                    	POP	HL
  F0E2    E6 7F                 KBMASK:	AND	07FH
  F0E3                          MASK	EQU	$-1	;*****=>;this byte modified by ESC 0/1
  F0E4    C9                    	RET
                                ;
                                ;	SIOST - SIO channel B input ready status.
                                ;
  F0E5    DB 07                 SIOST:	IN	A,(SIOCPB)	;get SIO status register
  F0E7    E6 01                 	AND	00000001B
  F0E9    C8                    	RET	Z		;if no data available
  F0EA    3E FF                 	LD	A,-1
  F0EC    C9                    	RET
                                ;
                                ;	SIOIN - SIO channel B input character.
                                ;
  F0ED    CD F066               SIOIN1:	CALL	IDLE		;idle CPU
  F0F0    CD F0E5               SIOIN:	CALL	SIOST		;test console status
  F0F3    28 F8                 	JR	Z,SIOIN1	;loop until data is
  F0F5    DB 05                 	IN	A,(SIODPB)	;ready at SIO data port
  F0F7    C9                    	RET
                                ;
                                ;	SIOOUT - SIO channel B output character.
                                ;
  F0F8    F5                    SIOOUT:	PUSH	AF
  F0F9    CD F105               SIOX1:	CALL	SIORDY
  F0FC    CC F066               	CALL	Z,IDLE		;idle CPU if transmitter not ready
  F0FF    28 F8                 	JR	Z,SIOX1
  F101    F1                    	POP	AF
  F102    D3 05                 	OUT	(SIODPB),A	;output data to SIO
  F104    C9                    	RET
                                ;
                                ;	SIORDY - SIO channel B output ready ststus.
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-19
CONSOLE / PRINTER DRIVERS

                                ;
  F105    3E 10                 SIORDY:	LD	A,10H		;reset status latch
  F107    D3 07                 	OUT	(SIOCPB),A
  F109    DB 07                 	IN	A,(SIOCPB)
  F10B    E6 04                 	AND	00000100B	;test TBE status bit
  F10C                          SIOMSK	EQU	$-1	;*****=>;modified at run time
  F10D    EE 04                 	XOR	00000100B
  F10E                          SIOVAL	EQU	$-1	;*****=>;modified at run time
  F10F    28 02                 	JR	Z,SIORD1	;if hardware is ready
  F111    AF                    	XOR	A
  F112    C9                    	RET
  F113    F6 FF                 SIORD1:	OR	-1		;set ready status
  F115    00                    XONENB:	NOP		;*****=>;put RET here to disable Xon/Xoff
  F116    CD F0E5               	CALL	SIOST
  F119    28 11                 	JR	Z,SIORD3	;if input not available
  F11B    CD F0F0               	CALL	SIOIN
  F11E    E6 7F                 	AND	7FH
  F120    D6 13                 	SUB	XOFF
  F122    28 05                 	JR	Z,SIORD2	;if printer said Stop
  F124    D6 FE                 	SUB	XON-XOFF
  F126    20 04                 	JR	NZ,SIORD3	;if not Resume
  F128    2F                    	CPL			;set printer ready
  F129    32 F12D               SIORD2:	LD	(XOFFLG),A
  F12C    3E FF                 SIORD3:	LD	A,-1
  F12D                          XOFFLG	EQU	$-1	;*****=>;set ^S pending flag
  F12E    B7                    	OR	A
  F12F    C9                    	RET
                                ;
                                ;	REMOVE - Remove key from FIFO.
                                ;
  F130    21 FF30               REMOVE:	LD	HL,FIFCNT	;decrement FIFO count
  F133    35                    	DEC	(HL)
  F134    21 FF32               	LD	HL,FIFOUT	;point HL to FIFO output offset
  F137    34                    INDEX:	INC	(HL)		;advance FIFO pointer
  F138    CB A6                 	RES	4,(HL)		;modulo 16
  F13A    3E 20                 	LD	A,LOW FIFO
  F13C    86                    	ADD	A,(HL)		;index into FIFO by offset
  F13D    6F                    	LD	L,A
  F13E    7E                    	LD	A,(HL)		;fetch character in FIFO
  F13F    C9                    NULINT:	RET
                                	SUBTTL	INTERRUPT SERVICE ROUTINES
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-20
INTERRUPT SERVICE ROUTINES

                                
                                ;
                                ;	ISR - Interrupt Service Routines.
                                ;
                                SERVICE	MACRO
                                	LD	(SAVSTK),SP	;save user stack pointer and
                                	LD	SP,INTSTK	;switch to local stack
                                	PUSH	HL		;save machine state
                                	PUSH	AF
                                	ENDM
                                ;
                                ;	KEYSRV - Parallel Keyboard Interrupt Service.
                                ;
  F140                          KEYSRV: SERVICE			;save state
  F140    ED 73 F1EC      +     	LD	(SAVSTK),SP	;save user stack pointer and
  F144    31 FF50         +     	LD	SP,INTSTK	;switch to local stack
  F147    E5              +     	PUSH	HL		;save machine state
  F148    F5              +     	PUSH	AF
  F149    C5                    	PUSH	BC
  F14A    DB 1E                 	IN	A,(KBDDAT)	;read keyboard input port
  F14C    2F                    	CPL
  F14D    FE 9E                 	CP	SCRPRT
  F14F    20 16                 	JR	NZ,KEY2		;if not screen print key
  F151    3A F20E               	LD	A,(SPACT)
  F154    B7                    	OR	A
  F155    28 0B                 	JR	Z,KEY1		;if screen not printing now
  F157    3E 07                 	LD	A,3+(1 SHL 2)	;set state to CR/LF/stop
  F159    32 F20E               	LD	(SPACT),A	;set screen print state
  F15C    AF                    	XOR	A
  F15D    32 F224               	LD	(SPCNT),A	;restart character counter
  F160    18 2D                 	JR	KEY5
  F162    CD F0BF               KEY1:	CALL	SSP		;start screen print
  F165    18 28                 	JR	KEY5
  F167    21 FF30               KEY2:	LD	HL,FIFCNT	;bump input FIFO character count
  F16A    FE 9B                 	CP	ABORT		;check user Abort Key
  F16C    28 11                 	JR	Z,KEY3		;warm start system
  F16E    4F                    	LD	C,A
  F16F    7E                    	LD	A,(HL)
  F170    3C                    	INC	A
  F171    FE 10                 	CP	16
  F173    30 1A                 	JR	NC,KEY5		;exit now if FIFO is full
  F175    77                    	LD	(HL),A
  F176    21 FF31               	LD	HL,FIFIN	;point HL to FIFO input offset
  F179    CD F137               	CALL	INDEX
  F17C    71                    	LD	(HL),C		;store character in FIFO @ HL
  F17D    18 10                 	JR	KEY5
  F17F    CD F1EF               KEY3:	CALL	RETINS		;release PIO interrupt controller
  F182    06 03                 	LD	B,3
  F184    36 00                 KEY4:	LD	(HL),0		;clear FIFO count
  F186    2C                    	INC	L		;and FIFO in/out pointers
  F187    10 FB                 	DJNZ	KEY4
  F189    CD F293               	CALL	CRTOFF		;turn CRT memory off
  F18C    CD F003               	CALL	WARM		;and warm start system
  F18F    C1                    KEY5:	POP	BC
  F190    18 57                 	JR	RFI		;return from interrupt
                                ;
                                ;	TIMER - Once per second interrupt.
                                ;
  F192                          TIMER:	SERVICE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-21
INTERRUPT SERVICE ROUTINES

  F192    ED 73 F1EC      +     	LD	(SAVSTK),SP	;save user stack pointer and
  F196    31 FF50         +     	LD	SP,INTSTK	;switch to local stack
  F199    E5              +     	PUSH	HL		;save machine state
  F19A    F5              +     	PUSH	AF
  F19B    2A FF52               	LD	HL,(TIKCNT)	;advance binary seconds counter
  F19E    23                    	INC	HL
  F19F    22 FF52               	LD	(TIKCNT),HL
  F1A2    CD F048               	CALL	USRSEC		;invoke user's interrupt routine
  F1A5    21 FF55               	LD	HL,TIMOUT	;decrement disk turn-off timer
  F1A8    35                    	DEC	(HL)
  F1A9    20 06                 	JR	NZ,TIMER1	;exit if not timed out yet
  F1AB    DB 1C                 	IN	A,(SYSPIO)
  F1AD    E6 F8                 	AND	11111000B	;disable all drive selects which
  F1AF    D3 1C                 	OUT	(SYSPIO),A	;turns off spindle motors
  F1B1    C5                    TIMER1:	PUSH	BC
  F1B2    06 02                 	LD	B,2
  F1B4    3E 3B                 	LD	A,59
  F1B6    21 FF5B               	LD	HL,SECS		;point at wall clock
  F1B9    34                    TIMER2:	INC	(HL)		;increment seconds
  F1BA    BE                    	CP	(HL)
  F1BB    30 2B                 	JR	NC,TIMER3	;if not one minute or hour
  F1BD    36 00                 	LD	(HL),0
  F1BF    2B                    	DEC	HL
  F1C0    10 F7                 	DJNZ	TIMER2
  F1C2    3E 17                 	LD	A,23
  F1C4    34                    	INC	(HL)		;increment hours
  F1C5    BE                    	CP	(HL)
  F1C6    30 20                 	JR	NC,TIMER3	;if not one day
  F1C8    36 00                 	LD	(HL),0
  F1CA    D5                    	PUSH	DE
  F1CB    2B                    	DEC	HL
  F1CC    2B                    	DEC	HL
  F1CD    4E                    	LD	C,(HL)		;get month
  F1CE    2B                    	DEC	HL		;point to day
  F1CF    11 F1F0               	LD	DE,DPM-1	;point to day/month table
  F1D2    EB                    	EX	DE,HL
  F1D3    09                    	ADD	HL,BC
  F1D4    7E                    	LD	A,(HL)		;get number of days
  F1D5    EB                    	EX	DE,HL
  F1D6    D1                    	POP	DE
  F1D7    34                    	INC	(HL)		;increment day
  F1D8    BE                    	CP	(HL)
  F1D9    30 0D                 	JR	NC,TIMER3	;if not end of month
  F1DB    36 01                 	LD	(HL),1		;reset day in month
  F1DD    23                    	INC	HL
  F1DE    34                    	INC	(HL)		;increment month
  F1DF    3E 0B                 	LD	A,11
  F1E1    BE                    	CP	(HL)
  F1E2    30 04                 	JR	NC,TIMER3	;if not New Year's Eve
  F1E4    36 01                 	LD	(HL),1		;wrap December to January
  F1E6    23                    	INC	HL
  F1E7    34                    	INC	(HL)		;signal Guy Lombardo
  F1E8    C1                    TIMER3:	POP	BC
                                ;
                                ;	RFI - Return From Interrupt.
                                ;
  F1E9    F1                    RFI:	POP	AF
  F1EA    E1                    	POP	HL
  F1EB    31 0000               	LD	SP,0		;restore stack
  F1EC                          SAVSTK	EQU	$-2	;*****=>;this word modified at runtime
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-22
INTERRUPT SERVICE ROUTINES

  F1EE    FB                    	EI			;re-enable interrupts and return
  F1EF    ED 4D                 RETINS:	RETI
                                ;
                                ;	Table of Days Per Month.
                                ;
  F1F1    1F                    DPM:	DB	31		;January
  F1F2    1C                    	DB	28		;Febuary
  F1F3    1F                    	DB	31		;March
  F1F4    1E                    	DB	30		;April
  F1F5    1F                    	DB	31		;May
  F1F6    1E                    	DB	30		;June
  F1F7    1F                    	DB	31		;July
  F1F8    1F                    	DB	31		;August
  F1F9    1E                    	DB	30		;September
  F1FA    1F                    	DB	31		;October
  F1FB    1E                    	DB	30		;November
  F1FC    1F                    	DB	31		;December
                                ;
                                ;	MILLI - Millisecond timer interrupt service.
                                ;
  F1FD                          MILLI:	SERVICE
  F1FD    ED 73 F1EC      +     	LD	(SAVSTK),SP	;save user stack pointer and
  F201    31 FF50         +     	LD	SP,INTSTK	;switch to local stack
  F204    E5              +     	PUSH	HL		;save machine state
  F205    F5              +     	PUSH	AF
  F206    2A FF50               	LD	HL,(MILSEC)
  F209    23                    	INC	HL		;increment millisecond counter
  F20A    22 FF50               	LD	(MILSEC),HL
  F20D    3E 00                 	LD	A,0		;set screen print flag
  F20E                          SPACT	EQU	$-1	;*****=>;this byte modified at runtime
  F20F    67                    	LD	H,A
  F210    E6 03                 	AND	3
  F212    28 6D                 	JR	Z,MILL6		;if not printing screen
  F214    6F                    	LD	L,A
  F215    CD F105               	CALL	SIORDY		;get printer status
  F218    28 67                 	JR	Z,MILL6		;if printer not ready
  F21A    2D                    	DEC	L
  F21B    20 48                 	JR	NZ,MILL2	;if not character print state
  F21D    DB 1C                 	IN	A,(SYSPIO)	;get PIO state
  F21F    F5                    	PUSH	AF
  F220    CD F29C               	CALL	CRTON
  F223    3E 00                 	LD	A,0		;get character count
  F224                          SPCNT	EQU	$-1	;*****=>;byte modified at runtime
  F225    3D                    	DEC	A
  F226    FA F236               	JP	M,MIL0		;if end of line
  F229    32 F224               	LD	(SPCNT),A
  F22C    21 0000               	LD	HL,0		;set next character address
  F22D                          SPADDR	EQU	$-2	;*****=>;word modified at runtime
  F22F    7E                    	LD	A,(HL)
  F230    D3 05                 	OUT	(SIODPB),A	;fire hammer
  F232    2C                    	INC	L		;advance screen cursor
  F233    AF                    	XOR	A		;do not advance state
  F234    18 22                 	JR	MILL1		;if not end of line
  F236    3E 61                 MIL0:	LD	A,1+(24 SHL 2)	;set address of next print line
  F238    94                    	SUB	H
  F239    1F                    	RRA
  F23A    CB 2F                 	SRA	A
  F23C    CD F31E               	CALL	CCA		;compute cursor address
  F23F    E5                    	PUSH	HL		;save next line address
  F240    C5                    	PUSH	BC
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-23
INTERRUPT SERVICE ROUTINES

  F241    06 50                 	LD	B,80		;delete trailing blanks
  F243    7D                    	LD	A,L
  F244    80                    	ADD	A,B
  F245    6F                    	LD	L,A
  F246    2D                    MIL01:	DEC	L
  F247    7E                    	LD	A,(HL)		;get next character
  F248    E6 7F                 	AND	7FH
  F24A    FE 20                 	CP	' '
  F24C    20 02                 	JR	NZ,MIL02	;if not trailing blank
  F24E    10 F6                 	DJNZ	MIL01
  F250    78                    MIL02:	LD	A,B
  F251    32 F224               	LD	(SPCNT),A	;set number of characters to print
  F254    C1                    	POP	BC
  F255    E1                    	POP	HL
  F256    3E 03                 	LD	A,3		;set CR next state
  F258    22 F22D               MILL1:	LD	(SPADDR),HL	;set next display address
  F25B    21 F20E               	LD	HL,SPACT	;set state variable
  F25E    B6                    	OR	(HL)		;advance state
  F25F    77                    	LD	(HL),A
  F260    F1                    	POP	AF		;get PIO back
  F261    D3 1C                 	OUT	(SYSPIO),A
  F263    18 1C                 	JR	MILL6
  F265    2D                    MILL2:	DEC	L		;check next state
  F266    21 F20E               	LD	HL,SPACT	;set state address
  F269    20 11                 	JR	NZ,MILL4	;if not LF state
  F26B    7E                    	LD	A,(HL)
  F26C    D6 04                 	SUB	1 SHL 2		;advance line counter
  F26E    77                    	LD	(HL),A
  F26F    FE FE                 	CP	2-(1 SHL 2)
  F271    20 05                 	JR	NZ,MILL3
  F273    3E 01                 	LD	A,1		;disable CTC interrupt
  F275    D3 19                 	OUT	(CTC1),A
  F277    77                    	LD	(HL),A
  F278    3E 0A                 MILL3:	LD	A,LF		;set line feed
  F27A    18 02                 	JR	MILL5
  F27C    3E 0D                 MILL4:	LD	A,CR		;set carriage return
  F27E    D3 05                 MILL5:	OUT	(SIODPB),A	;move paper or carriage
  F280    35                    	DEC	(HL)
  F281    C3 F1E9               MILL6:	JP	RFI		;return from interrupt
                                	
                                	SUBTTL	CRT DRIVER
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-24
CRT DRIVER

                                
                                ;
                                ;	SETCUR - Set direct display cursor position.
                                ;
  F284    22 FFAF               SETCUR:	LD	(DIRCUR),HL	;set up cursor address
  F287    C9                    	RET
                                ;
                                ;	OUTCUR - Store character directly to CRT memory.
                                ;
  F288    CD F29C               OUTCUR:	CALL	CRTON		;turn on CRT bank
  F28B    2A FFAF               	LD	HL,(DIRCUR)	;fetch direct cursor
  F28E    71                    	LD	(HL),C		;store character
  F28F    23                    	INC	HL
  F290    22 FFAF               	LD	(DIRCUR),HL
                                ;
                                ;	CRTOFF - Turn CRT RAM off.
                                ;
  F293    F3                    CRTOFF:	DI			;lock PIO access
  F294    DB 1C                 	IN	A,(SYSPIO)
  F296    CB BF                 CRTOF1:	RES	7,A		;reset CRT bank enable
  F298    FB                    	EI			;unlock PIO access
  F299    D3 1C                 CRTON1:	OUT	(SYSPIO),A
  F29B    C9                    	RET
                                ;
                                ;	CRTON - Turn CRT RAM on.
                                ;
  F29C    F3                    CRTON:	DI			;lock time-out interrupt
  F29D    DB 1C                 	IN	A,(SYSPIO)	;get PIO status
  F29F    CB FF                 	SET	7,A		;enable bank
  F2A1    18 F6                 	JR	CRTON1
                                ;
                                ;	CRTLDIR - Block move from/to CRT memory.
                                ;
                                ;	Entry:	HL = Source address
                                ;		DE = Destination address
                                ;		BC = Number of bytes to move
                                ;		A  = 0 - Move CRT RAM to CRT RAM
                                ;		A  < 0 - Move sys RAM to CRT RAM 
                                ;		A  > 0 - Move CRT RAM to sys RAM
                                ;
  F2A3    ED 73 F31B            CRTLDIR:LD	(USRSTK),SP	;do not use callers stack
  F2A7    31 FFE0               	LD	SP,CRTSTK	;since it may disappear
  F2AA    A7                    	AND	A		;set entry conditions
  F2AB    CD F29C               	CALL	CRTON
  F2AE    28 37                 	JR	Z,CRTMV		;block move within CRT RAM
  F2B0    F2 F2B5               	JP	P,LDIR2		;if move from CRT RAM to system RAM
  F2B3    EE 80                 LDIR1:	XOR	80H
  F2B5    D3 1C                 LDIR2:	OUT	(SYSPIO),A	;enable source bank
  F2B7    E5                    	PUSH	HL		;save move source address
  F2B8    21 FFB0               	LD	HL,-80		;count down one transfer buffer
  F2BB    ED 4A                 	ADC	HL,BC
  F2BD    E3                    	EX	(SP),HL		;save overflow, retrieve source address
  F2BE    FA F2C4               	JP	M,LDIR3		;if less than one buffer
  F2C1    01 0050               	LD	BC,80		;transfer one buffer
  F2C4    C5                    LDIR3:	PUSH	BC		;save byte count
  F2C5    D5                    	PUSH	DE		;save destination address
  F2C6    11 FF5C               	LD	DE,LINBUF	;set upper buffer
  F2C9    ED B0                 	LDIR			;move data to upper RAM
  F2CB    D1                    	POP	DE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-25
CRT DRIVER

  F2CC    C1                    	POP	BC
  F2CD    DB 1C                 	IN	A,(SYSPIO)	;enable destination bank
  F2CF    EE 80                 	XOR	80H
  F2D1    D3 1C                 	OUT	(SYSPIO),A
  F2D3    E5                    	PUSH	HL		;save source address
  F2D4    21 FF5C               	LD	HL,LINBUF	;set upper  buffer
  F2D7    ED B0                 	LDIR			;move data from buffer to destination
  F2D9    E1                    	POP	HL
  F2DA    C1                    	POP	BC		;retrieve bytes left to transfer
  F2DB    78                    	LD	A,B
  F2DC    A7                    	AND	A
  F2DD    FA F2E9               	JP	M,CRTMVO	;no more move, turn CRT RAM off and return
  F2E0    B1                    	OR	C
  F2E1    28 06                 	JR	Z,CRTMVO	;if no more
  F2E3    DB 1C                 	IN	A,(SYSPIO)
  F2E5    18 CC                 	JR	LDIR1		;continue transfer one buffer at a crack
  F2E7                          CRTMV:	LDIRS
  F2E7    ED B0           +     	LDIR
  F2E9    CD F293               CRTMVO:	CALL	CRTOFF		;turn CRT RAM off
  F2EC    ED 7B F31B            	LD	SP,(USRSTK)
  F2F0    C9                    	RET
                                	IF	LDIRSM
                                ;
                                ;	SIMLDIR - Simulate LDIR for broken hardware.
                                ;
                                SIMLDIR:LD	A,(HL)		;move one byte
                                	LD	(DE),A
                                	INC	HL		;advance addresses
                                	INC	DE
                                	DEC	BC		;decrement byte count
                                	LD	A,B
                                	OR	C
                                	JR	NZ,SIMLDIR	;if move incomplete
                                	RET
                                	ENDIF
                                	SUBTTL	RESIDENT CRT DRIVER.
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-26
RESIDENT CRT DRIVER.

                                
                                ;
                                ;	CRTOUT - CRT Output Driver.
                                ;
                                ;	Entry:	Character in register A
                                ;		16 bytes of stack space available
                                ;	Exit:	Character displayed, all registers saved
                                ;
  F2F1    E5                    CRTOUT:	PUSH	HL		;maintain users registers on his stack
  F2F2    D5                    	PUSH	DE
  F2F3    C5                    	PUSH	BC
  F2F4    F5                    	PUSH	AF
  F2F5    4F                    	LD	C,A		;set character to process
  F2F6    CD F2FE               	CALL	FASTCRT		;process character quickly
  F2F9    F1                    	POP	AF		;restore callers registers
  F2FA    C1                    	POP	BC
  F2FB    D1                    	POP	DE
  F2FC    E1                    	POP	HL
  F2FD    C9                    	RET
                                ;
                                ;	FASTCRT - Fast CRT driver.
                                ;
                                ;	Entry:	Character in C
                                ;	Exit:	The only register preserved is SP
                                ;		Peeking in register A reveals valuable characters.
                                ;
  F2FE    ED 73 F31B            FASTCRT:LD	(USRSTK),SP	;do not use callers stack
  F302    31 FFE0               	LD	SP,CRTSTK	;since it may disappear
  F305    DD E5                 	PUSH	IX		;since PLINK ignores register usage rules
  F307    DB 1C                 	IN	A,(SYSPIO)	;read system PIO
  F309    B7                    	OR	A		;set bank enable status
  F30A    F5                    	PUSH	AF		;save status for exit code
  F30B    CD F29C               	CALL	CRTON		;turn on CRT memory
  F30E    FB                    	EI			;enable interrupts
  F30F    CD 0169               	CALL	CRTDVR		;execute CRT driver ROM
  F312    F1                    	POP	AF		;get previous bank enable status
  F313    F4 F293               	CALL	P,CRTOFF	;disable bank now if it was disabled on entry
  F316    DD E1                 	POP	IX
  F318    3E 00                 	LD	A,0		;sneak balcones golden characters to FAST users
  F319                          GOLD	EQU	$-1
  F31A    31 F31B               	LD	SP,USRSTK	;restore callers stack
  F31B                          USRSTK	EQU	$-2	;*****=>;this operand word is modified at runtime
  F31D    C9                    	RET
                                ;
                                ;	CCA - Compute Cursor Address.
                                ;
                                ;	Entry:	A = Row
                                ;
  F31E    67                    CCA:	LD	H,A
  F31F    3A FFB1               	LD	A,(BASE)
  F322    84                    	ADD	A,H
  F323    3C                    CCA1:	INC	A		;entry with base absolute
  F324    D6 18                 CCA2:	SUB	24		;ditto
  F326    30 FC                 	JR	NC,CCA2
  F328    C6 78                 	ADD	A,24+2*CRTBAS
  F32A    67                    	LD	H,A
  F32B    2E 00                 	LD	L,0
  F32D    CB 2C                 	SRA	H
  F32F    CB 1D                 	RR	L
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-27
RESIDENT CRT DRIVER.

  F331    C9                    	RET
                                ;
                                ;	RSTATT - Restore Previous Attribute.
                                ;
  F332    01 0000               RSTATT:	LD	BC,0		;execute previous attribute routine
  F333                          LSTATT	EQU	$-2
  F335    C5                    	PUSH	BC
  F336    C9                    	RET
  F337    E5                    SETPRV:	PUSH	HL
  F338    21 01CF               	LD	HL,SETLOW
  F339                          PRVATT	EQU	$-2
  F33B    22 F333               	LD	(LSTATT),HL
  F33E    ED 43 F339            	LD	(PRVATT),BC
  F342    E1                    	POP	HL
  F343    C9                    	RET
                                	SUBTTL	ROM-RESIDENT CRT DRIVER
                                	PAGE
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-28
ROM-RESIDENT CRT DRIVER

                                
                                	BELOW			;execute in banked ROM
  0000!                   +     	DEFS	COMRES
                                ;
                                ;	CRTDVR - Crt Driver Proper.
                                ;
  0169    2A FFAC               CRTDVR:	LD	HL,(CURSOR)	;set cursor address
  016C    3A FFB4               	LD	A,(CHRSAV)	;retrieve character under cursor
  016F    77                    	LD	(HL),A		;replace character under cursor
  0170    32 F319               	LD	(GOLD),A	;bury balcones gold
  0173    3A FFB2               	LD	A,(LEADIN)	;set leadin state
  0176    B7                    	OR	A
  0177    20 1D                 	JR	NZ,CRTD2	;if processing escape sequence
  0179    3A F0E3               	LD	A,(MASK)	;get keyboard mask
  017C    A1                    	AND	C
  017D    4F                    	LD	C,A
  017E    FE 20                 	CP	' '
  0180    38 14                 	JR	C,CRTD2		;if control code
  0182    3A FFB3               CRTD1:	LD	A,(ATTRIB)
  0185    B1                    	OR	C
  0186    77                    	LD	(HL),A		;store displayable character
  0187    2C                    	INC	L		;advance pointer to next column
  0188    7D                    	LD	A,L
  0189    E6 7F                 	AND	01111111B	;extract column# from HL
  018B    FE 50                 	CP	80
  018D    38 0A                 	JR	C,CRTD3		;if end of line not reached
  018F    AD                    	XOR	L
  0190    6F                    	LD	L,A		;return cursor to left side
  0191    CD 02F7               	CALL	LFEED		;execute line feed
  0194    18 03                 	JR	CRTD3
  0196    CD 023D               CRTD2:	CALL	CONTRL		;process control character
  0199    22 FFAC               CRTD3:	LD	(CURSOR),HL	;save cursor pointer for next time
  019C    7E                    	LD	A,(HL)		;get character at new cursor location
  019D    32 FFB4               	LD	(CHRSAV),A	;save for next time 'CRTOUT' is called
  01A0    3A FFAE               	LD	A,(CSRCHR)	;get cursor character
  01A3    FE 20                 	CP	' '
  01A5    C8                    	RET	Z		;if no cursor
  01A6    4F                    	LD	C,A
  01A7    7E                    	LD	A,(HL)
  01A8    CB BF                 	RES	7,A
  01AA    FE 20                 	CP	' '
  01AC    79                    	LD	A,C		;set character used for cursor
  01AD    28 03                 	JR	Z,CRTD4		;if character is a space
  01AF    7E                    	LD	A,(HL)		;toggle attribute
  01B0    EE 80                 	XOR	80H
  01B2    77                    CRTD4:	LD	(HL),A		;store cursor character
  01B3    C9                    	RET
                                ;
                                ;	MULTI - Process multiple character escape sequence.
                                ;
  01B4    EB                    MULTI:	EX	DE,HL		;unconditionally reset the lead-in
  01B5    36 00                 	LD	(HL),0		;state to zero
  01B7    EB                    	EX	DE,HL
  01B8    3D                    	DEC	A
  01B9    20 4E                 	JR	NZ,SETXY1	;if not initial state
  01BB    79                    	LD	A,C		;get second character of sequence
                                	IF	(OPTIONS AND O.ESCT) EQ 0
                                	CP	'='
                                	JR	NZ,MULTI1
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-29
ROM-RESIDENT CRT DRIVER

                                	LD	A,2
                                	LD	(DE),A
                                	RET
                                MULTI1:	POP	AF		;pitch return address
                                	JR	CRTD1
                                	ENDIF
                                	IF	(OPTIONS AND O.ESCT) NE 0
                                ;
                                ;	Escape table search
                                ;
  01BC    E5                    	PUSH	HL
  01BD    21 028A               	LD	HL,ESCTAB
  01C0    01 0011               	LD	BC,ESCTBL
  01C3    ED B1                 SEARCH:	CPIR
  01C5    09                    	ADD	HL,BC
  01C6    09                    	ADD	HL,BC
  01C7    09                    	ADD	HL,BC
  01C8    4E                    	LD	C,(HL)
  01C9    23                    	INC	HL
  01CA    46                    	LD	B,(HL)
  01CB    E1                    	POP	HL
  01CC    C0                    	RET	NZ
  01CD    C5                    	PUSH	BC
  01CE    C9                    	RET
                                	ENDIF			;options and o.esct
                                ;
                                ;	Set attribute modes.
                                ;
  01CF    D3 36                 SETLOW:	OUT	(LOWLITE),A	;set low-light mode
  01D1    C3 F337               	JP	SETPRV
  01D4    D3 35                 SETBLI:	OUT	(CHROM2),A	;select ROM 2
  01D6    AF                    	XOR	A		;select standard character set
  01D7    18 08                 	JR	MODE1
  01D9    D3 35                 SETINV:	OUT	(CHROM2),A	;select ROM 2
  01DB    18 02                 	JR	MODE	
  01DD    D3 34                 SETGRA:	OUT	(CHROM1),A	;select ROM 1
  01DF    3E 40                 MODE:	LD	A,40H		;select alternate character set
  01E1    CD F337               MODE1:	CALL	SETPRV		;set up previous attribute
  01E4    47                    	LD	B,A
  01E5    F3                    	DI			;lock system
  01E6    DB 1C                 	IN	A,(SYSPIO)	;read system PIO
  01E8    CB B7                 	RES	6,A		;clear ROM select bit
  01EA    B0                    	OR	B
  01EB    FB                    	EI			;unlock
  01EC    D3 1C                 	OUT	(SYSPIO),A	;set or reset display mode
  01EE    C9                    	RET
                                ;
                                ;	Enable/disable (D7) display of selected attribute mode
                                ;
  01EF    3E 80                 ENATR:	LD	A,80H
                                ;	JR	DIS1
  01F1    06                    	DB	6 ;LD B,	;skip XOR
  01F2    AF                    DISATR:	XOR	A
  01F3    32 FFB3               DIS1:	LD	(ATTRIB),A
  01F6    C9                    	RET
                                ;
                                ;	SETMSK - Select 7 or 8 bit data from keyboard
                                ;
  01F7    0F                    SETMSK:	RRCA			;get low order bit as upper bit mask
  01F8    F6 7F                 	OR	7FH
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-30
ROM-RESIDENT CRT DRIVER

  01FA    4F                    	LD	C,A
  01FB    11 F0E3               	LD	DE,MASK
  01FE    1A                    	LD	A,(DE)
  01FF    32 F319               	LD	(GOLD),A	;stash balcones gold
  0202    79                    	LD	A,C
  0203    12                    	LD	(DE),A		;store keyboard mask
  0204    C9                    	RET
                                ;
                                ;	Process cursor position sequence.
                                ;
  0205    3E 02                 SETXY:	LD	A,2
  0207    12                    	LD	(DE),A		;make leadin=2 next time
  0208    C9                    	RET
  0209    3D                    SETXY1:	DEC	A
  020A    20 10                 	JR	NZ,M3TST	;if not in state 2
  020C    6F                    	LD	L,A		;clear low cursor pos
  020D    3E 03                 	LD	A,3
  020F    12                    	LD	(DE),A		;set state 3 for next time
  0210    79                    SETROW:	LD	A,C
  0211    E6 7F                 	AND	07FH		;strip parity bit
  0213    D6 20                 	SUB	' '
  0215    D8                    	RET	C		;if illegal character
  0216    FE 18                 	CP	24
  0218    D0                    	RET	NC
  0219    C3 F31E               	JP	CCA		;compute cursor address
  021C    3D                    M3TST:	DEC	A
  021D    20 0C                 	JR	NZ,M4TST	;if not ready for column
  021F    79                    SETCOL:	LD	A,C
  0220    E6 7F                 	AND	07FH		;strip parity bit
  0222    D6 20                 	SUB	' '		; of esc,'=',row,col sequence
  0224    D8                    	RET	C
  0225    FE 50                 	CP	80
  0227    D0                    	RET	NC
  0228    B5                    	OR	L		;merge in col# with L
  0229    6F                    	LD	L,A
  022A    C9                    	RET
  022B    3D                    M4TST:	DEC	A
  022C    20 04                 	JR	NZ,M5TST	;if not escape state 4
  022E    D1                    	POP	DE		;pitch address of CRT D3
  022F    C3 0182               	JP	CRTD1		;display character in C
  0232    3A FFAE               M5TST:	LD	A,(CSRCHR)
  0235    32 F319               	LD	(GOLD),A	;stash balcones gold
  0238    79                    	LD	A,C
  0239    32 FFAE               	LD	(CSRCHR),A	;store new cursor character
  023C    C9                    	RET
                                ;
                                ;	CONTRL - Process control character.
                                ;
  023D    11 FFB2               CONTRL:	LD	DE,LEADIN	;point at leadin state
  0240    D2 01B4               	JP	NC,MULTI	;if multi code sequence in progress
  0243    FE 05                 	CP	'E'-64
  0245    D8                    	RET	C		;control character is out of range
  0246    E5                    	PUSH	HL		;save cursor
  0247    21 024A               	LD	HL,CTLTAB-('E'-64)*2
  024A    06 00                 	LD	B,0
  024C    09                    	ADD	HL,BC		;index through control character table
  024D    09                    	ADD	HL,BC
  024E    4E                    	LD	C,(HL)
  024F    23                    	INC	HL
  0250    46                    	LD	B,(HL)		;get address of control subroutine
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-31
ROM-RESIDENT CRT DRIVER

  0251    E1                    	POP	HL
  0252    C5                    	PUSH	BC
  0253    C9                    	RET			;execute control code driver
                                	IF	(OPTIONS AND O.ESCT) EQ 0
                                CTLTAB:	DEFW	DEFCUR		;Ctrl-e is define new cursor character
                                	DEFW	RSTATT		;Ctrl-f is restore previous attribute mode
                                	DEFW	BELL		;Ctrl-g is the bell
                                	DEFW	BAKSPC		;Ctrl-h is cursor left
                                	DEFW	TAB		;Ctrl-i is tab
                                	DEFW	LFEED		;Ctrl-j is cursor down
                                	DEFW	UPCSR		;Ctrl-k is cursor up
                                	DEFW	FORSPC		;Ctrl-l is cursor right
                                	DEFW	RETURN		;Ctrl-m is carriage return
                                	DEFW	SETMSK		;Ctrl-n is strip keyboard upper bit
                                	DEFW	SETMSK		;Ctrl-o is pass keyboard upper bit
                                	DEFW	ENATR		;Ctrl-p is enable screen upper bit
                                	DEFW	CLREOS		;Ctrl-q is clear to end-of-screen
                                	DEFW	SETLOW		;Ctrl-r is set lo-lite mode
                                	DEFW	SETINV		;Ctrl-s is set inverse video mode
                                	DEFW	SETGRA		;Ctrl-t is set graphics mode
                                	DEFW	SETBLI		;Ctrl-u is set blinking mode
                                	DEFW	LININS		;Ctrl-v is line insert
                                	DEFW	LINDEL		;Ctrl-w is line delete
                                	DEFW	CLREOL		;Ctrl-x is clear to end-of-line
                                	DEFW	DISATR		;Ctrl-y is disable screen upper bit
                                	DEFW	CLRSCN		;Ctrl-z is clear screen
                                	DEFW	ESCAPE		;Ctrl-[ is escape
                                	DEFW	CHRINS		;Ctrl-\ is character insert
                                	DEFW	CHRDEL		;Ctrl-] is character delete
                                	DEFW	HOMEUP		;Ctrl-^ is home up
                                	DEFW	STUFF		;Ctrl-_ is display control chars
                                CTLSIZ	EQU	$-CTLTAB
                                	ENDIF			;options and o.esct
                                	IF	(OPTIONS AND O.ESCT) NE 0
  0254    02C5                  CTLTAB:	DEFW	DEFCUR		;Ctrl-e is define new cursor character
  0256    F332                  	DEFW	RSTATT		;Ctrl-f is restore previous attribute mode
  0258    032F                  	DEFW	BELL		;Ctrl-g is the bell
  025A    02CE                  	DEFW	BAKSPC		;Ctrl-h is cursor left
  025C    031F                  	DEFW	TAB		;Ctrl-i is tab
  025E    02F7                  	DEFW	LFEED		;Ctrl-j is cursor down
  0260    02DC                  	DEFW	UPCSR		;Ctrl-k is cursor up
  0262    02D4                  	DEFW	FORSPC		;Ctrl-l is cursor right
  0264    02F2                  	DEFW	RETURN		;Ctrl-m is carriage return
  0266    02C0                  	DEFW	NONO		;Ctrl-n is not acceptable
  0268    02C0                  	DEFW	NONO		;Ctrl-o is not acceptable
  026A    02C0                  	DEFW	NONO		;Ctrl-p is not acceptable
  026C    0361                  	DEFW	CLREOS		;Ctrl-q is clear to end-of-screen
  026E    02C0                  	DEFW	NONO		;Ctrl-r is not acceptable
  0270    02C0                  	DEFW	NONO		;Ctrl-s is not acceptable
  0272    02C0                  	DEFW	NONO		;Ctrl-t is not acceptable
  0274    02C0                  	DEFW	NONO		;Ctrl-u is not acceptable
  0276    02C0                  	DEFW	NONO		;Ctrl-v is not acceptable
  0278    02C0                  	DEFW	NONO		;Ctrl-w is not acceptable
  027A    0344                  	DEFW	CLREOL		;Ctrl-x is clear to end-of-line
  027C    02C0                  	DEFW	NONO		;Ctrl-y is not acceptable
  027E    0357                  	DEFW	CLRSCN		;Ctrl-z is clear screen
  0280    02BD                  	DEFW	ESCAPE		;Ctrl-[ is escape
  0282    02C0                  	DEFW	NONO		;Ctrl-\ is not acceptable
  0284    02C0                  	DEFW	NONO		;Ctrl-] is not acceptable
  0286    02C9                  	DEFW	HOMEUP		;Ctrl-^ is home up
