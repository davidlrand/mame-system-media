  FD80    04                    	INC	B
  FD81    05                    	DEC	B
  FD82    C0                    	RET	NZ		;if line feed did not scroll
  FD83    CD FD89               	CALL	LTL		;link top line
  FD86    3E 0A                 	LD	A,LF
  FD88    C9                    	RET
                                ;
                                ;	LTL - Link Top Line.
                                ;
  FD89    21 FF5C               LTL:	LD	HL,LINBUF
  FD8C    ED 5B FEE8            	LD	DE,(TOPPTR)	;set address of line above screen
  FD90    01 0050               	LD	BC,80
  FD93    ED B0                 	LDIR			;move line
  FD95    CD FE34               	CALL	WUP		;wrap upper pointer
  FD98    ED 53 FEE8            	LD	(TOPPTR),DE	;set new top line address
  FD9C    2A FEE6               	LD	HL,(BOTPTR)
  FD9F    EB                    	EX	DE,HL
  FDA0    B7                    	OR	A
  FDA1    ED 52                 	SBC	HL,DE
  FDA3    C0                    	RET	NZ
  FDA4    11 0050               	LD	DE,80
  FDA7    19                    	ADD	HL,DE		;advance bottom pointer
  FDA8    EB                    	EX	DE,HL
  FDA9    CD FE34               	CALL	WUP		;wrap upper pointer
  FDAC    ED 53 FEE6            	LD	(BOTPTR),DE
  FDB0    C9                    	RET
                                ;
                                ;	DTL - Display Top Line.
                                ;
  FDB1    ED 5B FEE8            DTL:	LD	DE,(TOPPTR)	;get line above screen
  FDB5    21 FFB0               	LD	HL,-80
  FDB8    19                    	ADD	HL,DE
  FDB9    CD FE41               	CALL	WLP		;wrap lower pointer
  FDBC    22 FEE8               	LD	(TOPPTR),HL
  FDBF    01 0050               	LD	BC,80
                                ;
                                ;	DLN - Display line.
                                ;
  FDC2    E5                    DLN:	PUSH	HL
  FDC3    09                    	ADD	HL,BC
  FDC4    2B                    	DEC	HL
  FDC5    3E 20                 	LD	A,' '
  FDC7    ED A9                 DLN1:	CPD
  FDC9    20 03                 	JR	NZ,DLN2		;if not trailing blank
  FDCB    EA FDC7               	JP	PE,DLN1
  FDCE    E1                    DLN2:	POP	HL
  FDCF    E0                    	RET	PO		;if entire line blank
  FDD0    41                    	LD	B,C
  FDD1    04                    	INC	B
  FDD2    C5                    DLN3:	PUSH	BC
  FDD3    7E                    	LD	A,(HL)
  FDD4    4F                    	LD	C,A
  FDD5    FE 20                 	CP	' '
  FDD7    30 08                 	JR	NC,DLN4
  FDD9    E5                    	PUSH	HL
  FDDA    0E 1F                 	LD	C,FORCE		;force next character out
  FDDC    CD FE9B               	CALL	OUTCRT
  FDDF    E1                    	POP	HL
  FDE0    4E                    	LD	C,(HL)
  FDE1    23                    DLN4:	INC	HL		;advance address
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-67
