                                	IF	0
                                	LD	C,L		;use first arg as unit#
                                	CALL	SELECT
                                	JR	NZ,DSKERR
                                	LD	A,(PARAM2)
                                	LD	C,A		;get track number
                                	CALL	SEEK
                                	LD	A,(PARAM3)
                                	LD	C,A		;get sector number
                                DSK2:	LD	HL,(PARAM4)
                                	LD	A,(LINBUF)	;get command read or write
                                	CP	'W'
                                	JR	NZ,DSK3		;go to read command
                                	CALL	WRITE
                                	JR	DSK4
                                DSK3:	CALL	READ
                                DSK4:
                                	ENDIF
  FC80    21 FFB5               	LD	HL,PARAM1	;move parameters to disk command
  FC83    11 FA10               	LD	DE,PHYDRV
