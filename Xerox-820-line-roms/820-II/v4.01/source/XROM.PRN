                                ;
                                ;	SWAP - Swap logical drives.
                                ;
                                ;	Entry:	C = first  drive index, 0-15
                                ;		L = second drive index, 0-15
                                ;
  FCEE    06 00                 SWAP:	LD	B,0		;clear upper indices
  FCF0    60                    	LD	H,B
  FCF1    11 F360               	LD	DE,SELTAB	;set select table address
  FCF4    29                    	ADD	HL,HL
  FCF5    19                    	ADD	HL,DE
  FCF6    EB                    	EX	DE,HL		;set second address to DE, get seltab to HL
  FCF7    09                    	ADD	HL,BC
  FCF8    09                    	ADD	HL,BC		;set first address to HL
  FCF9    06 02                 	LD	B,2
  FCFB    4E                    SWAP1:	LD	C,(HL)		;swap two bytes
  FCFC    1A                    	LD	A,(DE)
  FCFD    77                    	LD	(HL),A
  FCFE    79                    	LD	A,C
  FCFF    12                    	LD	(DE),A
  FD00    23                    	INC	HL
  FD01    13                    	INC	DE
  FD02    10 F7                 	DJNZ	SWAP1		;if swap not complete
  FD04    C9                    	RET
