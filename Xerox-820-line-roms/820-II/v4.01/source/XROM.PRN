  FD5E    D3 00                 	OUT	(BAUDA),A
  FD60    3A EE7E               	LD	A,(Z.BAUB)	;configure channel B bit rate
  FD63    D3 0C                 	OUT	(BAUDB),A
  FD65    3A EE77               	LD	A,(Z.SIOM)	;configure printer ready mask
  FD68    32 F10C               	LD	(SIOMSK),A
  FD6B    3A EE79               	LD	A,(Z.SIOV)	;configure printer ready value
