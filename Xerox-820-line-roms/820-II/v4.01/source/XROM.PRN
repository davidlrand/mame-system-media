                                	IF	OPTIONS AND O.INPC
                                ;
                                ;	-- read input port command --
                                ;
BALCONES OPERATING SYSTEM FOR THE XEROX 820-II   	MACRO-80 3.44	09-Dec-81	PAGE	1-58
TRANSIENT COMMAND PROCESSORS

                                ;	* I <16-bit port address>
                                ;
                                	OVERLAY	INCMD
  035A'                   +     	C&SEG
  FC55    3D                    	DEC	A
  FC56    37                    	SCF
  FC57    C0                    	RET	NZ		;if not one parameter
  FC58    4D                    	LD	C,L		;set input port
  FC59    44                    	LD	B,H
  FC5A    CD FC36               IN1:	CALL	CRLF
  FC5D    79                    	LD	A,C		;display port address
  FC5E    CD FC1B               	CALL	PUT2HS
  FC61    ED 78                 IN2:	IN	A,(C)
  FC63    CD FC1B               	CALL	PUT2HS
  FC66    CD F009               	CALL	CONIN		;read character
  FC69    FE 20                 	CP	' '
  FC6B    28 F4                 	JR	Z,IN2		;read same port again
  FC6D    FE 0D                 	CP	CR
  FC6F    28 06                 	JR	Z,IN3		;if read next
  FC71    FE 2D                 	CP	'-'
  FC73    28 04                 	JR	Z,IN4		;if read previous
  FC75    B7                    	OR	A		;clear carry
  FC76    C9                    	RET
  FC77    03                    IN3:	INC	BC		;advance to next port
  FC78    03                    	INC	BC
  FC79    0B                    IN4:	DEC	BC
  FC7A    18 DE                 	JR	IN1
                                	ELSE
                                INCMD	EQU	WHAT
                                	ENDIF
