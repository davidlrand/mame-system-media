  FC93    B7                    	OR	A
  FC94    20 0D                 	JR	NZ,BOOT3	;if not rigid
  FC96    21 000D               	LD	HL,13		;set reserved track offset within DPB
  FC99    19                    	ADD	HL,DE
  FC9A    4E                    	LD	C,(HL)		;get reserved tracks
