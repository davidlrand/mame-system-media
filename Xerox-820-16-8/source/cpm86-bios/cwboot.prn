009D*	BIOS            0059*	BSELD           00A4*	BSETD           
0099*	BSETS           0090*	BSETT           0012*	BWBOOT          
0002 	C.EB2           0004 	C.FIVE          0007 	C.KEYM          
0003 	C.LPKB          0060 	C.RGD           0020 	C.RGD5          
0040 	C.SASI          00CFI'	CBOOT           0800 	CCPLEN          
0004 	CDISK           F03C 	CONFG           0039*	DBOOT           
011E'	DMABAS          0082'	EB2WBT          0104'	MLS             
0113'	MLS1            0115'	MLS2            002C 	NSECTS          
008C 	OS.CPM          FFCC 	OSBOOT          00F8I'	PMSG            
00A7*	READ            0043 	REV             00AE'	SECCNT          
00BA'	SPT             0116'	TRANSZ          0035I'	WBOOT           
0055'	WBT0            008D'	WBT1            0093'	WBT2            
00B6'	WBT3            00C4'	WBT4            0000'	WBT5            
001C'	WBTCOM          0024'	WBTERR          0105'	XLATE           



No Fatal error(s)


