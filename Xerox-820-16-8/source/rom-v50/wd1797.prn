  00F9'   1A                    	ld	a,(de)
  00FA'   1B                    	dec	de
  00FB'   E6 01                 	and	1
  00FD'   28 15                 	jr	z,sek1		;if one sided diskette
  00FF'   DB 1C                 	in	a,(wdsl)
  0101'   CB 67                 	bit	c.8in,a
  0103'   06 4D                 	ld	b,ntrk8		;set number of eight inch tracks
  0105'   20 02                 	jr	nz,sek0		;if 8" drives
  0107'   06 28                 	ld	b,ntrk5
  0109'   79                    sek0:	ld	a,c		;set seek track
  010A'   B8                    	cp	b
  010B'   3E 00                 	ld	a,0		;preset side 0
  010D'   38 05                 	jr	c,sek1		;if side 0
  010F'   79                    	ld	a,c
  0110'   90                    	sub	b		;wrap to side 1
  0111'   4F                    	ld	c,a
  0112'   3E 02                 	ld	a,2		;set side 1
  0114'   32 0046'              sek1:	ld	(rdwrs),a	;store F1 (update SS0)
  0117'   87                    	add	a,a		;move into select port position
  0118'   47                    	ld	b,a
  0119'   F3                    	di
  011A'   DB 1C                 	in	a,(wdsl)
  011C'   CB 97                 	res	2,a
  011E'   B0                    	or	b
  011F'   FB                    	ei
  0120'   D3 1C                 	out	(wdsl),a	;send out REAL SS0
  0122'   1A                    	ld	a,(de)		;check current position
  0123'   D3 11                 	out	(wdtr),a	;inform 1797 of current track
  0125'   B9                    	cp	c
  0126'   28 17                 	jr	z,seek3		;if position ok, load head
  0128'   3C                    	inc	a		;check for forced recovery
  0129'   CC 0148'              	call	z,rse		;recover seek errors
  012C'   28 0D                 	jr	z,seek1		;if error not recoverable
  012E'   79                    seek0:	ld	a,c		;set new track
  012F'   D3 13                 	out	(wddt),a	;in data register
  0131'   3E 1C                 	ld	a,1ch		;set seek with verify command
  0133'   CD 0193'              	call	isc		;issue step command
  0136'   E6 98                 	and	98h
  0138'   79                    	ld	a,c		;update current track
  0139'   28 02                 	jr	z,seek2		;if no errors
  013B'   F6 FF                 seek1:	or	-1		;force recovery next time
  013D'   12                    seek2:	ld	(de),a
  013E'   C9                    	ret
  013F'   CD 0197'              seek3:	call	rdc		;set type I status
  0142'   E6 20                 	and	20h		;test head load
  0144'   28 E8                 	jr	z,seek0		;if head is not loaded
  0146'   AF                    retzr:	xor	a		;say seek complete
  0147'   C9                    	ret
                                
                                ;;	rse - recover seek error.
                                ;
  0148'   C5                    rse:	push	bc
  0149'   CD 0155'              	call	rdid		;read id mark
  014C'   20 05                 	jr	nz,rse1		;if track position identified
  014E'   CD 0191'              	call	recal		;recalibrate
  0151'   E6 04                 	and	4		;verify track zero flag set
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-6
Floppy Disk Driver Proper

  0153'   C1                    rse1:	pop	bc
  0154'   C9                    	ret
                                
                                ;;	rdid - read id mark.
                                ;
  0155'   0E C4                 rdid:	ld	c,0c4h		;set Read Address Command
  0157'   CD 016D'              	call	stc		;start transfer command
  015A'   76                    	halt			;wait for interrupt
  015B'   ED 40                 	in	b,(c)		;first byte is track
  015D'   76                    	halt
  015E'   ED 48                 	in	c,(c)		;second byte is side, pitch next 4
  0160'   CD 0189'              	call	ttc		;terminate transfer command
  0163'   E6 98                 	and	98h		;ignore lost data
  0165'   20 04                 	jr	nz,rdid1	;if track not identified
  0167'   78                    	ld	a,b
  0168'   D3 11                 	out	(wdtr),a	;tell 1797 track head is on now
  016A'   F6                    	defb	0f6h		;or xra to set NZ
  016B'   AF                    rdid1:	xor	a		;set track not found
  016C'   C9                    	ret
                                
                                ;;	stc - start transfer command.
                                ;
  016D'   F3                    stc:	di			;lock normal interrupts
  016E'   3A 0066               	ld	a,(NMI)		;save byte at NMI address
  0171'   32 018A'              	ld	(ttca),a
  0174'   3E C9                 	ld	a,0c9h		;store RET there
  0176'   32 0066               	ld	(NMI),a
  0179'   79                    	ld	a,c		;retrieve command
  017A'   01 1413               	ld	bc,wddt+20*256	;1797 access timer / data port
  017D'   D3 10                 	out	(wdcr),a	;issue command
  017F'   10 FE                 	djnz	$		;pause 60 usec
  0181'   3E 00                 	ld	a,0
  0182'                         dsw	equ	$-1		;density switch
  0183'   E6 18                 	and	18h		;say ready and density
  0185'   C8                    	ret	z		;if double density
  0186'   06 80                 	ld	b,128		;set 128 byte single density sectors
  0188'   C9                    	ret
                                
                                ;;	ttc - terminate transfer command.
                                ;
  0189'   3E 00                 ttc:	ld	a,0		;restore location 66
  018A'                         ttca	equ	$-1
  018B'   32 0066               	ld	(NMI),a
  018E'   FB                    	ei			;take interrupts now
  018F'   18 0A                 	jr	woc		;wait for 1797 to complete
                                
                                ;;	recalibrate drive.
                                ;
  0191'   AF                    recal:	xor	a		;set restore command / track 0
  0192'   12                    	ld	(de),a		;set track zero
                                
                                ;;	isc - issue step command.
                                ;
  0193'   F6 01                 isc:	or	1		;insert step rate
  0194'                         stepr	equ	$-1	;*****=>;modify here for step rate change
  0195'   18 02                 	jr	icc
