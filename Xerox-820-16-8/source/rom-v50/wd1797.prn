Floppy Disk Driver Proper

                                
  0197'   3E D0                 rdc:	ld	a,0d0h		;terminate and set type I status
                                
                                ;;	icc  - issue controller command.
                                ;
  0199'   D3 10                 icc:	out	(wdcr),a	;issue 1797 command
                                
                                ;;	woc  - wait operation complete.
                                ;
  019B'   3E 14                 woc:	ld	a,20		;set 60 usec delay
  019D'   3D                    woc1:	dec	a
  019E'   20 FD                 	jr	nz,woc1
  01A0'   CD F066               woc2:	call	idle		;idle cpu
  01A3'   DB 10                 	in	a,(wdsr)	;set 1797 status
  01A5'   CB 47                 	bit	0,a
  01A7'   20 F7                 	jr	nz,woc2		;if busy, wait
  01A9'   C9                    	ret
                                
                                	subttl	Media Format Selector
                                	page
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-8
Media Format Selector

                                
                                
                                ;;	smf - set media format.
                                ;
                                ;	entry:	unit in A
                                ;
                                ;	exit:	DE = dpb address
                                ;		BC = translate table
                                ;
  01AA'   CD 0094'              smf:	call	selunt		;select unit
  01AD'   FA 0146'              	jp	m,retzr		;if disk not ready
  01B0'   21 0225'              	ld	hl,dtype
  01B3'   36 A0                 	ld	(hl),fm.ddss	;start out double density, single side, retry
  01B5'   DB 1C                 	in	a,(wdsl)	;read select status
  01B7'   CB 67                 	bit	c.8in,a		;test 8" / 5" status
  01B9'   20 02                 	jr	nz,smf0		;if 8 inch drives
  01BB'   CB F6                 	set	fm.fv,(hl)	;move up to 5.25" dpbs
  01BD'   3A 01BE'              smf0:	ld	a,(stpadr)	;set configurable step rate for 8" drives
  01BE'                         stpadr	equ	$-2
  01C0'   E6 03                 	and	3		;just so seeks aren't formats
  01C2'   32 0194'              	ld	(stepr),a	;save step rate in seek command
  01C5'   CD 0191'              smf0a:	call	recal		;establish position
  01C8'   E6 84                 	and	84h
  01CA'   C8                    	ret	z		;if not on track zero
  01CB'   FA 0146'              	jp	m,retzr		;if unit not ready
  01CE'   D3 31                 	out	(wddd),a	;set double density
  01D0'   3E FF                 	ld	a,-1
  01D2'   12                    	ld	(de),a		;clear drive on track
  01D3'   3E 02                 	ld	a,2		;use track 2 for density select
  01D5'   D3 13                 	out	(wddt),a
  01D7'   3E 18                 	ld	a,18h		;seek / no verify
  01D9'   CD 0193'              	call	isc		;issue seek command
  01DC'   3E 1C                 	ld	a,1ch		;find id mark
  01DE'   D3 10                 	out	(wdcr),a	;start verify
  01E0'   01 0000               	ld	bc,0		;set timers
  01E3'   10 FE                 smf1:	djnz	$		;pause
  01E5'   DB 10                 	in	a,(wdsr)
  01E7'   CB 47                 	bit	0,a
  01E9'   28 08                 	jr	z,smf1a		;if command completed
  01EB'   0D                    	dec	c
  01EC'   20 F5                 	jr	nz,smf1		;if more time
  01EE'   CD 0197'              	call	rdc		;terminate seek
  01F1'   3E 18                 	ld	a,18h		;set pseudo record not found
  01F3'   E6 18                 smf1a:	and	18h		;check record not found / crc error
  01F5'   13                    	inc	de		;point to density word in track table
  01F6'   12                    	ld	(de),a
  01F7'   1B                    	dec	de
  01F8'   28 14                 	jr	z,smf2		;if density select successful
  01FA'   D3 30                 	out	(wdsd),a	;use single density
  01FC'   3E 1C                 	ld	a,1ch		;verify single density
  01FE'   CD 0193'              	call	isc		;issue seek
  0201'   E6 18                 	and	18h
  0203'   28 07                 	jr	z,smf1b		;if single density successful
  0205'   CB 7E                 	bit	fm.un,(hl)	;test retry
  0207'   CB BE                 	res	fm.un,(hl)	;clear retry
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-9
Media Format Selector

  0209'   20 BA                 	jr	nz,smf0a	;if retry
  020B'   C9                    	ret			;return select error
  020C'   CB AE                 smf1b:	res	fm.dd,(hl)	;back up to single density dpbs
  020E'   CB BE                 smf2:	res	fm.un,(hl)	;clear retry
  0210'   DB 1C                 	in	a,(wdsl)
  0212'   CB D7                 	set	2,a		;select side 2
  0214'   D3 1C                 	out	(wdsl),a
  0216'   CD 0155'              	call	rdid		;read id mark
  0219'   28 09                 	jr	z,smf4		;if no id found, must be one side
  021B'   0D                    	dec	c
  021C'   20 06                 	jr	nz,smf4		;if side 1 ID not read
  021E'   CB E6                 	set	fm.ds,(hl)	;bump up to two sided dpbs
  0220'   21 0221'              	ld	hl,smfa		;set double sided status in track table
  0221'                         smfa	equ	$-2
  0223'   34                    	inc	(hl)
  0224'   21 0000               smf4:	ld	hl,0		;set diskette type
  0225'                         dtype	equ	$-2
  0227'   7D                    	ld	a,l		;save type
  0228'   4C                    	ld	c,h		;preset no translate
  0229'   44                    	ld	b,h
  022A'   11 0000*              	ld	de,dpb8s	;set base of disk parameter blocks
  022D'   19                    	add	hl,de
  022E'   EB                    	ex	de,hl		;return DPB address in DE
  022F'   CB 6F                 	bit	fm.dd,a
  0231'   C0                    	ret	nz		;if diskette is double density
  0232'   01 023D'              	ld	bc,trn5		;preset 5.25" skew table
  0235'   CB 77                 	bit	fm.fv,a
  0237'   C0                    	ret	nz		;if diskette is small
  0238'   01 0000*              	ld	bc,trn6		;set 8" translate
  023B'   3C                    	inc	a		;force NZ
  023C'   C9                    	ret
                                
                                ;;	Skew by 5 translate table.
                                ;
  023D'   01 06 0B 10           trn5::	db	01,06,11,16
  0241'   03 08 0D 12           	db	03,08,13,18
  0245'   05 0A 0F 02           	db	05,10,15,02
  0249'   07 0C 11 04           	db	07,12,17,04
  024D'   09 0E                 	db	09,14
                                
  024F'                         trktbl:
                                
                                	end
