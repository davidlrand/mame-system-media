                                	title	Western Digital WD-1797-02 Floppy Disk Driver		
                                
                                	.z80
                                
                                ;;	Western Digital WD-1797-02 Floppy Disk Driver.
                                ;
                                ;	Copyright (c) 1981, Balcones Computer Corporation
                                ;
                                ;;	Standard Disk Driver Interface Definitions.
                                ;
                                ;	The main entry point (FLOPPY) is called with HL pointing
                                ;	to a disk driver request block.  All information is passed
                                ;	in this request as follows:
                                ;
                                ;	HL->	db	command	;1 = read, 0 = write, -1 = select dph
                                ;		db	phunit	;physical unit for request (0-3)
                                ;		db	cpunit	;CP/M logical drive for request (0-15)
                                ;		dw	track	;CP/M track number (offset already applied)
                                ;		dw	sector	;Phys sector number (after deblocking)
                                ;		dw	address	;CP/M dma transfer address
                                ;
                                ;	The standard deblocker processes CP/M BIOS style select
                                ;	requests.  If the selected drive is not logged in, the
                                ;	deblocker issues a driver Select command.  The deblocker
                                ;	remembers the address of the DPH returned by the driver in
                                ;	order to quickly process successive BIOS select calls to a
                                ;	drive that is already logged in, by returning this address
                                ;	without assistance from the physical driver.
                                ;
                                ;	The Select command causes the media to be examined for its
                                ;	density and drive type.  This information is maintained locally
                                ;	by the driver for use in following read/write requests.  The
                                ;	driver then returns the address of a CP/M disk parameter header
                                ;	in register HL that coresponds to the unit and media format.
                                ;	The media may not be changed without issuing another driver
                                ;	Select command.  Note that a driver MUST NOT remember the unit
                                ;	for later use since this Select command is issued only once
                                ;	when the disk is logged in.  The Select command request block
                                ;	will contain only the first three bytes. (-1, phunit, cpunit)
                                ;
                                ;	The Read and Write commands process physical sectors according
                                ;	to the density determined by the previously issued Select command.
                                ;	The request block contains the unit, track, sector, and transfer
                                ;	address.  For double density diskettes, the transfer address will
                                ;	point to one of the deblocker's host buffers, and 256 bytes must
                                ;	be transfered to/from there.  However, for single density diskettes
                                ;	the transfer address will point directly to the users dma buffer,
                                ;	but only 128 bytes may be transfered.
                                	subttl	Assembly Constants
                                	page	60
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-1
Assembly Constants

                                
                                ;;	Monitor Entry Points.
                                ;
  F039                          daytim	equ	0f039h		;get address of timer data
  F066                          idle	equ	0f066h		;idle cpu
  F069                          soft	equ	0f069h		;record soft error
                                
  0066                          NMI	equ	00066h		;address of non maskable interrupt
                                
                                ;;	WD 1797 I/O port addresses.
                                ;
  0010                          wdsr	equ	10h		;status
  0010                          wdcr	equ	10h		;command
  0011                          wdtr	equ	11h		;track
  0012                          wdsn	equ	12h		;sector
  0013                          wddt	equ	13h		;data
                                
  001C                          wdsl	equ	1ch		;drive select port
  0030                          wdsd	equ	30h		;select single density
  0031                          wddd	equ	31h		;select double density
                                
                                
                                ;;	External Disk Parameter Tables.
                                ;
                                	extrn	Dpbase,Dpb8s,Trn6
                                
  0007                          fm.un	equ	7
  0004                          fm.ds	equ	4
  0005                          fm.dd	equ	5
  0006                          fm.fv	equ	6
  00A0                          fm.ddss	equ	(1 shl fm.dd) or (1 shl fm.un)
                                
  004D                          ntrk8	equ	77
  0028                          ntrk5	equ	40
                                
  0004                          c.8in	equ	4
  0005                          c.two	equ	5
  0006                          timout	equ	6		;motor / select time out
  000A                          dpbofs	equ	10		;offset in dph for dpb address
                                
                                	subttl	Floppy Disk Driver Proper
                                	page
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-2
Floppy Disk Driver Proper

                                
                                ;;	Western Digital Floppy Disk Driver.
                                ;
  0000'   CD 0197'              Dskdvr::call	rdc		;un hang busy controller
  0003'   7E                    	ld	a,(hl)		;set command
  0004'   23                    	inc	hl		;point to unit
  0005'   32 0037'              	ld	(rdop),a
  0008'   3C                    	inc	a
  0009'   28 55                 	jr	z,select	;if select command
  000B'   06 0A                 	ld	b,10		;set retry count
  000D'   C5                    flop1:	push	bc		;save count
  000E'   E5                    	push	hl		;save command
  000F'   7E                    	ld	a,(hl)		;set unit select
  0010'   CD 0094'              	call	selunt
  0013'   FA 0056'              	jp	m,flop5		;if unit not ready
  0016'   23                    	inc	hl
  0017'   23                    	inc	hl
  0018'   4E                    	ld	c,(hl)		;set track low
  0019'   CD 00F3'              	call	seek		;position disk
  001C'   4E                    	ld	c,(hl)		;retrieve track low
  001D'   20 37                 	jr	nz,flop5	;if unrecoverable error
  001F'   23                    	inc	hl		;track high
  0020'   23                    	inc	hl
  0021'   13                    	inc	de		;point to second byte of track table entry
  0022'   1A                    	ld	a,(de)		;get diskette type
  0023'   E6 18                 	and	18h
  0025'   7E                    	ld	a,(hl)		;sector low
  0026'   20 06                 	jr	nz,flop2	;if single density, cp/m skews
  0028'   79                    	ld	a,c		;get current logical track
  0029'   B7                    	or	a
  002A'   7E                    	ld	a,(hl)		;set sector
  002B'   28 01                 	jr	z,flop2		;if single density track zero
  002D'   3C                    	inc	a		;translate for double density
  002E'   D3 12                 flop2:	out	(wdsn),a	;set sector to read in 1791
  0030'   23                    	inc	hl		;skip sector high
  0031'   23                    	inc	hl		;dmal
  0032'   5E                    	ld	e,(hl)		;set transfer address to HL
  0033'   23                    	inc	hl		;dmah
  0034'   56                    	ld	d,(hl)
  0035'   EB                    	ex	de,hl
  0036'   3E 00                 	ld	a,0		;set read/write switch
  0037'                         rdop	equ	$-1
  0038'   B7                    	or	a
  0039'   0E A8                 	ld	c,0a8h		;preset write command
  003B'   3E A3                 	ld	a,0a3h		;set second part of OUTI
  003D'   28 03                 	jr	z,flop3		;if write
  003F'   0E 88                 	ld	c,088h		;turn write command into read command
  0041'   3D                    	dec	a		;turn OUTI into INI
  0042'   32 004E'              flop3:	ld	(rdwra),a	;set up i/o direction
  0045'   3E 00                 	ld	a,0
  0046'                         rdwrs	equ	$-1		;set side compare flag
  0047'   81                    	add	a,c
  0048'   4F                    	ld	c,a
  0049'   CD 016D'              	call	stc		;start transfer
  004C'   76                    flop4:	halt			;wait for DRQ or INT
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-3
Floppy Disk Driver Proper

  004D'   ED A2                 		ini		;transfer next byte
  004E'                         rdwra	equ	$-1
  004F'   20 FB                 	jr	nz,flop4	;if transfer not complete
  0051'   CD 0189'              	call	ttc		;terminate transfer command
  0054'   E6 DF                 	and	0dfh		;set error bits
  0056'   E1                    flop5:	pop	hl		;recover command pointer
  0057'   C1                    	pop	bc
  0058'   C8                    	ret	z		;if no errors
  0059'   D8                    	ret	c		;if 5.25" not ready
  005A'   CD F069               	call	soft
  005D'   10 AE                 	djnz	flop1		;if retry not exceeded
  005F'   C9                    	ret
                                
                                ;;	select - select dph for unit.
                                ;
  0060'   7E                    select:	ld	a,(hl)		;set unit
  0061'   FE 04                 	cp	4
  0063'   D2 0000*              	jp	nc,selerr##	;if bad unit select
  0066'   26 00                 	ld	h,0
  0068'   CD F039               	call	daytim		;set address of timers
  006B'   2B                    	dec	hl		;point to motor timer
  006C'   22 00A9'              	ld	(mtradr),hl
  006F'   2B                    	dec	hl		;point to configurable step rate
  0070'   22 01BE'              	ld	(stpadr),hl	;store address of step rate for media selector
  0073'   26 00                 	ld	h,0
  0075'   6F                    	ld	l,a
  0076'   29                    	add	hl,hl		;multiply by 2**4
  0077'   29                    	add	hl,hl
  0078'   29                    	add	hl,hl
  0079'   29                    	add	hl,hl
  007A'   11 0000*              	ld	de,Dpbase	;set address of disk parameter headers
  007D'   19                    	add	hl,de		;set dph address
  007E'   E5                    	push	hl
  007F'   CD 01AA'              	call	smf		;set media format
  0082'   E1                    	pop	hl
  0083'   CA 0000*              	jp	z,selerr##	;if no media
  0086'   71                    	ld	(hl),c		;store translate table
  0087'   23                    	inc	hl
  0088'   70                    	ld	(hl),b
  0089'   01 000A               	ld	bc,dpbofs
  008C'   09                    	add	hl,bc		;point to dpb addr and clear carry
  008D'   72                    	ld	(hl),d		;fill in dpb address
  008E'   2B                    	dec	hl
  008F'   73                    	ld	(hl),e
  0090'   ED 42                 	sbc	hl,bc		;point back to dph
  0092'   AF                    	xor	a
  0093'   C9                    	ret
                                
                                ;;	select physical unit.
                                ;
  0094'   4F                    selunt:	ld	c,a		;save select
  0095'   EB                    	ex	de,hl
  0096'   21 0250'              	ld	hl,trktbl+1	;set track / density table address
  0099'   06 00                 	ld	b,0
  009B'   09                    	add	hl,bc
  009C'   09                    	add	hl,bc
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-4
Floppy Disk Driver Proper

  009D'   22 0221'              	ld	(smfa),hl	;save address for media selector
  00A0'   EB                    	ex	de,hl
  00A1'   1A                    	ld	a,(de)		;get previous density switch
  00A2'   1B                    	dec	de		;point to track word
  00A3'   CD 00E8'              	call	selden		;select density
  00A6'   3E 06                 	ld	a,timout	;start motor / select timer
  00A8'   32 00A9'              	ld	(mtradr),a
  00A9'                         mtradr	equ	$-2		;address filled in by once only routine
  00AB'   FB                    	ei			;insure clock enabled
  00AC'   CB 89                 	res	1,c		;map C->A, D->B
  00AE'   DB 1C                 	in	a,(wdsl)	;read current select
  00B0'   47                    	ld	b,a
  00B1'   E6 F8                 	and	not 7
  00B3'   B1                    	or	c		;insert new select
  00B4'   3C                    	inc	a		;0-1, 1-2
  00B5'   D3 1C                 	out	(wdsl),a	;select drive
  00B7'   A8                    	xor	b
  00B8'   E6 03                 	and	3
  00BA'   28 25                 	jr	z,sel3		;if drive select identical
  00BC'   3E FF                 	ld	a,-1		;force track position recovery
  00BE'   12                    	ld	(de),a
  00BF'   CB 60                 	bit	c.8in,b		;test 8/5 status
  00C1'   20 1E                 	jr	nz,sel3		;if 8"
  00C3'   CD 0197'              	call	rdc		;set type I status
  00C6'   06 08                 	ld	b,2*4		;watch for four holes (8 transitions)
  00C8'   E5                    sel1:	push	hl
  00C9'   2A 00A9'              	ld	hl,(mtradr)	;get address of motor select timer
  00CC'   7E                    	ld	a,(hl)
  00CD'   E1                    	pop	hl
  00CE'   D6 04                 	sub	timout-2	;look for 1-2 seconds
  00D0'   D8                    	ret	c		;if drive not spinning
  00D1'   DB 10                 	in	a,(wdsr)
  00D3'   E6 02                 	and	2
  00D5'   28 F1                 sel2:	jr	z,sel1		;if index not under light
  00D7'   3A 00D5'              	ld	a,(sel2)	;switch index polarity
  00DA'   EE 08                 	xor	8 ; (jr z) xor (jr nz)
  00DC'   32 00D5'              	ld	(sel2),a
  00DF'   10 E7                 	djnz	sel1		;wait for at least three revolutions
  00E1'   DB 10                 sel3:	in	a,(wdsr)	;set ready status
  00E3'   E6 80                 	and	80h
  00E5'   C9                    	ret
                                
  00E6'   3E 18                 seldns:	ld	a,18h		;set track zero single density
  00E8'   32 0182'              selden:	ld	(dsw),a		;store switch for read/write routines
  00EB'   E6 18                 	and	18h
  00ED'   D3 31                 	out	(wddd),a	;pre-select dual density
  00EF'   C8                    	ret	z		;if dual density
  00F0'   D3 30                 	out	(wdsd),a	;select single density
  00F2'   C9                    	ret
                                
                                ;;	seek - position disk.
                                ;
  00F3'   79                    seek:	ld	a,c		;set new track
  00F4'   B7                    	or	a
  00F5'   CC 00E6'              	call	z,seldns	;force single density track 0
  00F8'   13                    	inc	de
Western Digital WD-1797-02 Floppy Disk Driver			MACRO-80 3.44	09-Dec-81	PAGE	1-5
