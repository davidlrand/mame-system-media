Console support routines

                                
                                ;;	getlin - read line into buffer.
                                ;
  FB34    3E 40                 gethlp:	ld	a,'@'
  FB36    32 FF5C               	ld	(linbuf),a
  FB39    3E 0D                 	ld	a,cr
  FB3B    32 FF5D               	ld	(linbuf+1),a
  FB3E    C9                    	ret
  FB3F    41                    getlin:	ld	b,c		;save max line length parameter in b
  FB40    CD FC2F               glin1:	call	echo		;get a character from the console
  FB43    FE 1E                 	cp	Helpkey
  FB45    28 ED                 	jr	z,gethlp	;if user needs help
  FB47    77                    	ld	(hl),a
  FB48    FE 0D                 	cp	cr		;check for carriage return
  FB4A    C8                    	ret	z		;if end of line
  FB4B    FE 08                 	cp	'H'-64		;check for ctl-h backspace
  FB4D    28 09                 	jr	z,glin4
  FB4F    FE 20                 	cp	' '
  FB51    D8                    	ret	c		;other control characters are illegal
  FB52    23                    	inc	hl		;store character in buffer
  FB53    0D                    	dec	c
  FB54    20 EA                 	jr	nz,glin1	;get another if there's more room
  FB56    37                    	scf
  FB57    C9                    	ret			;return with carry=1 if too
                                				;many characters are entered
  FB58    2B                    glin4:	dec	hl		;delete last character from buffer
  FB59    CD FC45               	call	pnext
  FB5C    20 08                 	defb	' ','H'-64	;delete character from screen
  FB5E    04                    	defb	eot
  FB5F    0C                    	inc	c
  FB60    78                    	ld	a,b		;set max line length
  FB61    91                    	sub	c
  FB62    30 DC                 	jr	nc,glin1	;if backspace not past the start of the line
  FB64    C9                    	ret
                                
  FB65    FD 23                 para0:	inc	iy		;advance character scan
  FB67    01 00FF               params:	ld	bc,low -1	;set parameter index
  FB6A    FD 7E 00              	ld	a,(iy+0)	;fetch character
  FB6D    D6 0D                 	sub	cr
  FB6F    C8                    	ret	z		;if no parameters
  FB70    D6 13                 	sub	' '-cr
  FB72    28 F1                 	jr	z,para0		;if leading blanks
  FB74    0C                    para1:	inc	c		;advance parameter index
  FB75    CB 51                 	bit	2,c
  FB77    37                    	scf
  FB78    C0                    	ret	nz		;error if > 4 numbers entered
  FB79    C5                    para2:	push	bc		;save parameter count
  FB7A    CD FBE2               	call	gethex		;read a number from line buffer
  FB7D    C1                    	pop	bc
  FB7E    DD 21 FFB5            para4:	ld	ix,param1	;point to parameter storage area
  FB82    DD 09                 	add	ix,bc		;add parameter count in bc
  FB84    DD 09                 	add	ix,bc
  FB86    DD 75 00              	ld	(ix+0),l
  FB89    DD 74 01              	ld	(ix+1),h	;store data returned from 'GETHEX'
  FB8C    FE 20                 	cp	' '
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-52
Console support routines

  FB8E    28 E4                 	jr	z,para1		;get another item if space
  FB90    FE 2C                 	cp	','
  FB92    28 E0                 	jr	z,para1		;get another item if comma
  FB94    79                    	ld	a,c		;set parameter count
  FB95    3C                    	inc	a
  FB96    C9                    	ret
                                
                                ;;	dump - dump memory.
                                ;
  FB97    E5                    dump:	push	hl		;save starting address
  FB98    CD FC1E               	call	put4hs		;print starting address in hex
  FB9B    CD FC26               	call	space
  FB9E    06 10                 	ld	b,16
  FBA0    3E 0F                 dump2:	ld	a,16-1		;skip 3 columns on 16 byte boundry
  FBA2    CD FC2B               	call	dmpfmt
  FBA5    3E 07                 	ld	a,8-1		;skip 2 columns on 8 byte boundry
  FBA7    CD FC2B               	call	dmpfmt
  FBAA    3E 03                 	ld	a,4-1		;skip 1 column  on 4 byte boundry
  FBAC    CD FC2B               	call	dmpfmt
  FBAF    7E                    	ld	a,(hl)		;get a data byte @ hl
  FBB0    23                    	inc	hl
  FBB1    CD FC23               	call	put2hs		;print the data in hex
  FBB4    10 EA                 	djnz	dump2		;repeat 16 times
  FBB6    CD FC26               	call	space
  FBB9    E1                    	pop	hl		;restore starting address
  FBBA    06 10                 	ld	b,16
  FBBC    3E 1F                 dump3:	ld	a,1fh		;force next character
  FBBE    CD F00C               	call	conout
  FBC1    7E                    	ld	a,(hl)		;get back data byte @ hl
  FBC2    23                    	inc	hl
  FBC3    CD F00C               	call	conout		;print ascii character in a
  FBC6    10 F4                 	djnz	dump3
  FBC8    CD F006               	call	const		;check console status
  FBCB    28 0C                 	jr	z,dump4		;if char not ready
  FBCD    CD F009               	call	conin		;read char
  FBD0    FE 0D                 	cp	cr
  FBD2    C8                    	ret	z		;if user abort
  FBD3    CD F009               	call	conin		;pause while user examines display
  FBD6    FE 0D                 	cp	cr
  FBD8    C8                    	ret	z		;if user found it
  FBD9    CD FC3E               dump4:	call	crlf		;send end of line
  FBDC    1B                    	dec	de
  FBDD    7A                    	ld	a,d
  FBDE    B3                    	or	e
  FBDF    20 B6                 	jr	nz,dump		;if dump not complete
  FBE1    C9                    	ret
                                
                                ;;	gethex converts ascii to binary.
                                ;
                                ;	carry set on illegal conversion result
                                ;	terminating character returns in a.
                                ;	hl returns with 16 bit binary integer
                                ;
  FBE2    21 0000               gethex:	ld	hl,0		;preset result
  FBE5    54                    	ld	d,h
  FBE6    5D                    	ld	e,l
