  FDCA    3E 20                 	ld	a,' '
  FDCC    ED A9                 dln1:	cpd
  FDCE    20 03                 	jr	nz,dln2		;if not trailing blank
  FDD0    EA FDCC               	jp	pe,dln1
  FDD3    E1                    dln2:	pop	hl
  FDD4    E0                    	ret	po		;if entire line blank
  FDD5    41                    	ld	b,c
  FDD6    04                    	inc	b
  FDD7    C5                    dln3:	push	bc
  FDD8    7E                    	ld	a,(hl)
  FDD9    4F                    	ld	c,a
  FDDA    FE 20                 	cp	' '
  FDDC    30 08                 	jr	nc,dln4
  FDDE    E5                    	push	hl
  FDDF    0E 1F                 	ld	c,force		;force next character out
  FDE1    CD FEA0               	call	outcrt
  FDE4    E1                    	pop	hl
  FDE5    4E                    	ld	c,(hl)
  FDE6    23                    dln4:	inc	hl		;advance address
  FDE7    E5                    	push	hl
  FDE8    CD FEA0               	call	outcrt		;display character
  FDEB    E1                    	pop	hl
  FDEC    C1                    	pop	bc
  FDED    10 E8                 	djnz	dln3		;if not entire line
  FDEF    C9                    	ret
                                
                                ;;	dbl - Display bottom line.
                                ;
  FDF0    CD FC45               dbl:	call	pnext		;plant cursor on bottom line
  FDF3    1B 3D 37 20           	db	esc,'=',' '+23,' ',eot
  FDF7    04                    
  FDF8    2A FEEB               	ld	hl,(botptr)
  FDFB    E5                    	push	hl
  FDFC    01 004F               	ld	bc,80-1
  FDFF    CD FDC7               	call	dln		;display bottom line
  FE02    E1                    	pop	hl
  FE03    01 0050               	ld	bc,80
  FE06    09                    	add	hl,bc
  FE07    EB                    	ex	de,hl
  FE08    CD FE39               	call	wup
  FE0B    ED 53 FEEB            	ld	(botptr),de
  FE0F    C9                    	ret
                                
                                ;;	lbl - link bottom line.
                                ;
  FE10    01 0050               lbl:	ld	bc,80
