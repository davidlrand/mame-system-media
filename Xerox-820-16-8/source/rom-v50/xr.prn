                                ;;	Set attribute modes.
                                ;
  0244    D3 36                 setlow:	out	(lowlite),a	;set lo-light mode
  0246    C3 F337               	jp	setprv
                                
  0249    D3 35                 setbli:	out	(chrom2),a	;select rom 2
  024B    AF                    	xor	a		;select standard char set
  024C    18 08                 	jr	mode1
                                
  024E    D3 35                 setinv:	out	(chrom2),a	;select rom 2
  0250    18 02                 	jr	mode	
                                
  0252    D3 34                 setgra:	out	(chrom1),a	;select rom 1
  0254    3E 40                 mode:	ld	a,40h		;select alternate char set
  0256    CD F337               mode1:	call	setprv		;set up previous attribute
  0259    47                    	ld	b,a
  025A    F3                    	di			;lock system
  025B    DB 1C                 	in	a,(syspio)	;read system pio
  025D    CB B7                 	res	6,a		;clear rom select bit
  025F    B0                    	or	b
  0260    FB                    	ei			;unlock
  0261    D3 1C                 	out	(syspio),a	;set or reset display mode
  0263    C9                    	ret
                                
                                ;;	Enable/disable (D7) display of selected attribute mode
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-33
Rom-resident Crt Driver

                                ;
  0264    3E 80                 enatr:	ld	a,80h
                                ;	jr	dis1
  0266    06                    	db	6 ;ld b,	;skip xor
                                
  0267    AF                    disatr:	xor	a
  0268    32 FFB3               dis1:	ld	(attrib),a
  026B    C9                    	ret
                                
                                ;;	setmsk - Select 7 or 8 bit data  from keyboard
                                ;
  026C    0F                    setmsk:	rrca			;get low order bit as upper bit mask
  026D    F6 7F                 	or	7fh
  026F    4F                    	ld	c,a
  0270    11 F0E3               	ld	de,mask
  0273    1A                    	ld	a,(de)
  0274    32 F319               	ld	(gold),a	;stash balcones gold
  0277    79                    	ld	a,c
  0278    12                    	ld	(de),a		;store keyboard mask
  0279    C9                    	ret
                                
                                ;;	Process cursor position sequence.
                                ;
  027A    3E 02                 setxy:	ld	a,2
  027C    12                    	ld	(de),a		;make leadin=2 next time
  027D    C9                    	ret
                                
  027E    3D                    setxy1:	dec	a
  027F    20 10                 	jr	nz,m3tst	;if not in state 2
  0281    6F                    	ld	l,a		;clear low cursor pos
  0282    3E 03                 	ld	a,3
  0284    12                    	ld	(de),a		;set state 3 for next time
  0285    79                    setrow:	ld	a,c
  0286    E6 7F                 	and	07fh		;strip parity bit
  0288    D6 20                 	sub	' '
  028A    D8                    	ret	c		;if illegal character
  028B    FE 18                 	cp	24
  028D    D0                    	ret	nc
  028E    C3 F31E               	jp	cca		;compute cursor address
                                
  0291    3D                    m3tst:	dec	a
  0292    20 0C                 	jr	nz,m4tst	;if not ready for column
  0294    79                    setcol:	ld	a,c
  0295    E6 7F                 	and	07fh		;strip parity bit
  0297    D6 20                 	sub	' '		; of esc,'=',row,col sequence
  0299    D8                    	ret	c
  029A    FE 50                 	cp	80
  029C    D0                    	ret	nc
  029D    B5                    	or	l		;merge in col# with l
  029E    6F                    	ld	l,a
  029F    C9                    	ret
                                
  02A0    3D                    m4tst:	dec	a
  02A1    20 04                 	jr	nz,m5tst	;if not escape state 4
  02A3    D1                    	pop	de		;pitch address of crtd3
  02A4    C3 01F7               	jp	crtd1		;display character in C
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-34
