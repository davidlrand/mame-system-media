  034E    D0                    	ret	nc		;do nothing if already there
  034F    2C                    	inc	l
  0350    C9                    	ret			;else advance the cursor pointer
                                
                                ;;	upscr - Move cursor up.
                                ;
  0351    11 FF80               upcsr:	ld	de,-128		;subtract 1 from row# component
  0354    19                    	add	hl,de		; of cursor pointer in hl
  0355    7C                    	ld	a,h
