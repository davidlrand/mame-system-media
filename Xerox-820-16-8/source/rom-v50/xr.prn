                                	below			;execute in banked rom
  0000!                   +     	defs	comres
                                
                                ;;	crtdvr - Crt Driver Proper.
                                ;
  01DE    2A FFAC               crtdvr:	ld	hl,(cursor)	;set cursor address
  01E1    3A FFB4               	ld	a,(chrsav)	;retrieve character under cursor
  01E4    77                    	ld	(hl),a		;replace character under cursor
  01E5    32 F319               	ld	(gold),a	;bury balcones gold
  01E8    3A FFB2               	ld	a,(leadin)	;set leadin state
  01EB    B7                    	or	a
  01EC    20 1D                 	jr	nz,crtd2	;if processing escape sequence
  01EE    3A F0E3               	ld	a,(mask)	;get keyboard mask
  01F1    A1                    	and	c
  01F2    4F                    	ld	c,a
  01F3    FE 20                 	cp	' '
  01F5    38 14                 	jr	c,crtd2		;if control code
  01F7    3A FFB3               crtd1:	ld	a,(attrib)
  01FA    B1                    	or	c
  01FB    77                    	ld	(hl),a		;store displayable character
  01FC    2C                    	inc	l		;advance pointer to next column
  01FD    7D                    	ld	a,l
  01FE    E6 7F                 	and	01111111b	;extract column# from hl
  0200    FE 50                 	cp	80
  0202    38 0A                 	jr	c,crtd3		;if end of line not reached
  0204    AD                    	xor	l
  0205    6F                    	ld	l,a		;return cursor to left side
  0206    CD 036C               	call	lfeed		;execute line feed
  0209    18 03                 	jr	crtd3
  020B    CD 02B2               crtd2:	call	contrl		;process control character
  020E    22 FFAC               crtd3:	ld	(cursor),hl	;save cursor pointer for next time
  0211    7E                    	ld	a,(hl)		;get character at new cursor location
  0212    32 FFB4               	ld	(chrsav),a	;save for next time 'CRTOUT' is called
  0215    3A FFAE               	ld	a,(csrchr)	;get cursor character
  0218    FE 20                 	cp	' '
  021A    C8                    	ret	z		;if no cursor
  021B    4F                    	ld	c,a
  021C    7E                    	ld	a,(hl)
  021D    CB BF                 	res	7,a
  021F    FE 20                 	cp	' '
  0221    79                    	ld	a,c		;set character used for cursor
  0222    28 03                 	jr	z,crtd4		;if character is a space
  0224    7E                    	ld	a,(hl)		;toggle attribute
  0225    EE 80                 	xor	80h
  0227    77                    crtd4:	ld	(hl),a		;store cursor character
  0228    C9                    	ret
                                
                                ;;	multi - Process multiple character escape sequence.
                                ;
  0229    EB                    multi:	ex	de,hl		;unconditionally reset the lead-in
  022A    36 00                 	ld	(hl),0		;state to zero
  022C    EB                    	ex	de,hl
  022D    3D                    	dec	a
  022E    20 4E                 	jr	nz,setxy1	;if not initial state
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-32
Rom-resident Crt Driver

  0230    79                    	ld	a,c		;get second character of sequence
                                
                                	if	(options and o.esct) eq 0
                                	cp	'='
                                	jr	nz,multi1
                                	ld	a,2
                                	ld	(de),a
                                	ret
                                multi1:	pop	af		;pitch return address
                                	jr	crtd1
                                	endif
                                
