  FE13    2A FEEB               	ld	hl,(botptr)
  FE16    B7                    	or	a
  FE17    ED 42                 	sbc	hl,bc
  FE19    CD FE46               	call	wlp
  FE1C    22 FEEB               	ld	(botptr),hl
  FE1F    EB                    	ex	de,hl
  FE20    2A FEED               	ld	hl,(topptr)
  FE23    B7                    	or	a
  FE24    ED 52                 	sbc	hl,de
  FE26    20 0B                 	jr	nz,lbl1
  FE28    2A FEED               	ld	hl,(topptr)
  FE2B    ED 42                 	sbc	hl,bc
  FE2D    CD FE46               	call	wlp
  FE30    22 FEED               	ld	(topptr),hl
  FE33    21 FF5C               lbl1:	ld	hl,linbuf
  FE36    ED B0                 	ldir			;move gold mine to buffer
  FE38    C9                    	ret
                                
                                ;;	wup - Wrap upper pointer.
                                ;
  FE39    E5                    wup:	push	hl
  FE3A    21 EE80               	ld	hl,buftop	;set end of buffer address
  FE3D    37                    	scf
  FE3E    ED 52                 	sbc	hl,de
  FE40    E1                    	pop	hl
  FE41    D0                    	ret	nc		;if not past end of buffer
  FE42    11 0100               	ld	de,Trmbuf	;start over at beggining of buffer
  FE45    C9                    	ret
                                
                                ;;	wlp - Wrap lower pointer.
                                ;
  FE46    E5                    wlp:	push	hl
  FE47    D5                    	push	de
  FE48    11 0100               	ld	de,Trmbuf	;set start of buffer address
  FE4B    B7                    	or	a
  FE4C    ED 52                 	sbc	hl,de
  FE4E    D1                    	pop	de
  FE4F    E1                    	pop	hl
  FE50    D0                    	ret	nc		;if not below start of buffer
  FE51    21 EE30               	ld	hl,buftop-80	;start over at end of buffer
  FE54    C9                    	ret
                                
                                ;;	gcp - get cursor position.
                                ;
  FE55    ED 4B FFB1            gcp:	ld	bc,(base)
  FE59    2A FFAC               	ld	hl,(cursor)
  FE5C    45                    	ld	b,l		;get column to B
  FE5D    CB B8                 	res	7,b
  FE5F    29                    	add	hl,hl		;set screen row to H
  FE60    7C                    	ld	a,h
  FE61    D6 60                 	sub	crtbas*2
  FE63    91                    	sub	c		;row = 23-(base-curh)
  FE64    C6 17                 	add	a,23
  FE66    D6 18                 gcp1:	sub	24
  FE68    30 FC                 	jr	nc,gcp1
  FE6A    4F                    	ld	c,a		;set row
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-79
Terminal / Screen Manager		

  FE6B    21 1F38               	ld	hl,'  '+24-100h	;offset for <esc>=
  FE6E    09                    	add	hl,bc
  FE6F    22 FE78               	ld	(rcpa),hl
  FE72    C9                    	ret
                                
                                ;;	rcp - Restore cursor position.
                                ;
  FE73    CD FC45               rcp:	call	pnext
  FE76    1B 3D                 	db	esc,'='
  FE78    20 20                 rcpa:	db	'  '
  FE7A    04                    	db	eot
  FE7B    C9                    	ret
                                
                                ;;	sio drivers.
                                ;
  FE7C    01 FE7D               sioins:	ld	bc,ports	;set status port to c
  FE7D                          ports	equ	$-2
  FE7F    ED 78                 	in	a,(c)
  FE81    CB 47                 	bit	0,a		;test rca
  FE83    C9                    	ret
                                
  FE84    CD FE7C               sioinp:	call	sioins		;get status
  FE87    28 FB                 	jr	z,sioinp	;if not ready
  FE89    48                    	ld	c,b		;set data port address
  FE8A    ED 78                 	in	a,(c)
  FE8C    CB BF                 	res	7,a		;pitch parity bit
  FE8E    C9                    	ret
                                
  FE8F    CD FE7C               siordt:	call	sioins		;get sio status
  FE92    CB 57                 	bit	2,a		;test TX empty
  FE94    C9                    	ret
                                
  FE95    08                    sioot:	ex	af,af'		;save char to send
  FE96    CD FE8F               sioot1:	call	siordt		;test transmit ready status
  FE99    28 FB                 	jr	z,sioot1	;if not ready
  FE9B    48                    	ld	c,b
  FE9C    08                    	ex	af,af'
  FE9D    ED 79                 	out	(c),a
  FE9F    C9                    	ret
                                
  FEA0    CD FEAC               outcrt:	call	siopl		;poll for input before & after
  FEA3    CD F2FE               	call	fastcrt
  FEA6    F5                    	push	af		;save balcones gold
  FEA7    CD FEAC               	call	siopl
  FEAA    F1                    	pop	af
  FEAB    C9                    	ret
                                
                                ;;	Siopl - Sio Poll Input Characters.
