                                	scf
                                	ret	nz
                                	call	blocad
                                	jr	verf2
                                
                                verf1:	ld	a,(de)
                                	call	check		;compare data @ de and @ hl
                                	ret	nz		;exit if escape request is indicated
                                	inc	hl
                                	inc	de
                                	dec	bc
                                verf2:	ld	a,b
                                	or	c
                                	jr	nz,verf1
                                	ret
