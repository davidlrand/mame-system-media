  FAA9    F4 F29C               	call	p,crton		;enable rom if disabled
  FAAC    ED B0                 	ldir
  FAAE    F1                    	pop	af
  FAAF    F4 F293               	call	p,crtoff	;disable rom if enabled
  FAB2    FB                    	ei
  FAB3    E1                    	pop	hl		;set execution address
  FAB4    E5                    prmt1:	push	hl
  FAB5    CD FC3E               	call	crlf
