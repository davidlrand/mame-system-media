                                ;;	escape - Initialize escape sequence.
                                ;
  0332    3E 01                 escape:	ld	a,1
  0334    12                    	ld	(de),a		;set sequence state
  0335    C9                    nono:	ret			;for escape processing
                                
                                ;;	stuff - Enable next char to be stored directly.
                                ;
  0336    3E 04                 stuff:	ld	a,4
  0338    12                    	ld	(de),a		;set sequence state
  0339    C9                    	ret			;for control char output mode
                                
                                ;;	defcur - Enable next chara to be new cursor.
                                ;
  033A    3E 05                 defcur:	ld	a,5
  033C    12                    	ld	(de),a
  033D    C9                    	ret
                                
                                ;;	homeup - Move cursor to upper left.
                                ;
  033E    0E 20                 homeup:	ld	c,' '		;use cursor addressing routine
  0340    C3 0285               	jp	setrow		;to do homeup almost for free
                                
                                ;;	bakspc - Move cursor left.
                                ;
  0343    7D                    bakspc:	ld	a,l		;check for left margin
  0344    E6 7F                 	and	01111111b
  0346    C8                    	ret	z		;abort if in leftmost column
  0347    2D                    	dec	l		;back up cursor pointer
  0348    C9                    	ret
                                
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-37
