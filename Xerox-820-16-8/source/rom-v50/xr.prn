                                ;;	Escape sequence table.
                                ;
                                ;	Maintains functional compatibility with terminals supporting
                                ;	ADM-3a style supersets.
                                ;
  02FF    28                    esctab:	db	'('		;disable attribute (Soroc/Televideo, et.al)
  0300    29                    	db	')'		;enable atribute (Soroc/Televideo, et.al)
  0301    2A                    	db	'*'		;clear screen (Soroc/Televideo, et.al)
  0302    30                    	db	'0'		;strip keyboard upper bit
  0303    31                    	db	'1'		;pass keyboard upper bit
  0304    34                    	db	'4'		;char font and blinking
  0305    35                    	db	'5'		;char font and graphics
  0306    36                    	db	'6'		;char font and blinking
  0307    37                    	db	'7'		;char font and inverse video
  0308    38                    	db	'8'		;char font and lo-light
  0309    3D                    	db	'='		;position cursor
  030A    45                    	db	'E'		;line insert (Televideo, et.al)
  030B    51                    	db	'Q'		;character insert (Televideo, et. al)
  030C    52                    	db	'R'		;line delete (Televideo, et. al)
  030D    57                    	db	'W'		;character delete (Televideo, et. al)      
  030E    54                    	db	'T'		;clear to end of line (Televideo, et. al)
  030F    59                    	db	'Y'		;clear to end of screen (Televideo, et. al)
  0011                          esctbl	equ	$-esctab
