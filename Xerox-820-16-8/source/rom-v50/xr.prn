                                ;;	Top of Overlay Area.
                                ;
                                	overlay	stop
  06CA'                   +     	c&seg
  02A2                          tpamax	equ	tpal+1		;set length of transient move
                                
                                ;;	Top of Resident Monitor.
                                ;
                                	below
  0000!                   +     	defs	comres
  04CF                          rbase	equ	$
                                
                                ;;	Top of Non Resident Monitor.
                                ;
                                	above
  05CC!                   +     	d&seg
  FC52                          restop	equ	$		;resident top
  0C52                          reslen	equ	$-monitr	;length of resident monitor
                                
                                	update			;clear active segment
                                
                                ;;	Top of Burned Rom Set.
                                ;
  17EB                          romtop	equ	bloc+dloc+tloc-monitr
                                
                                ;;	Fill Out Unused Rom Space.
                                ;
  0C52"                         	cseg
                                
