  0231    E5                    	push	hl
  0232    21 02FF               	ld	hl,esctab
  0235    01 0011               	ld	bc,esctbl
  0238    ED B1                 search:	cpir
  023A    09                    	add	hl,bc
  023B    09                    	add	hl,bc
  023C    09                    	add	hl,bc
  023D    4E                    	ld	c,(hl)
  023E    23                    	inc	hl
  023F    46                    	ld	b,(hl)
  0240    E1                    	pop	hl
  0241    C0                    	ret	nz
  0242    C5                    	push	bc
  0243    C9                    	ret
