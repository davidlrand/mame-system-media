                                	subttl	Code Generation Control Macros Definitions
                                	page
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-7
Code Generation Control Macros Definitions

                                
                                ;;	Rom code placement macros.
                                ;
                                ;;	The Common Segment holds the non-resident (banked) portion
                                ;	of the monitor.  This segment is not copied to ram.
                                ;
                                ;;	The Data Segment holds the resident portion of the monitor.
                                ;	It is moved to ram at location MONITR during initialization.
                                ;
                                ;;	The Code Segment holds the various Transient Commands.  Each
                                ;	command is loaded from the ROM to the TPA when it is executed.
                                ;
                                ;;	The following macros keep it all straight.
                                ;
                                ;;	below - Generate code for rom below.
                                ;
                                below	macro
                                	segment	b		;;enable common segment
                                	endm
                                
                                ;;	above - Generate code for ram above.
                                ;
                                above	macro
                                	segment	d		;;enable data segment
                                	endm
                                
                                ;;	Overlay - Generate code for transients.
                                ;
                                overlay	macro	addr
                                tloc	defl	tloc+$-cloc
                                addr	equ	tloc+bloc+cloc-Monitr
                                	segment	c		;;enable code segment
                                	endm
                                
                                ;;	bseg - activate common segment.
                                ;
                                bseg	macro
                                	common	/COMROM/
                                	defs	comres
                                sega	defl	$
                                	endm
                                
                                ;;	segment - Activate Segment.
                                ;
                                segment	macro	s
                                	update			;;update active phase counter
                                s&space	defl	-1		;;set enabled segment active        
                                	s&seg			;;activate segment code placement
                                	.phase	s&loc		;;set absolute segment location counter
                                	endm
                                
                                ;;	update - Update Phase Counters.
                                ;
                                update	macro
                                	if	bspace
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-8
Code Generation Control Macros Definitions

                                comres	defl	$-rom+100h-3
                                	endif
                                	irpc	x,<bcd>
                                	if	x&space		;;if segment active
                                	if	cspace
                                	if	tpal lt ($-cloc)
                                tpal	defl	$-cloc		
                                	endif			
                                	else
                                x&loc	defl	$		;;save segment address
                                	endif
                                x&space	defl	0		;;clear segment active
                                	.dephase		;;revert to relocatable
                                	endif
                                	endm
                                	endm
                                
  0000                          bloc	defl	rom		;establish non-resident code base
  F000                          dloc	defl	monitr		;establish resident code base
  0000                          tloc	defl	0		;establise Transient code base
  0000                          tpal	defl	0		;establish maximum transient length
  0000                          bspace	defl	0		;preset common segment inactive
  0000                          cspace	defl	0		;preset code segment inactive
  0000                          dspace	defl	0		;preset data segment inactive
  0000                          comres	defl	0		;preset common base address
                                
                                ldirs	macro
                                	if	ldirsm
                                	call	simldir
                                	else
                                	ldir
                                	endif
                                	endm
                                
                                	subttl	Ram Loader for Testing Only
                                	page
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-9
Ram Loader for Testing Only

                                
                                	bseg
  0000!                   +     	defs	comres
  0000!                         entry:
                                	if	debug
                                	jp	cpyout
                                	jp	xcks		;compute checksum
                                
                                cpyout:	di
                                	ld	hl,bbase	;move code out of resident memory
                                	ld	de,0c000h
                                	ld	bc,romsiz+movln
                                	ldir
                                	jp	0c000h
                                	else
  0000!   C3 0003!              	jp	xcks
                                	endif
                                
  0003!   21 00FD!              xcks:	ld	hl,bbase+movln
  0006!   01 17FF               	ld	bc,romsiz-1
  0009!   1E 00                 	ld	e,0		;preset checksum
  000B!   7E                    xcks1:	ld	a,(hl)
  000C!   23                    	inc	hl
  000D!   83                    	add	a,e
  000E!   5F                    	ld	e,a
  000F!   0B                    	dec	bc
  0010!   78                    	ld	a,b
  0011!   B1                    	or	c
  0012!   20 F7                 	jr	nz,xcks1
  0014!   7B                    	ld	a,e		;store twos complement of checksum
  0015!   ED 44                 	neg
  0017!   77                    	ld	(hl),a		;store checksum
  0018!   C3 0000               	jp	0
                                
                                	if	debug
                                	defs	80h-($-(entry-3)),-1
                                	endif
                                
                                
                                	subttl	System Initialization
                                	page
Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-10
System Initialization

                                
                                
  001B!                         bbase:				;symbol for accessing non-resident base address
                                	if	debug
                                	ld	hl,0c000h+movln	;move code into banked memory
                                	ld	de,prs		;set destination below
                                	ld	bc,romsiz	;move 4k
                                	in	a,(syspio)
                                	or	80h		;turn on rom/ram bank
                                	out	(syspio),a
                                	ldir
                                	jp	prs
                                	endif
                                
  001B!                         	defs	100h-($-(entry-3)),-1
                                
  00E2                          movln	equ	$-bbase
  00FD                          comres	defl	100h-3
                                
                                	below			;generate non-resident code
  0000!                   +     	defs	comres
                                
                                ;;	prs - preset storage.
                                ;
                                ;	Entry:	Power up or Reset button.
                                ;
  0000                          prs:
  0000    F3                    	di			;lock up system
  0001    AF                    	xor	a
  0002    3D                    prs1:	dec	a		;the pause that refershes
  0003    20 FD                 	jr	nz,prs1
  0005    ED 73 FFE0            	ld	(rstsp),sp	;save partial reset state
  0009    22 FFE2               	ld	(rsthl),hl	;in case the luser go boom
  000C    E1                    	pop	hl		;pick possible return off stack
  000D    22 FFE4               	ld	(rstpc),hl
  0010    D9                    	exx			;give primary registers half a break
  0011    1C                    	inc	e
  0012    31 3839               	ld	sp,3839h	;load strange values in SP
  0015    31 4142               	ld	sp,4142h
  0018    4C                    	ld	c,h		;insure
