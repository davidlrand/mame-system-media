  0090    01 FFBF               ddskld:	ld	bc,0ffbfh	;verify validation #-let BC be ROM byte pointer
  0093    ED 78                 	in	a,(c)		;get msb of validation #
  0095    05                    	dec	b		;reset byte pointer
  0096    67                    	ld	h,a		;h <- msb of validation #
  0097    ED 78                 	in	a,(c)		;get lsb of validation #
  0099    05                    	dec	b		;reset byte pointer
  009A    6F                    	ld	l,a		;hl <- validation #
  009B    11 AA56               	ld	de,-valnum	;de <- negative of validation #
  009E    19                    	add	hl,de		;add ROM's val.# to neg. of standard val. #
  009F    7C                    	ld	a,h		;
  00A0    B5                    	or	l		;if invalid ROM validation # then
  00A1    C2 00FD                       jp      nz,lpkbd        ;   jump to low profile keyboard
  00A4    21 F091                       ld	hl,confg	;set configuration byte for 5.25"
  00A7    DB A6                 	in	a,(expbx)	;get id byte
  00A9    05                    	dec	b		;reset byte pointer
  00AA    FE 21                 	cp	rgd5   		;if 5.25 rigid configuration then
  00AC    CA 00B9               	jp	z,ddskid1	;   continue disk driver load
  00AF    FE 20                 	cp	flpy5   	;if not 5.25 floppy configuration then
  00B1    C2 0136               	jp	nz,err2		;   jump to error message
  00B4    3E 14                 	ld	a,flpy5id
  00B6    C3 00BB               	jp	ddskld1
  00B9    3E 24                 ddskid1:ld	a,rgd5id
  00BB    B6                    ddskld1:or	(hl)		;redefine configuration byte
  00BC    77                    	ld	(hl),a		;store configuration byte
  00BD    ED 50                 	in	d,(c)		;d <- msb of driver length
  00BF    05                    	dec	b		;reset byte pointer
  00C0    ED 58                 	in	e,(c)		;e <- lsb of driver length
  00C2    05                    	dec	b		;reset byte pointer
  00C3    ED 60                 	in      h,(c)   	;hl <- RAM address of disk driver
  00C5    05                    	dec	b		;reset byte pointer
  00C6    ED 68                 	in	l,(c)
  00C8    05                    	dec	b		;reset byte pointer
  00C9    E5                    	push    hl		;save RAM starting address
  00CA    19                    	add	hl,de		;hl <- RAM address of last byte of disk driver
  00CB    D5                    	push	de		;save driver length
  00CC    7A                    	ld	a,d		
  00CD    C6 B0                 	add	a,0b0h   	;set port for highest block of ROM
  00CF    4F                    	ld	c,a		;c <- port for highest block in ROM
  00D0    14                            inc     d               ;adjust block counter
  00D1    43                    	ld	b,e		;b <- byte count
  00D2    AF                            xor     a               ;clear a
  00D3    B8                    	cp	b		;if (b=0) then
  00D4    CA 00D9               	jp	z,ddskld3	;   jump to load last byte in block
                                				;Repeat
  00D7    ED BA                 ddskld2:indr			;   input 255 bytes
  00D9    ED AA                 ddskld3:ind			;   input last byte
  00DB    0D                    	dec	c		;   decrement block #
  00DC    15                    	dec	d		;   decrement block counter
  00DD    20 F8                 	jr	nz,ddskld2	;Until all blocks are loaded
  00DF    C1                    	pop	bc		;retrieve driver length
  00E0    E1                    	pop     hl   		;retrieve RAM starting address
  00E1    CD 0124               	call	ccs		;get checksum
  00E4    C2 0136               	jp	nz,err2		;if invalid checksum then ROM error
  00E7    01 F8BF                       ld      bc,0f8bfh       ;high byte of power up address
  00EA    ED 60                         in      h,(c)
  00EC    05                            dec     b
