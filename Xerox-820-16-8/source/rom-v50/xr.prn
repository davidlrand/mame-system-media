Balcones Operating System for the XEROX 820-II	MACRO-80 3.44	09-Dec-81	PAGE	1-19
Monitor Function Processors

                                
                                
                                ;;	Monitor Restart.
                                ;
  F07C    F3                    restart:di			;lock system
  F07D    DB 1C                 	in	a,(syspio)
  F07F    F6 80                 	or	1 shl 7		;enable banked rom
  F081    D3 1C                 	out	(syspio),a
  F083    C3 0000               	jp	prs		;reload monitor from rom or ram
                                
                                ;;	Daytim - Return Address of Time-of-Day.
                                ;
  F086    11 FF56               daytim:	ld	de,day		;point to day of month
  F089    18 0F                 	jr	retval
                                
                                ;;	Config - Return Configuration Status Byte.
                                ;
  F08B    3A F0E3               config:	ld	a,(mask)	;turn keyboard mask into c.keym
  F08E    E6 80                 	and	080h
  F090    F6 00                 	or	0
  F091                          confg	equ	$-1	;*****=>;This word stored by Preset
  F092    5F                    	ld	e,a
  F093    16 64                 	ld	d,rev-400	;return revision level
  F095    18 03                 	jr	retval
                                
                                ;;	getsel - Get address of Select table.
                                ;
  F097    11 F360               getsel:	ld	de,Seltab	;set select table address
                                
