FDE0 	ALL03           FE00 	ALL04           FE80 	ALL05           
FEC0 	ALL06           FEE0 	ALL07           FD00 	CHK00           
FD20 	CHK01           FD40 	CHK02           FD60 	CHK03           
0000 	CHK04           0000 	CHK05           0000 	CHK06           
0000 	CHK07           FC80 	DIRBUF          00C0I'	DPB8D           
00A0I'	DPB8S           0000I'	DPBASE          00E0'	DPBRG4          
00F0'	DPBRG5          0100'	DPBRG6          0110'	DPBRG7          
009AI'	SELERR          0080I'	TRN6            



No Fatal error(s)


