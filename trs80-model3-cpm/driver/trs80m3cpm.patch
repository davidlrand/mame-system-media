+// "CP/M Cheap" hardware mod (Bill Brewer, 80 Microcomputing, March 1983, p112).
+// A replacement address decoder watches bit 0 of the spare output latch at port
+// 0xEC.  REMAP=0 (power-on default, view 0) leaves the stock Model III map;
+// REMAP=1 (view 1) maps RAM over 0x0000-0xF7FF and relocates the keyboard to
+// 0xF800 and video to 0xFC00, giving CP/M a full low-memory TPA.  The bootstrap
+// does OUT (0ECH),9 to enter CP/M mode and OUT (0ECH),8 to return.
+//
+// memory_view is used (rather than address_map_bank_device) so the switchable
+// regions stay in the CPU's own address space: the Model III paces FDC data
+// transfers with the Z80 WAIT line, and the indirect access of a bank device
+// breaks that cycle-tight timing (cf. the 4P's "floppy not working").
+void trs80m3_state::m3cpm_mem(address_map &map)
+{
+	map(0x0000, 0x3fff).view(m_vlow);
+	m_vlow[0](0x0000, 0x37ff).rom().region("maincpu", 0);                                   // REMAP=0: ROM
+	m_vlow[0](0x37e8, 0x37e9).rw(FUNC(trs80m3_state::printer_r), FUNC(trs80m3_state::printer_w));
+	m_vlow[0](0x3800, 0x3bff).r(FUNC(trs80m3_state::keyboard_r));
+	m_vlow[0](0x3c00, 0x3fff).ram().share(m_p_videoram);
+	m_vlow[1](0x0000, 0x3fff).ram().share("lowram");                                        // REMAP=1: RAM
+
+	map(0x4000, 0xf7ff).ram().share("mainram");                                             // RAM in both modes (coherent)
+
+	map(0xf800, 0xffff).view(m_vhigh);
+	m_vhigh[0](0xf800, 0xffff).ram().share("topram");                                       // REMAP=0: RAM
+	m_vhigh[1](0xf800, 0xfbff).r(FUNC(trs80m3_state::keyboard_r));                           // REMAP=1: keyboard
+	m_vhigh[1](0xfc00, 0xffff).ram().share(m_p_videoram);                                    //          video (same RAM)
+}
+
 void trs80m3_state::m3_io(address_map &map)
 {
 	map.global_mask(0xff);
