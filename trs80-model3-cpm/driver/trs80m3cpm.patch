@@ -360,6 +372,12 @@ void trs80m3_state::port_ec_w(uint8_t data)
 		m_cassette->change_state(( data & 2 ) ? CASSETTE_MOTOR_ENABLED : CASSETTE_MOTOR_DISABLED, CASSETTE_MASK_MOTOR );
 
 	m_port_ec = data & 0x7e;
+
+	if (m_cpm_mod)   // "CP/M Cheap" mod: bit 0 = REMAP (1=RAM at 0x0000, 0=ROM at 0x0000)
+	{
+		m_vlow.select(BIT(data, 0));
+		m_vhigh.select(BIT(data, 0));
+	}
 }
 
