@@ -88,7 +88,19 @@ uint8_t trs80m3_state::port_e4_r()
 
 	u8 data = m_nmi_data;
 	m_nmi_data = 0;
-	return ~(m_nmi_mask & data);
+	u8 status = ~(m_nmi_mask & data);
+	// The "CP/M Cheap" BIOS NMI handler reads port 0xE4 (RDNMISTATUS) and tests
+	// for exactly 0x7E on a good FDC-INTRQ NMI -- i.e. it requires bit 7 (Disk
+	// INTRQ, active low) AND bit 0 to read 0.  Bit 0 is undefined on a stock
+	// Model III (tech ref), but a local hardware mod on the author's machine
+	// drove it to 0; the BIOS depends on that.  MAME returns it as 1, so without
+	// this the handler falls to its error path (FORCEINT) and disk I/O never
+	// completes.  Gated to trs80m3cpm because it reflects that machine's mod,
+	// not stock hardware (a faithful stock port_e4_r -- bit 6 is really Disk DRQ,
+	// idle reads 0x3F per trs80gp -- is a separate matter).
+	if (m_cpm_mod)
+		status &= 0xfe;
+	return status;
 }
 
