	TITLE	'DSI-32000 I/O KERNEL'
	start

VIRT:	equ	1

EXEC:	EQU	1
CMOD:	EQU	H'20
VMOD:	EQU	H'5C
DBGMOD:	EQU	H'1F80
DBG:	EQU	DBGMOD+H'C	;DEBUGGER MODULE ENTRY
PRGM:	EQU	H'8C		;PROGRAM'S MAIN MODULE offset
MPRGM:	equ	h'9c		;Program's main module number (offset zero)

;	if	aduart = 1
;DUARCNT:EQU	H'F7FE38
;	endif
;	if	aduart = 0
;DUARCNT:equ	h'200138
;	endif

	;
	;-----------------------------------------------------------------;
	;								  ;
	;  Copyright (C) 1985 by Definicon Systems Inc.			  ;
